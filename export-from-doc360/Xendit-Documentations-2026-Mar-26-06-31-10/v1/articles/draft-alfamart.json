[{"Code":"en","Title":"Alfamart","Slug":"draft-alfamart","ContentType":2,"Content":"<p data-block-id=\"mmbpc6c2-d639wy-919\"><a id=\"_j5wih1vxvjn6\" display=\"false\"></a></p><h1 data-block-id=\"mmbpc6c5-gbwezj-920\"><a id=\"_rgwl05coo69f\" display=\"false\"></a></h1><h2 data-block-id=\"mmbpc6c7-t3pmm3-921\"><a id=\"_9j6h54imkhti\" display=\"false\"></a>Glossary</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-piw7lg-922\"><strong>Terms</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-mzjssu-923\"><strong>Description</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-c58muv-924\">Spotdraft</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-4k8ldy-925\">Platform to process e-sign</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-qmvktt-926\">Prefix</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-6xrldq-927\">unique alphanumeric code will be used to identify payment</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-jyk3fw-928\">MID </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-gbvtam-929\">unique identifier code auto generate by system</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ce-tfrci2-930\">Cashpay</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cf-eyqevg-931\">Xendit’s product team that handles retail outlet</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cf-d684c4-932\">Alfamart Form</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cf-mexp20-933\">Form that used to apply alfamart</p></th></tr></tbody></table></div><h1 data-block-id=\"mmbpc6cf-00l35o-934\"><a id=\"_cgq5oqxzdqds\" display=\"false\"></a></h1><h2 data-block-id=\"mmbpc6cf-r132wu-935\"><a id=\"_ejxly55we75x\" display=\"false\"></a></h2><h1 data-block-id=\"mmbpc6ch-38d50d-951\"><a id=\"_li62zw85vogf\" display=\"false\"></a></h1><h2 data-block-id=\"mmbpc6ch-w6py0i-952\"><a id=\"_d758rtuj0pwc\" display=\"false\"></a>Partner PIC</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ci-kicqbp-953\"><strong>Name</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ci-3qxixb-954\"><strong>Email</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-as9gld-955\">Kania A Olisvelos</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-jamjtg-956\">kania.a.olisvelos@sat.co.id,</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-7lt6tt-957\">Andreas Tulus S</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-c9wc9n-958\">andreas.t.sedyanto@sat.co.id</p></th></tr></tbody></table></div><h1 data-block-id=\"mmbpc6ck-55p0ty-959\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a></h1><h2 data-block-id=\"mmbpc6ck-mxmj0y-960\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a>Eligibility</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-24jstq-961\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-znodhx-962\"><strong>Can Apply for Alfamart</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-168e46-963\">Indonesian Entity (PT/CV/Yayasan)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ck-ml4hfr-964\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cl-vgxhvo-965\">Indonesian Entity (Perseroan perorangan/PP)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cl-343w1x-966\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cl-07ep6n-967\">Indonesian Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cl-tiw5hb-968\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cl-0uhkqj-969\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cl-tl6v38-970\">✅</p></th></tr></tbody></table></div><h2 data-block-id=\"mmbpc6cl-swpjmw-971\"><a id=\"_6c0oxkffxx60\" display=\"false\"></a>Merchant Requirements </h2><p data-block-id=\"mmbpc6co-xkotdh-973\">Below are the requirements that a merchant has to submit, whether it’s upon onboarding or CA application request</p><p data-block-id=\"mmbpc6co-xkotdh-973\"><br type=\"inline\"><strong>Indonesian Individual: </strong></p><ul data-block-id=\"mmbpc6co-rkaskf-975\"><li data-block-id=\"mmbpc6co-l9rtr3-976\"><p data-block-id=\"mmkaav70-hj6n0p-236\">ID Card</p></li><li data-block-id=\"mmbpc6co-0a7qo5-977\"><p data-block-id=\"mmkaav71-0lgzyu-237\">Complete Address</p></li><li data-block-id=\"mmbpc6co-0sb3gh-978\"><p data-block-id=\"mmkaav71-uf5c65-238\">PIC Name, Mobile number, and Email Address</p></li></ul><p data-block-id=\"mmbpc6co-784r2w-979\"><br type=\"inline\"><strong>Indonesian Entity:</strong> </p><ul data-block-id=\"mmbpc6co-lfcnu0-981\"><li data-block-id=\"mmbpc6co-7ey55v-982\"><p data-block-id=\"mmkaav71-rhuyiq-239\">Date of Establishment (refer to Akta Pendirian)</p></li><li data-block-id=\"mmbpc6co-shuzyr-983\"><p data-block-id=\"mmkaav71-f1i1tt-240\">SIUP or NIB number</p></li><li data-block-id=\"mmbpc6co-7vr354-984\"><p data-block-id=\"mmkaav71-hdziv2-241\">NPWP number of the company </p></li><li data-block-id=\"mmbpc6co-kpcvzc-985\"><p data-block-id=\"mmkaav71-f1us49-242\">PIC Name, Mobile number, and Email Address</p></li></ul><h2 data-block-id=\"mmbpc6co-g1hnri-986\"><a id=\"_ujkex4eg0uw0\" display=\"false\"></a>SLA</h2><p data-block-id=\"mmbpc6co-beld2c-987\">Alfamart activated in 3 working days from the date merchant submits complete requirements to MO</p><h2 data-block-id=\"mmbpc6co-7cl17k-988\"><a id=\"_r0miqi6pvfyc\" display=\"false\"></a>Onboarding Flow</h2><h1 data-block-id=\"mmbpc6co-462vmf-989\"><a id=\"_ugj9tkstyf4d\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6co-bhxdbf-990\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cp-y0dj1x-991\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cr-nul8ms-992\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cr-l2fbhh-993\"><strong>Owner</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cs-ieqon4-994\">Merchant applies for Alfamart</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cs-5lk7rz-995\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ct-bd7sx0-996\">Merchant submits request by clicking activate button on add payment methods tab on  merchant dashboard <a href=\"https://dashboard.xendit.co/settings/payment-methods\"><u>https://dashboard.xendit.co/settings/payment-methods</u></a></p><p data-block-id=\"mmbpc6ct-xaozm1-997\"><img data-block-id=\"mmbpc6ct-ynpbj0-998\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-r8vaizzs.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ct-1l9k3w-999\">Merchant Dashboard</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaav72-4zsjbp-243\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ct-hxg9rt-000\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ct-lirs9z-001\"> Merchant’s Alfamart activation request will visible in Channel Activation dashboard with status New </p><p data-block-id=\"mmbpc6ct-oo07io-002\"><img data-block-id=\"mmbpc6ct-parpf5-003\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-a84oy72h.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6ct-gqdi6z-004\">Click edit and MO check merchant’s detail </p><p data-block-id=\"mmbpc6ct-e91s5u-005\">MO need to check : </p><ul data-block-id=\"mmbpc6ct-0xm0g7-006\"><li data-block-id=\"mmbpc6ct-svwzi4-007\"><p data-block-id=\"mmkaav72-eswshd-244\">Business name not more than 25 character</p></li></ul><p data-block-id=\"mmbpc6ct-4fgqdl-008\"><img data-block-id=\"mmbpc6ct-gcupte-009\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-sey4bttn.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ct-po2xhh-010\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6ct-hk7sdr-011\">Signing Preparation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cu-w7ynx8-012\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cu-m185ag-013\">MO need to generate Alfamart form &amp; process signing request before submitting to Alfamart</p><p data-block-id=\"mmbpc6cu-rmvi02-014\">Click 3 dots in Alfamart dashboard and click Download PDFs</p><p data-block-id=\"mmbpc6cu-f7un29-015\"><img data-block-id=\"mmbpc6cu-a1v19i-016\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-lkk2o5wx.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cu-4k9jr4-017\">Once MO click Download PDFs, this action will automatically download all new merchant’s Alfamart request application form</p><p data-block-id=\"mmbpc6cu-g6r0gb-018\">MO also can download manually by clicking PDF button</p><p data-block-id=\"mmbpc6cu-ey0e0k-019\"><img data-block-id=\"mmbpc6cu-2richf-020\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-x893bkd9.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cu-g51j72-021\">We’ll get a pop up message, then click View and continue click download </p><p data-block-id=\"mmbpc6cu-5oamsj-022\"><img data-block-id=\"mmbpc6cu-amf6x0-023\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-mun1w175.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cu-y6bhjz-024\">Attached is Alfamart form from channel activation dashboard </p><p data-block-id=\"mmbpc6cu-j3gx63-025\"><img data-block-id=\"mmbpc6cu-r6al5v-026\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-h33e7nac.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cu-l1a92m-027\">Once alfamart form successfully downloaded, MO need to make sure form naming is correct, with format </p><p data-block-id=\"mmbpc6cu-rv6bl1-028\"><strong>Business Name - Alfamart Application</strong></p><p data-block-id=\"mmbpc6cu-fkbzeh-029\">Merchant’s status will updated to : awaiting_esign_from_customer</p><p data-block-id=\"mmbpc6cu-yxzajd-030\"><img data-block-id=\"mmbpc6cu-dokhtj-031\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-0cz6dt1a.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cu-tedv8m-032\">Alfamart Dashboard</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cu-2nu9b2-033\">Signing Process</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cu-8mdjdi-034\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cu-x9cscn-035\">MO will proceed Alfamart form for signing request  through <a href=\"https://app.spotdraft.com/home\"><u>Spotdraft </u></a></p><p data-block-id=\"mmbpc6cu-u76tea-036\">Click on + icon, this will show dropdown of contract signing type</p><p data-block-id=\"mmbpc6cu-uzolkc-037\"><img data-block-id=\"mmbpc6cu-nfh5eo-038\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-5gkq5to6.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cu-il4aof-039\">For Alfamart, choose Send for Signature, drag or upload file of Alfamart form for signing </p><p data-block-id=\"mmbpc6cu-y3xavs-040\"><img data-block-id=\"mmbpc6cv-b2s3zf-041\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-rr92860y.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-b1vv8e-042\">Click next</p><p data-block-id=\"mmbpc6cv-1u2oso-043\"><img data-block-id=\"mmbpc6cv-e8zyjn-044\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-jj0grly9.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-3g0c0o-045\">Next step is fill the dropdown, and for the contract type,  choose<em> Alfamart: Product Application Form</em></p><p data-block-id=\"mmbpc6cv-ttje8w-046\"><img data-block-id=\"mmbpc6cv-liqvft-047\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-s7h0cmcw.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-ez42db-048\">For the counterparty name, put merchant’s name / Legal name, if merchant’s name already listed, just checklist on the merchant’s name, <img data-block-id=\"mmbpc6cv-wt6fel-049\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-nqpfoypp.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-e2ar1h-050\">if not available yet fill in merchant’s name and click add or + icon</p><p data-block-id=\"mmbpc6cv-mhv67v-051\"><img data-block-id=\"mmbpc6cv-foi4ws-052\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-uc8c2sqj.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-06zwtf-053\">Click upload once data filled in </p><p data-block-id=\"mmbpc6cv-dezkn0-054\"><img data-block-id=\"mmbpc6cv-4tqlwv-055\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-orqplm7w.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-hc3lyz-056\">Once form successfully uploaded, MO prepare for signing the form</p><p data-block-id=\"mmbpc6cv-lx0arj-057\"><img data-block-id=\"mmbpc6cv-bim61h-058\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-iglatv50.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-wpj2m0-059\">This Alfamart form need to be signed by Xendit PIC &amp; Merchant, and MO need to add manually the receiver by adding email manually</p><p data-block-id=\"mmbpc6cv-aeiqzc-060\">Click add recipient</p><p data-block-id=\"mmbpc6cv-7ojwk9-061\"><img data-block-id=\"mmbpc6cv-scvacl-062\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-d7c5x9ew.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-krd38k-063\">In the dropdown Party,  choose PT Sinar Digital Terdepan</p><p data-block-id=\"mmbpc6cv-x0qy1u-064\"><img data-block-id=\"mmbpc6cv-gucqr0-065\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-id72kt2d.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-1fp2o2-066\">In Recipient type, choose Receiver / Viewer</p><p data-block-id=\"mmbpc6cv-i9ug89-067\"><img data-block-id=\"mmbpc6cv-j25iky-068\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-q5pkzxe2.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-wg5hrb-069\">Type MO email <a><u>merchops@xendit.co</u></a> as recipient</p><p data-block-id=\"mmbpc6cv-cx6ad2-070\"><img data-block-id=\"mmbpc6cv-onaic1-071\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-15lc8ug2.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-20iw5o-072\">Click Save and Close </p><p data-block-id=\"mmbpc6cv-biya4w-073\"><img data-block-id=\"mmbpc6cv-tjm1tv-074\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-syxpp1yq.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cv-836okf-075\">Before signing request, MO need to put signing field in Alfamart form by click assign field </p><p data-block-id=\"mmbpc6cv-980znj-076\"><img data-block-id=\"mmbpc6cw-k28ltd-077\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-y98v6vhu.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-cjbwbi-078\">Drag signature column to the designated name</p><p data-block-id=\"mmbpc6cw-jajbdf-079\"><img data-block-id=\"mmbpc6cw-5mi4me-080\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-98t3g521.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-8fav18-081\"><img data-block-id=\"mmbpc6cw-avhjhi-082\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-p8f13f68.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-l1f18p-083\">Once the signatory field completed, Click Review and Send</p><p data-block-id=\"mmbpc6cw-pjbk2p-084\"><img data-block-id=\"mmbpc6cw-pi351w-085\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-0jy18oe3.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-qsznpb-086\">And continue click Send for Signature</p><p data-block-id=\"mmbpc6cw-xy27jw-087\"><img data-block-id=\"mmbpc6cw-vf2ejx-088\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-v5dczdst.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-644eb5-089\">Once MO click signing, the request will listed as Signing</p><p data-block-id=\"mmbpc6cw-koevdv-090\"><img data-block-id=\"mmbpc6cw-o1tbc5-091\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-ahpejswp.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-p6dbdy-092\">Once Alfamart form is fully signed by both party, status in Spotdraft will updated to Executed </p><p data-block-id=\"mmbpc6cw-i9nrlu-093\"><img data-block-id=\"mmbpc6cw-5svn21-094\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-vr70w8l4.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-uayihx-095\">And MO also get notification on slack channel <a href=\"https://xendit.slack.com/archives/C02B3H10FR8\"><u>#hellosign-alfamart-kredivo</u></a></p><p data-block-id=\"mmbpc6cw-wrm94l-096\"><img data-block-id=\"mmbpc6cw-0ih78r-097\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-kxel6tap.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cw-i6s4uk-098\">MO can download fully signed forms in Spotdraft or in slack channel. </p><p data-block-id=\"mmbpc6cw-ho0k2x-099\">In Spotdraft, click Download contract</p><p data-block-id=\"mmbpc6cw-giu1lu-100\"><img data-block-id=\"mmbpc6cw-66c6xt-101\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-ccbybz9e.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cw-h60p4o-102\">Spotdraft</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cw-ricfcw-103\">Form Submission</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cw-3q4i3c-104\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cx-vnvwpf-105\">Before submitting Alfamart form to partner, MO need to upload fully signed form in Alfamart Dashboard</p><p data-block-id=\"mmbpc6cx-zr3ojs-106\">Click the PDF button</p><p data-block-id=\"mmbpc6cx-m6xsj3-107\"><img data-block-id=\"mmbpc6cx-ravntm-108\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-otm4100h.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-flyinz-109\">We’ll get a pop up message, click Upload, and upload the fully signed form </p><p data-block-id=\"mmbpc6cx-i0pew3-110\"><img data-block-id=\"mmbpc6cx-bxf8uh-111\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-dodmevdb.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-fq7bwo-112\">Select file and click upload </p><p data-block-id=\"mmbpc6cx-bnxnhj-113\"><img data-block-id=\"mmbpc6cx-q3u54m-114\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-eftuvend.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-ltwyn4-115\"><img data-block-id=\"mmbpc6cx-jpozcd-116\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-kodyntc0.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-t6vkvn-117\">Once form successfully uploaded, the view button will change to blue</p><p data-block-id=\"mmbpc6cx-j2qyb8-118\"><img data-block-id=\"mmbpc6cx-61oooy-119\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-u8apqr02.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cx-i1c7e0-120\">Alfamart Dashboard</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cx-o2eszk-121\">Submit Form</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cx-eb1ki1-122\">6</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cx-474ze8-123\">MO will submit Alfamart form in bulk from channel activation dashboard, click the three dots, click Email to Alfamart</p><p data-block-id=\"mmbpc6cx-zq2xxz-124\"><img data-block-id=\"mmbpc6cx-crezfx-125\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-5gokgrhn.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-gnlywe-126\">Choose the date range</p><p data-block-id=\"mmbpc6cx-qrosc0-127\"><img data-block-id=\"mmbpc6cx-itxde6-128\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-s6tv1j2q.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-383ufg-129\"><em>📝please notes, when set the date ranges, it’s refer to merchant’s submission time / request for Alfamart activation </em><strong><em>not</em></strong><em> the date of submission to partner </em></p><p data-block-id=\"mmbpc6cx-gmy8go-130\">Click submit and checklist on the merchant’s name / BID and click Email to Alfamart</p><p data-block-id=\"mmbpc6cx-rb4ish-131\"><img data-block-id=\"mmbpc6cx-2nbze8-132\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-mgp9evnk.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-po1u01-133\">Make sure click Yes on the confirmation pop up message</p><p data-block-id=\"mmbpc6cx-rxtxq1-134\"><img data-block-id=\"mmbpc6cx-ezebyu-135\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-ar79uaps.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cx-a8437h-136\">Once MO click confirm, this automatically send submission email to Alfamart</p><p data-block-id=\"mmbpc6cx-o6nyu6-137\">Attached is email sent to partner</p><p data-block-id=\"mmbpc6cx-47l21b-138\"><img data-block-id=\"mmbpc6cy-n0tawy-139\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-f425hidw.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cy-peho5f-140\">Status merchant on Channel Activation dashboard will update to <strong>awaiting_feedback_from_alfamart</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaav77-xzx5gu-245\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cy-977j2u-141\">Submission Feedback</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaav77-3yrvem-246\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cy-elhm96-142\">Alfamart team will review the merchant’s application detail and will get back to MO and inform MO if  merchant has been registered in Alfamart system </p><p data-block-id=\"mmbpc6cy-qmtc1o-143\"><img data-block-id=\"mmbpc6cy-7q171d-144\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-5ajsj25m.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cy-onr4xf-145\">Alfamart </p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cy-s3v84z-146\">Alfamart Activation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cy-9xb1qz-147\">7</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cy-43pa2q-148\">Go to Alfamart dashboard, MO can use filter to check which merchant with status <em>awaiting_feedback_from_alfamart</em></p><p data-block-id=\"mmbpc6cy-kzn3w3-149\"><img data-block-id=\"mmbpc6cy-s62gj3-150\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-oqxttldy.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cy-dhd6ii-151\">Once Alfamart give feedback, MO need to activate Alfamart in dashboard</p><p data-block-id=\"mmbpc6cy-lreawt-152\">Click edit</p><p data-block-id=\"mmbpc6cy-auoq2b-153\"><img data-block-id=\"mmbpc6cy-eyheg4-154\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-0mjqyvd3.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cy-amcgwe-155\">And continue click Activate</p><p data-block-id=\"mmbpc6cy-f17oeu-156\"><img data-block-id=\"mmbpc6cy-07jieb-157\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-2j0szx5k.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cz-7w2mwo-158\">We’ll get a pop up message as confirmation, and click activate</p><p data-block-id=\"mmbpc6cz-554bbk-159\"><img data-block-id=\"mmbpc6cz-a5d9jh-160\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-iha0sq0s.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cz-6puil3-161\">Merchant’s status in Alfamart dashboard will updated to Live</p><p data-block-id=\"mmbpc6cz-vkva2n-162\"><img data-block-id=\"mmbpc6cz-fln2bf-163\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-mntr10gl.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmbpc6cz-3vttpg-164\">Merchant will get activation notification email</p><p data-block-id=\"mmbpc6cz-d4u9xc-165\"><img data-block-id=\"mmbpc6cz-l9jh2v-166\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-alfamart-image-vboiypgk.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmbpc6cz-79yx4c-167\">Dashboard - Email</p></th></tr></tbody></table></div><p data-block-id=\"mmkaav79-z2le16-247\"></p>","SeoTitle":"Alfamart","Description":null},{"Code":"id","Title":"Alfamart","Slug":"alfamart-1","ContentType":2,"Content":null,"SeoTitle":"Alfamart","Description":null},{"Code":"th","Title":"Alfamart","Slug":"alfamart-1","ContentType":2,"Content":null,"SeoTitle":"Alfamart","Description":null},{"Code":"es-mx","Title":"Alfamart","Slug":"alfamart-1","ContentType":2,"Content":null,"SeoTitle":"Alfamart","Description":null}]