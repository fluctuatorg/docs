[{"Code":"en","Title":"Mandiri Cards - Aggregator","Slug":"draft-mandiri-cards-aggregator","ContentType":2,"Content":"<p data-block-id=\"mm4hjmi0-g39pi6-001\"><a id=\"_vpxm85nexyyh\" display=\"false\"></a></p><h2 data-block-id=\"mm4hjmi1-hnzqm9-002\"><a id=\"_ejxly55we75x\" display=\"false\"></a>Xendit Stakeholders</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi2-wm4x90-003\"><strong>Department</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi2-flixe0-004\"><strong>PIC</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi2-dyxmja-005\"><strong>PIC Role</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi2-1vm88l-006\">Partnership</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi3-bwj8uh-007\"><a><u>Vanadia Sofaria</u></a></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi3-dg4lgu-008\">Partnership PIC for Mandiri</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi3-e5av9p-009\">Cards Team</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi4-4d4cvv-010\"><u>Simon</u></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi4-oiy8eg-011\">Product Manager (Cards)</p></th></tr></tbody></table></div><h1 data-block-id=\"mm4hjmi4-hrhy4v-012\"><a id=\"_eo72pz5za9ta\" display=\"false\"></a></h1><h2 data-block-id=\"mm4hjmi4-u0og9h-013\"><a id=\"_x5gzec6f0lg\" display=\"false\"></a>Related Documents</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi4-elgnud-014\"><strong>Document name</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi4-cxe5uz-015\"><strong>Description</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi4-wgmol9-016\"><strong>Link to document</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi5-fp73j1-017\">MID Account Creation on Cybersource Portal (EBC)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi5-lnb5ya-018\">Step of MID configuration on EBC and Admin Dashboard</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi5-1czv7w-019\"><a href=\"https://docs.google.com/document/u/0/d/1WXkraNDpZcvA_CPsWKWD4MDm8D0KOlmplUOzecF05IY/edit\"><u>MID Account Creation on Cybersource Portal (EBC)</u></a></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi5-wpyl5i-020\">Mandiri Aggregator Cards Onboarding - Guide</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi5-n3ezcw-021\">High Level Onboarding docs</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi6-uhu520-022\"><a href=\"https://docs.google.com/document/u/0/d/1nnovkiRPS7I4SpYQOf0VsIsIk-fyoPqavUFrTIOVFY0/edit\"><u>Mandiri Aggregator Cards Onboarding - Guide</u></a></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi6-83ym0t-023\">Form</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi6-ssisy7-024\">Form need to be fill for registration process</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi6-w7hsa0-025\"><a href=\"https://docs.google.com/document/u/0/d/1s5CeP_tBjMgBNfqIwdBc2K6cz2cSe9Mu/edit\"><u>Draft Surat Rekomendasi Merchant Agregator v4_rpf2.docx</u></a></p></th></tr></tbody></table></div><h1 data-block-id=\"mm4hjmi6-5m8f80-026\"><a id=\"_1869wc89osrc\" display=\"false\"></a></h1><h2 data-block-id=\"mm4hjmi6-tto4ty-027\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a>Eligibility</h2><h1 data-block-id=\"mm4hjmi6-6508mc-028\"><a id=\"_audslu4b8jx\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi6-x0j74n-029\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi7-90266t-030\"><strong>Can Apply for Mandiri Cards Aggregator</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi7-0z9s3b-031\">Indonesian Entity (PT/CV/Yayasan)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi7-myuj08-032\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi7-5c1xfh-033\">Indonesian Entity (Perseroan perorangan/PP)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi7-xf9jqa-034\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi7-44x81u-035\">Indonesian Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi8-oshu8i-036\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi8-fh7h8l-037\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi8-2w9ccv-038\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi8-n3pgpc-039\">Foreign Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi8-0nf0rq-040\">❌</p></th></tr></tbody></table></div><h2 data-block-id=\"mm4hjmi8-imwqik-041\"><a id=\"_acexhig5p7db\" display=\"false\"></a>Industry Restriction</h2><p data-block-id=\"mm4hjmi8-3vc5sn-042\"><em>*) notes: there were some exceptions made if sales are really pushing for this. MO will to coordinate with partnership for partnerships to negotiate with partner</em></p><h1 data-block-id=\"mm4hjmi8-z87iut-043\"><a id=\"_opno5zvq83i1\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi9-yr8gs7-044\"><strong>Industry</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi9-88vcdx-045\"><strong>List of Business</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"5\"><p data-block-id=\"mm4hjmi9-bu7mq5-046\">Pornographic/adult services/night club</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi9-l6utok-047\">Sale of dangerous products/services, i.e. weaponry, illegal drugs, and narcotics</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi9-gcvuqd-048\">Gambling</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmi9-0cmo1b-049\">Sale of fake/imitated goods in which breaches the intellectual/property rights</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmia-wvesy8-050\">Merchants that indicated/suspected as platform offering illegal cash-out (gesek tunai/gestun)</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmia-lmx8nw-051\">Jasa Titip</p></th></tr><tr><th colspan=\"1\" rowspan=\"6\"><p data-block-id=\"mm4hjmia-7l7r7y-052\">Financial institutions</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmia-rdszgr-053\">Banks and Remittance</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmia-djr8vw-054\">Peer to Peer lending without license/not registered in Otoritas Jasa Keuangan (OJK)</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmia-yh3t10-055\">Payment Gateway or business that can potentially act as an aggregator</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmib-5gg8aq-056\">Merchants classified as Financial Tech or Digital Finance companies without Bank Indonesia license</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmib-3onuvh-057\">Merchants classified as Financial Tech companies without license/not registered in OJK</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmib-xi30bx-058\">Cryptocurrency</p></th></tr><tr><th colspan=\"1\" rowspan=\"3\"><p data-block-id=\"mm4hjmib-aerorb-059\">Non-financial businesses that require licensing</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmib-pgbjtq-060\">Sale of alcohol/liquor/booze without license</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmib-l0dpi8-061\">Sale of living creatures without license i.e breeder, kennel, adoption center</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmic-net69i-062\">Business which pr no oduct/services is yet to be licensed by authorities</p></th></tr></tbody></table></div><h1 data-block-id=\"mm4hjmic-jzpzl3-063\"><a id=\"_p9ni9b15e5wm\" display=\"false\"></a></h1><h2 data-block-id=\"mm4hjmic-xrvdn5-064\"><a id=\"_mlq067tta99i\" display=\"false\"></a>Onboarding flow</h2><h3 data-block-id=\"mm4hjmic-el8mz7-065\"> <span type=\"spanMark\" style=\"font-size:16px;\">Merchant Requirements </span></h3><p data-block-id=\"mm4hjmic-89po24-068\">Below are the requirements that a merchant has to submit, whether it’s upon onboarding or VA application request</p><h3 data-block-id=\"mm4hjmic-iwoi8p-069\"><a id=\"_6qs1laq7u8zd\" display=\"false\"></a><span type=\"spanMark\" style=\"font-size:18px;\">Onboarding</span></h3><ol data-block-id=\"mm4hjmic-vvqkcr-070\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm4hjmic-434rd1-071\"><p data-block-id=\"mm4hkqtk-klerk0-216\">Form Mandiri Aggregator </p></li><li data-block-id=\"mm4hjmic-x8vc45-072\"><p data-block-id=\"mm4hkqtk-me0k0j-217\"><a href=\"https://docs.google.com/document/d/1s5CeP_tBjMgBNfqIwdBc2K6cz2cSe9Mu/edit\"><u>Form Mandiri Cards Aggregator</u></a></p></li><li data-block-id=\"mm4hjmic-iojsvd-073\"><p data-block-id=\"mm4hkqtk-n7srn5-218\">Website</p><ol data-block-id=\"mm4hjmic-4tax9o-074\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm4hjmid-c21ffs-075\"><p data-block-id=\"mm4hkqtk-4ih0b7-219\">No Social Media and Micro-Ecommerce</p></li><li data-block-id=\"mm4hjmid-9bzykx-076\"><p data-block-id=\"mm4hkqtk-ji09k1-220\">If a website, website must be active and fully running, i.e:</p><ol data-block-id=\"mm4hjmid-2pbfut-077\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm4hjmid-qa21v1-078\"><p data-block-id=\"mm4hkqtk-qgo65x-221\">Link is accessible</p></li><li data-block-id=\"mm4hjmid-veohu8-079\"><p data-block-id=\"mm4hkqtk-npky88-222\">Show product/ service</p></li><li data-block-id=\"mm4hjmid-vrxnfb-080\"><p data-block-id=\"mm4hkqtl-j6t6we-223\">Price in IDR</p></li><li data-block-id=\"mm4hjmid-nf2xoa-081\"><p data-block-id=\"mm4hkqtl-n1cosg-224\">Not a template or “coming soon” website</p></li></ol></li><li data-block-id=\"mm4hjmid-7gdxec-082\"><p data-block-id=\"mm4hkqtl-3pd9zk-225\">If an app, app is listed in PlayStore / AppStore</p></li></ol></li></ol><h2 data-block-id=\"mm4hjmid-91af90-083\"><a id=\"_eer2kk965by4\" display=\"false\"></a>Activation SLA</h2><p data-block-id=\"mm4hjmid-xf67mp-084\">Mandiri Cards Aggregator activated in 21 working days from the date merchant submits complete requirements to MO</p><h1 data-block-id=\"mm4hjmid-ik5jp1-085\"><a id=\"_dyjk5zsj8pp1\" display=\"false\"></a></h1><h2 data-block-id=\"mm4hjmid-tw7tol-086\"><a id=\"_m5b14r4s1l6z\" display=\"false\"></a>Onboarding Steps</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:50px;\"><col style=\"width:250px;\"><col style=\"width:105px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmid-47z0st-087\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmid-2evjym-088\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmid-qjy5vm-089\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmie-pygbqf-090\"><strong>Owner</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmie-ji34kl-091\">Merchant applies for Mandiri cards Aggrgator</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmie-xdj9ox-092\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmie-g2nvgr-093\">AM/Sales make request in <strong>#mo-request channel in slack </strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmie-xkpv3u-094\">Sales/AM</p></th></tr><tr><th colspan=\"1\" rowspan=\"5\"><p data-block-id=\"mm4hjmie-67cet2-095\">MO Process Merchant’s Application</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmif-xh699s-096\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmif-r8nfg4-097\">MO will direct sales/AM to fill in the <a href=\"https://docs.google.com/forms/d/e/1FAIpQLSdjyRSewzWHOCnSSQe3RqX06ELY4DHbA1MI43p9-uQCDjmgbQ/viewform\"><u>G-form </u></a></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmif-li0wk2-098\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmif-337j7u-099\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmif-eu6hls-100\">MO will send the form via spotdraft to Bu Susanti with subject <strong><em>Form - {Merchant Name} Mandiri Aggregator</em></strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmif-mle7j8-101\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmif-wf76rk-102\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmig-ud239n-103\">MO have to check this channel <strong>#hellosign-alfamart-kredivo-Mandiri</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmig-bqu1qv-104\">Merchant</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmig-c7p835-105\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmig-s9c10y-106\">Once signed, MO has to submit the form to Mandiri. <br type=\"inline\"><br type=\"inline\">To:<em> </em><a><em><u>ecommerce@yokke.co.id</u></em></a><em>, </em><a><em><u>Dea.Asril@bankmandiri.co.id</u></em></a><em> <br type=\"inline\">Cc:  </em><a><em><u>ferdinand@xendit.co</u></em></a><em> , </em><a><em><u>merchantops@xendit.co</u></em></a><em>, </em><a><em><u>cards@xendit.co</u></em></a><em>, </em></p><p data-block-id=\"mm4hjmih-azd8ek-109\"><strong><em>AM/Sales email address</em></strong><em>, </em><a><em><u>alvin.kristanto@xendit.co</u></em></a><em>, </em><a><em><u>syuhada.sipayung@xendit.co</u></em></a><em> <br type=\"inline\"><br type=\"inline\">Body email: <br type=\"inline\"><br type=\"inline\">Dear Tim Mandiri,</em></p><p data-block-id=\"mm4hjmih-9d2wtf-110\"><em>Berikut terlampir pengajuan pendaftaran Cards Aggregator Xendit pada </em><strong><em>XXX</em></strong><em>. Total terdapat </em><strong><em>X</em></strong><em> merchant :</em></p><ol data-block-id=\"mm4hjmih-vqmslr-111\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm4hjmih-rcg6h1-112\"><p data-block-id=\"mm4hkqtn-7y4tjt-226\"><strong><em>XXX</em></strong></p></li><li data-block-id=\"mm4hjmih-010ei7-113\"><p data-block-id=\"mm4hkqtn-ltm8pd-227\"><strong><em>XXX</em></strong></p></li></ol><p data-block-id=\"mm4hjmih-kkif37-114\"><em>Mohon untuk dapat diproses dan didaftarkan. Apabila terdapat kekurangan informasi maupun dokumen harap menghubungi kami kembali.</em></p><p data-block-id=\"mm4hjmih-h4fd8d-115\"><em>Atas perhatian dan kerjasamanya, kami ucapkan terima kasih<br type=\"inline\"><br type=\"inline\">Best Regards, <br type=\"inline\">MerchantOps<br type=\"inline\"><br type=\"inline\"></em></p><p data-block-id=\"mm4hjmii-rp9byj-116\">Example of email: <br type=\"inline\"><img data-block-id=\"mm4hjmii-qfq4oy-119\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-mandiri-cards-aggregator-image-ljq13i6k.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmii-zhovnb-120\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmii-n3xo1h-121\">6</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmii-qzck89-122\">Mandiri will give the MID by replying to MerchantOps email, and MO have to onboard it to the <a href=\"https://ebc.cybersource.com/ebc2/\"><u>EBC</u></a> portal by following this <a href=\"https://docs.google.com/document/d/1WXkraNDpZcvA_CPsWKWD4MDm8D0KOlmplUOzecF05IY/edit#heading=h.y5exo0trfxfa\"><u>SOP</u></a>. </p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmij-4ih0qk-123\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"3\"><p data-block-id=\"mm4hjmij-hsph47-124\">Cards Testing</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmij-8l54cy-125\">7</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmij-l6vpw3-126\">After onboard to EBC Portal, MO will tag<strong> @merchantops-id-cards </strong>to do UAT.  </p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmij-zkv2qp-127\">MO Cards</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmij-jagjos-128\">8</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmij-7qurv1-129\">After the UAT process is completed, MO cards will fill this <a href=\"https://docs.google.com/spreadsheets/d/1C48TeyLt9sTWajzF2XxbEjcLDaevpijqtHwd7uygu-k/edit#gid=559110446\"><u>sheet</u></a> and  ask Finops regarding the settlement. Template below<br type=\"inline\"><br type=\"inline\"></p><p data-block-id=\"mm4hjmik-6nkjl4-132\"><em>[Checking Settlement Mandiri Cards Aggregator Testing Transaction]</em></p><p data-block-id=\"mm4hjmik-sr8xog-133\"><em>Hi @finops, kindly need your help to confirm settlement on cards aggregator testing transaction for Mandiri Cards Aggregator Channel Activation. Please note:</em></p><ol data-block-id=\"mm4hjmik-cq5tni-134\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm4hjmik-0jmq7m-135\"><p data-block-id=\"mm4hkqtp-hrdqrx-228\"><em>Please Checklist Settlement Check Column if the fund are settled.</em></p></li><li data-block-id=\"mm4hjmik-ffpyr6-136\"><p data-block-id=\"mm4hkqtp-o4mbcj-229\"><em>Please write in the notes column if the fund are not settled.</em></p></li></ol><p data-block-id=\"mm4hjmik-c9i0qx-137\"><em>For the details of transaction can be access on this (link), please let us know if all the fund settled on the bank account and Please Let me know If you need other info regarding the transaction.</em></p><p data-block-id=\"mm4hjmik-ei2wy4-138\"><em>Thank you :prayge:</em></p><p data-block-id=\"mm4hjmik-lfthbk-139\"><em>cc: @phelia @Jess @merchantops-id-cards</em></p><p data-block-id=\"mm4hjmik-wp4l24-140\"><em><br type=\"inline\"><img data-block-id=\"mm4hjmik-t3tzrl-142\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-mandiri-cards-aggregator-image-wakle2rq.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></em></p><p data-block-id=\"mm4hjmik-xxbhjd-143\"><br type=\"inline\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmik-q0w8sf-145\">MO Cards</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mm4hjmik-34go2h-146\">9</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm4hjmik-54zubl-147\">Will inform merchant notification that Mandiri Cards Aggregator is ready to use. </p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"105\"><p data-block-id=\"mm4hjmil-88xog1-148\">MO</p></th></tr></tbody></table></div><h1 data-block-id=\"mm4hjmil-liadwk-149\"><a id=\"_u6759hdxmhnz\" display=\"false\"></a></h1><p data-block-id=\"mm4hkqtq-twvm3r-230\"></p>","SeoTitle":"Mandiri Cards - Aggregator","Description":null},{"Code":"id","Title":"Mandiri Cards - Aggregator","Slug":"mandiri-cards-aggregator","ContentType":2,"Content":null,"SeoTitle":"Mandiri Cards - Aggregator","Description":null},{"Code":"th","Title":"Mandiri Cards - Aggregator","Slug":"mandiri-cards-aggregator","ContentType":2,"Content":null,"SeoTitle":"Mandiri Cards - Aggregator","Description":null},{"Code":"es-mx","Title":"Mandiri Cards - Aggregator","Slug":"mandiri-cards-aggregator","ContentType":2,"Content":null,"SeoTitle":"Mandiri Cards - Aggregator","Description":null}]