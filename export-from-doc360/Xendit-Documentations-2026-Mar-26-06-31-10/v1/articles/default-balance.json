[{"Code":"en","Title":"[Regional] Default balance","Slug":"default-balance","ContentType":2,"Content":"<p data-block-id=\"72ea0db9-474f-4dc4-bf91-5e56dbdcfe43\">Your default currency balance with Xendit is configured based on your home country.</p><p data-block-id=\"b2cde9f5-1f3c-4349-8967-0a79bb65ece9\">Xendit automatically converts all your incoming funds from payments into your default currency balance.</p><p data-block-id=\"c7403207-e609-4b7f-9603-e8a94ffffb78\"><span style=\"color:rgb(0, 0, 0);background:transparent;font-family:Arial;font-size:11pt;font-weight:400;background-color:transparent;font-style:normal;font-variant:normal;text-decoration:none;vertical-align:baseline;\" type=\"spanMark\"><span style=\"border:none;display:inline-block;overflow:hidden;width:353px;height:96px;\" type=\"spanNode\"><img data-block-id=\"bfa1ab12-4925-409c-8eaa-986629b59622\" src=\"https://lh7-rt.googleusercontent.com/docsz/AD_4nXdeISVfOiX_cE7GtEa19zpLDEZ4oIOXbQymqoi13qWKd9b1QsVVWOaC-GMceR32_z37J4Axfg9AFUysrnppXIYxH-5T1CsTlniY7jFOp6dfp91sRKwBUtBKjctz0DWfP4yI1Lpa?key=8rOVuiacFnkRIbTxpzwbVBcX\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"353\" height=\"96\" dataalign=\"right\" datadisplay=\"inline\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"margin-left:0px;margin-top:0px;\"></span></span></p><h3 data-block-id=\"70ec33ec-5be3-4899-ad88-a22e34dff83e\">Changing your default balance</h3><p data-block-id=\"396d0fc8-6fe5-49d6-9aaa-641e4bd93c16\">You can change your default balance to another currency balance from your Settings page. After doing so, all your incoming funds from payments will be automatically converted and settled into the new default currency balance. </p>","SeoTitle":"[Regional] Default balance","Description":null},{"Code":"id","Title":"Default balance","Slug":"default-balance","ContentType":2,"Content":null,"SeoTitle":"Default balance","Description":null},{"Code":"th","Title":"Default balance","Slug":"default-balance","ContentType":2,"Content":null,"SeoTitle":"Default balance","Description":null},{"Code":"es-mx","Title":"[Regional] Default balance","Slug":"default-balance","ContentType":2,"Content":"<p data-block-id=\"72ea0db9-474f-4dc4-bf91-5e56dbdcfe43\">Your default currency balance with Xendit is configured based on your home country.</p><p data-block-id=\"b2cde9f5-1f3c-4349-8967-0a79bb65ece9\">Xendit automatically converts all your incoming funds from payments into your default currency balance.</p><p data-block-id=\"c7403207-e609-4b7f-9603-e8a94ffffb78\"><span style=\"color:rgb(0, 0, 0);background:transparent;font-family:Arial;font-size:11pt;font-weight:400;background-color:transparent;font-style:normal;font-variant:normal;text-decoration:none;vertical-align:baseline;\" type=\"spanMark\"><span style=\"border:none;display:inline-block;overflow:hidden;width:353px;height:96px;\" type=\"spanNode\"><img data-block-id=\"bfa1ab12-4925-409c-8eaa-986629b59622\" src=\"https://lh7-rt.googleusercontent.com/docsz/AD_4nXdeISVfOiX_cE7GtEa19zpLDEZ4oIOXbQymqoi13qWKd9b1QsVVWOaC-GMceR32_z37J4Axfg9AFUysrnppXIYxH-5T1CsTlniY7jFOp6dfp91sRKwBUtBKjctz0DWfP4yI1Lpa?key=8rOVuiacFnkRIbTxpzwbVBcX\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"353\" height=\"96\" dataalign=\"right\" datadisplay=\"inline\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"margin-left:0px;margin-top:0px;\"></span></span></p><h3 data-block-id=\"70ec33ec-5be3-4899-ad88-a22e34dff83e\">Changing your default balance</h3><p data-block-id=\"396d0fc8-6fe5-49d6-9aaa-641e4bd93c16\">You can change your default balance to another currency balance from your Settings page. After doing so, all your incoming funds from payments will be automatically converted and settled into the new default currency balance. </p>","SeoTitle":"[Regional] Default balance","Description":null}]