ate:0;--tw-skew-x:0;--tw-skew-y:0;--tw-scale-x:1;--tw-scale-y:1;--tw-scroll-snap-strictness:proximity;--tw-ring-offset-width:0px;--tw-ring-offset-color:#fff;--tw-ring-color:rgba(59,130,246,.5);--tw-ring-offset-shadow:0 0 #0000;--tw-ring-shadow:0 0 #0000;--tw-shadow:0 0 #0000;--tw-shadow-colored:0 0 #0000;color:var(--tw-prose-headings);font-weight:600;vertical-align:middle;padding:0.5rem;--tw-border-opacity:1;text-align:center;\"><p data-block-id=\"mheklzfv-43cfhw-022\"><strong>Max. Characters</strong></p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"184\" class=\"border border-slate-300 p-2 whitespace-pre-line\" style=\"box-sizing:border-box;border-width:184px;border-style:solid;border-color:rgb(203 213 225/var(--tw-border-opacity));border-image:initial;--tw-border-spacing-x:0;--tw-border-spacing-y:0;--tw-translate-x:0;--tw-translate-y:0;--tw-rotate:0;--tw-skew-x:0;--tw-skew-y:0;--tw-scale-x:1;--tw-scale-y:1;--tw-scroll-snap-strictness:proximity;--tw-ring-offset-width:0px;--tw-ring-offset-color:#fff;--tw-ring-color:rgba(59,130,246,.5);--tw-ring-offset-shadow:0 0 #0000;--tw-ring-shadow:0 0 #0000;--tw-shadow:0 0 #0000;--tw-shadow-colored:0 0 #0000;vertical-align:baseline;padding:0.5rem;--tw-border-opacity:1;\"><p data-block-id=\"mheklzfv-hfz6jd-023\">Any</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"457\" class=\"border border-slate-300 p-2 whitespace-pre-line\" style=\"box-sizing:border-box;border-width:457px;border-style:solid;border-color:rgb(203 213 225/var(--tw-border-opacity));border-image:initial;--tw-border-spacing-x:0;--tw-border-spacing-y:0;--tw-translate-x:0;--tw-translate-y:0;--tw-rotate:0;--tw-skew-x:0;--tw-skew-y:0;--tw-scale-x:1;--tw-scale-y:1;--tw-scroll-snap-strictness:proximity;--tw-ring-offset-width:0px;--tw-ring-offset-color:#fff;--tw-ring-color:rgba(59,130,246,.5);--tw-ring-offset-shadow:0 0 #0000;--tw-ring-shadow:0 0 #0000;--tw-shadow:0 0 #0000;--tw-shadow-colored:0 0 #0000;vertical-align:baseline;padding:0.5rem;--tw-border-opacity:1;\"><p data-block-id=\"mheklzfv-1tldys-024\">Any</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"304\" class=\"border border-slate-300 p-2 whitespace-pre-line\" style=\"box-sizing:border-box;border-width:304px;border-style:solid;border-color:rgb(203 213 225/var(--tw-border-opacity));border-image:initial;--tw-border-spacing-x:0;--tw-border-spacing-y:0;--tw-translate-x:0;--tw-translate-y:0;--tw-rotate:0;--tw-skew-x:0;--tw-skew-y:0;--tw-scale-x:1;--tw-scale-y:1;--tw-scroll-snap-strictness:proximity;--tw-ring-offset-width:0px;--tw-ring-offset-color:#fff;--tw-ring-color:rgba(59,130,246,.5);--tw-ring-offset-shadow:0 0 #0000;--tw-ring-shadow:0 0 #0000;--tw-shadow:0 0 #0000;--tw-shadow-colored:0 0 #0000;vertical-align:baseline;padding:0.5rem;--tw-border-opacity:1;\"><p data-block-id=\"mheklzfv-fgtdxq-025\">148 characters</p></td></tr></tbody></table></div><p data-block-id=\"mheklral-bjgads-016\"></p>","SeoTitle":"China","Description":null},{"Code":"id","Title":"China","Slug":"china","ContentType":2,"Content":null,"SeoTitle":"China","Description":null},{"Code":"th","Title":"China","Slug":"china","ContentType":2,"Content":null,"SeoTitle":"China","Description":null},{"Code":"es-mx","Title":"China","Slug":"china","ContentType":2,"Content":null,"SeoTitle":"China","Description":null}]