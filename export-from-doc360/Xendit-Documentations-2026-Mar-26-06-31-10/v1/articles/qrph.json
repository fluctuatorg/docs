[{"Code":"en","Title":"QRPh","Slug":"qrph","ContentType":2,"Content":"<p data-block-id=\"0ea65c3d-a38c-40be-a208-d546ab91ccec\"><img data-block-id=\"ddc1ed3e-11cd-4537-bffb-fa882bb16eac\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/qrph.jpeg\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" title=\"image(23).png\" width=\"264\" height=\"71\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:264px;height:71px;\"></p><p data-block-id=\"40d09386-139f-4cf1-8307-2c85d716974e\">QRPh is the national Quick Response (QR) code standard in the Philippines for real-time payments. It allows customers to make instant payments from their bank or e-wallet apps by scanning a QR code displayed by a merchant.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Features</h2><div data-type=\"table-content\"><table width=\"735\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:735px;width:735px;\"><colgroup><col style=\"width:463px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"db4dfef8-c563-4305-8c29-ef2b1aa63d40\">Channel Code</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"c3c6bd76-58de-4ac5-b1d8-062fe0ec80e0\"><code>QRPH</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"05742465-0957-4c43-b4a1-a714d1ec5bd9\">Currency</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"02bbaac3-3880-4b14-a8ac-99727c107237\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"216547ce-9149-4c98-863b-af7a9b417559\">Minimum Amount</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"b3dcd6fe-765a-461a-8ac9-f2894e111c72\">1.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"917595fc-cd1e-4638-a3ac-8c763018c400\">Maximum Amount</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"a03d6897-7172-4e71-92e4-7903aa1ee0e6\">50,000.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"dd693bd7-6fa5-470c-a762-3bd25581ee55\">User Approval Flow</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"1e281341-6029-45ba-9355-4cc176c02afd\">PRESENT TO CUSTOMER</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"00b142a2-96d8-469f-a603-d7f653f2f6a6\">Reusable Payment Code</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"a1136f0f-cfc8-43e9-8f8c-2b016ba94b40\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"a15e3b11-bb7c-4496-bbdd-cbc61b5faf78\">Custom Payment Code</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"dad7b186-c852-4fb3-90cf-b36d2e2e97f5\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"d4fc461e-77d4-4e93-b6a4-95652e301b57\">Display Merchant Name</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"b6a0211d-e77b-4b67-a283-93add001d4fc\">MERCHANT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"260ee695-3783-478d-b6ce-168812cf5235\">Display User Name</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"a4c6c5c5-9024-4ade-9b26-fe6d949b75d7\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"ebe59eaf-3581-4b5e-9133-086846171bc3\">Set Expiry</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"99c8cb58-8ba9-46cb-9e75-fdac1c6aeb47\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"7750e331-7b15-4423-9ba5-f771994775fe\">Settlement Time (hours)</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"058633eb-5306-4427-9500-fda71cbfaee3\">T+1 BUSINESS DAYS</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"6779fc15-6426-43e4-83b0-b2e6307dba73\">Refund</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"33925a2c-78ca-46e4-b21f-8b36b5ee3fd3\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"0baabc7e-a92b-49d0-af45-796c16289f04\">Partial Refund</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"d13ec362-0671-4327-a68e-d9c64b63edbc\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"166f9598-76a9-48a7-b24b-9c06b9f896ce\">Multiple Partial Refund</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"13bd794d-854a-4079-a1e5-30746661a7ef\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"256467fa-b7fd-45f2-b88e-195088282404\">Refund Validity (days)</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"60594c72-13e1-4b7a-835e-21b421c0b32f\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"5c93e485-a74d-4a50-8a1b-9bba2a9f420b\">Compatible integration</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"08a92202-e311-4fab-ac7e-6da8139ad455\">Payment API, Payment Link</p></td></tr></tbody></table></div><h2 data-block-id=\"e6a751eb-5650-46eb-98fc-a30d619b0118\">How to pay</h2><p data-block-id=\"cb31e330-5585-4d41-a3ed-1a716796bd53\"><strong>Find the QR Code</strong></p><ol data-block-id=\"59f777cb-bc85-4396-9d31-2ece9cc3b7ad\" start=\"1\"><li data-block-id=\"ed790ef6-0b03-460a-a2dd-8f3f705675f9\"><p data-block-id=\"68f37280-ea3f-42e7-93cf-d5373721d254\">Select <strong>QRPh</strong> as your payment method on the checkout page</p></li><li data-block-id=\"a8881572-05af-4d8e-b684-08dc471a52db\"><p data-block-id=\"7bcc7045-5a7b-4815-a8ed-9c1e84aaafa4\">A QR code will be displayed along with the transaction details (e.g., amount and merchant name)</p></li></ol><p data-block-id=\"47226094-dffc-4b06-820e-293dfa291751\"><strong>Payment Details</strong></p><ol data-block-id=\"5312d980-d76a-4ad2-91d7-97a61fbb0c94\" start=\"1\"><li data-block-id=\"f4294f12-552c-4a19-b2d5-7ece203ec90e\"><p data-block-id=\"c86c27d5-948a-4e14-93a6-de5f31687d9b\">Open your mobile banking app or e-wallet that supports QRPh</p></li><li data-block-id=\"fae4fdc6-df6b-4f93-a8b3-1b1a21296fdf\"><p data-block-id=\"c35b75e1-99a7-4d5f-802d-f82e9e50b059\">Use the <strong>Scan QR Code</strong> feature in your app</p></li><li data-block-id=\"d56c2b58-d28f-49f3-8d83-91cc41bbe61c\"><p data-block-id=\"f35a1253-c8e4-479d-b56c-175133beb9e8\">Point your phone camera at the QR code displayed on the checkout page</p></li><li data-block-id=\"bfbee0a8-6535-45db-adca-aa24bdceb011\"><p data-block-id=\"cf53c4d8-4849-4bef-a9b9-068f9a97ed7c\">Verify the transaction details (e.g., amount and recipient)</p></li></ol><p data-block-id=\"b627a50d-d438-4280-88f1-7534227b6b73\"><strong>Confirm Payment</strong></p><ol data-block-id=\"e27520c3-d079-49ee-a3c8-08a3fb521c21\" start=\"1\"><li data-block-id=\"ea0385c1-bd9a-4761-999f-b67ce4f7182e\"><p data-block-id=\"388ccace-e545-4aec-81e4-21ec21e4ea8e\">Confirm the transaction in your app</p></li><li data-block-id=\"85211a65-7e55-4d71-84b1-7c82aeed15b1\"><p data-block-id=\"7966d984-bba1-4be3-be41-edcb1eb7ace6\">Enter your PIN or use biometric authentication (if required)</p></li></ol><h4 data-block-id=\"6859f999-9823-4eca-b0ac-263cf439bbc8\">Payment Flow</h4><h2 data-block-id=\"861918c3-8b4d-40d7-a2be-9581ace433c8\"><img data-block-id=\"8858d3de-c585-4dab-9f44-8a8f15a1446f\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image-1735806730640.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"\"></h2><p data-block-id=\"8e9aac87-b7ff-4f0e-b9c9-0178d8f76e42\"></p><p data-block-id=\"1fba7422-3f0f-475f-a3cd-ed72e33bce4f\"></p><p data-block-id=\"acd97665-43b1-498b-89ca-e66b24c0a68f\"></p><p data-block-id=\"490a489a-2a58-4dc9-96ea-9e5cc09fc8be\"></p>","SeoTitle":"QRPh","Description":null},{"Code":"id","Title":"QRPh","Slug":"payment-channel-page-push-6","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><p data-block-id=\"0ea65c3d-a38c-40be-a208-d546ab91ccec\"><img data-block-id=\"ddc1ed3e-11cd-4537-bffb-fa882bb16eac\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/qrph.jpeg\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" title=\"image(23).png\" width=\"264\" height=\"71\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:264px;height:71px;\"></p><p data-block-id=\"40d09386-139f-4cf1-8307-2c85d716974e\">QRPh adalah standar kode Quick Response (QR) nasional di Filipina untuk pembayaran real-time. Ini memungkinkan pelanggan untuk melakukan pembayaran instan dari aplikasi bank atau e-wallet mereka dengan memindai kode QR yang ditampilkan oleh merchant.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Fitur</h2><div data-type=\"table-content\"><table width=\"735\" class