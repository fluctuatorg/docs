[{"Code":"en","Title":"LinkAja","Slug":"draft-linkaja","ContentType":2,"Content":"<p data-block-id=\"mmkaxsns-cz4mas-968\"></p><h1 data-block-id=\"mmkaxsns-oy8fnj-969\"><a id=\"_rgwl05coo69f\" display=\"false\"></a></h1><h2 data-block-id=\"mmkaxsns-n0wqdj-970\"><a id=\"_9j6h54imkhti\" display=\"false\"></a>Glossary</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnt-gf3mj7-971\">Terms</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnt-vxuwqy-972\">Description</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnt-k67gqs-973\">WCO ( Web Check Out) Form</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnt-5cv60t-974\">Excel sheet form from LinkAja we use to onboard merchant to LinkAja</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnt-xd4g71-975\">QRIS</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnt-o8z0h4-976\">Merchant that apply LinkAja will automatically get QRIS</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-4mbg8k-977\">MID LinkAja</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-gj463k-978\">Merchant ID LinkAja to activate LinkAja</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-qquaw4-979\">MID QRIS</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-9t29a0-980\">Merchant ID Partner to activate QRIS</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-kviwc0-981\">MDR</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-q3p6hs-982\">Merchant Discount Rate</p></th></tr></tbody></table></div><h1 data-block-id=\"mmkaxsnu-5zcokr-983\"><a id=\"_le0lnzh5mitv\" display=\"false\"></a></h1><h2 data-block-id=\"mmkaxsnu-qnloxq-984\"><a id=\"_e4mdpp1mmmy7\" display=\"false\"></a>Related Documents</h2><h1 data-block-id=\"mmkaxsnu-mlo1g8-985\"><a id=\"_buutoeaen34k\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnu-tcelsm-986\">Document Name</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-7bdv70-987\">Description</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-di3d4s-988\">Link to Document</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-mqgpoh-989\">Table MDR Special LinkAja</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-qopxey-990\">Table requirements from LinkAja to merchant that request special rate</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-mqxpg7-991\"><a href=\"https://docs.google.com/spreadsheets/d/1FRTu_DcPrNZdp1WNee9jOAN75KTSxMJBxTZ0atsovDk/edit#gid=0\"><u>Table MDR</u></a></p></th></tr></tbody></table></div><h1 data-block-id=\"mmkaxsnv-fhn4nj-992\"><a id=\"_z0e1xbi9nkqv\" display=\"false\"></a></h1><h2 data-block-id=\"mmkaxsnv-x7fdwx-993\"><a id=\"_iyngp9kuh65w\" display=\"false\"></a>Eligibility</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-8jg21x-994\">Entity Type</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnv-5ymmy9-995\">Can Apply for LinkAja</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-mskyg1-996\">Indonesian Entity (PT/CV/Yayasan)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-4x3208-997\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-kmse6y-998\">Indonesian Entity (Perseroan perorangan/PP)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-u2xrua-999\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-916exc-000\">Indonesian Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-yl3kdy-001\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-ymsfm8-002\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnw-bffsy5-003\">✅</p></th></tr></tbody></table></div><h2 data-block-id=\"mmkaxsnw-l0utru-004\"><a id=\"_vexy2w4yopau\" display=\"false\"></a>Merchant Requirements </h2><p data-block-id=\"mmkaxsnx-611upk-005\">Below are the requirements that a merchant has to submit, whether it’s upon onboarding or CA application request</p><h3 data-block-id=\"mmkaxsnx-jp09kg-006\">Legal Documents</h3><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnx-b71460-007\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnx-dh2fik-008\"><strong>Requirements</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnx-148b5v-009\">Individual</p></th><th colspan=\"1\" rowspan=\"1\"><ol data-block-id=\"mmkaxsnx-gsu7qy-010\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkaxsnx-4si9eo-011\"><p data-block-id=\"mmszh956-iuixuz-157\">KTP number</p></li><li data-block-id=\"mmkaxsnx-4up3mm-012\"><p data-block-id=\"mmszh956-g6q24k-158\">Address based on KTP</p></li><li data-block-id=\"mmkaxsnx-9dal30-013\"><p data-block-id=\"mmszh957-clrjd5-159\">Date of issued of KTP</p></li></ol></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnx-s3su5q-014\">Local Entity</p></th><th colspan=\"1\" rowspan=\"1\"><ol data-block-id=\"mmkaxsny-qhk8in-015\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkaxsny-2losz2-016\"><p data-block-id=\"mmszh957-3ucvvk-160\">SIUP or NIB number</p></li><li data-block-id=\"mmkaxsny-3g6nkq-017\"><p data-block-id=\"mmszh957-w1w33g-161\">Place and Date of company establishment</p></li><li data-block-id=\"mmkaxsny-bcm41d-018\"><p data-block-id=\"mmszh957-q72vc5-162\">SIUP or NIB validity period</p></li><li data-block-id=\"mmkaxsny-jysprp-019\"><p data-block-id=\"mmszh957-karlr3-163\">Director’s KTP number</p></li><li data-block-id=\"mmkaxsny-zbsko2-020\"><p data-block-id=\"mmszh958-fawjsz-164\">Address of Director based on KTP</p></li><li data-block-id=\"mmkaxsny-0mltx9-021\"><p data-block-id=\"mmszh958-ozp5bx-165\">Date of issued the Director’s KTP</p></li><li data-block-id=\"mmkaxsny-xrpng5-022\"><p data-block-id=\"mmszh958-sa09y4-166\">NPWP company number</p></li></ol></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsny-x4wjau-023\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><ol data-block-id=\"mmkaxsny-z4z1n4-024\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkaxsny-6mj21f-025\"><p data-block-id=\"mmszh958-qz27dr-167\">Passport number</p></li><li data-block-id=\"mmkaxsny-9v14kl-026\"><p data-block-id=\"mmszh958-3uj7yx-168\">Passport date of issuance</p></li><li data-block-id=\"mmkaxsny-u658ea-027\"><p data-block-id=\"mmszh958-ye0ycn-169\">For foreign Address use Xendit Address (Menara Sentraya)</p></li></ol></th></tr></tbody></table></div><p data-block-id=\"mmszh959-5vqfcv-170\"></p><h3 data-block-id=\"mmkaz7uz-ckffz5-227\">QRIS Requirements</h3><h1 data-block-id=\"mmkaxsny-99qnry-028\"><a id=\"_utjlh7t85x90\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsny-2wa8wn-029\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsny-8q6vzf-030\"><strong>Requirements</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsny-qf3i5u-031\">QRIS Requirement</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnz-1o4l74-032\">Legal detail requirement for QRIS same with requirement above, except for : </p><ol data-block-id=\"mmkaxsnz-r8ckbc-033\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkaxsnz-eb7lym-034\"><p data-block-id=\"mmszh959-qb0k5r-171\">Indonesia companies with foreign directors should provide KITAS as a requirement to apply QRIS, if they can not provide KITAS, MO will activate those merchants using Xendit credential code. (200414091925001). </p></li><li data-block-id=\"mmkaxsnz-99z53o-035\"><p data-block-id=\"mmszh95a-ccagl2-172\">Local merchants will automatically get QRIS when they apply for LinkAja</p></li></ol></th></tr></tbody></table></div><h3 data-block-id=\"mmkazgin-ah5w7n-228\">MDR Requirements</h3><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnz-7zbnm7-036\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnz-yixjfl-037\"><strong>Requirements</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsnz-la50ia-038\">MDR Requirement </p></th><th colspan=\"1\" rowspan=\"1\"><ol data-block-id=\"mmkaxsnz-s5nyja-039\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkaxsnz-llo02g-040\"><p data-block-id=\"mmszh95a-ljwws1-173\">LinkAja new MDR scheme for merchant in criteria : Games &amp; Digital Content</p></li><li data-block-id=\"mmkaxsnz-l06dz0-041\"><p data-block-id=\"mmszh95a-tgw50v-174\">Merchant criteria Games &amp; Digital Content <strong>(local) : MDR 3%</strong></p></li><li data-block-id=\"mmkaxsnz-vpexgd-042\"><p data-block-id=\"mmszh95a-lidyrq-175\">Merchant criteria Games &amp; Digital Content <strong>(foreign) : MDR 3,5%</strong></p></li></ol><p data-block-id=\"mmkaxsnz-8avs1t-043\">Merchant - merchant yang masuk dalam kategori games dan digital content: </p><ol data-block-id=\"mmkaxsnz-76g3b7-044\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkaxsnz-k8h74n-045\"><p data-block-id=\"mmszh95b-ftivdd-176\"><strong>Games. </strong>Tipe konten game termasuk, <strong>aplikasi games, website games, marketplace game (termasuk yang menjual game atau voucher game)</strong>.  <strong>Contoh: Sega, Epic Games, Ubisoft, Steam, Lapakgaming. </strong></p></li><li data-block-id=\"mmkaxso0-x6i2y6-046\"><p data-block-id=\"mmszh95b-dvkheu-177\"><strong>Audio Streaming.</strong> Tipe konten audio, termasuk music streaming, serta platform dan marketplace yang menjual produk dan layanan berbagi audio file, soundtrack, music. <strong>Contoh: Spotify, Pandora, Deezer. </strong></p></li><li data-block-id=\"mmkaxso0-wjdike-047\"><p data-block-id=\"mmszh95b-p4upf0-178\"><strong>Video Streaming. </strong>Tipe konten video, termasuk home videos, music videos, TV shows, dan film / movies. <strong>Contoh: Viu, Netflix, HBO Go, Disney+. </strong></p></li><li data-block-id=\"mmkaxso0-c1iqz8-048\"><p data-block-id=\"mmszh95b-ezyl31-179\"><strong>Images.</strong> Tipe konten images, termasuk platform dan marketplace yang menjual layanan berbagi foto dan gambar. <strong>Contoh: Getty Images, Shutterstocks, Deviantart. </strong></p></li><li data-block-id=\"mmkaxso0-wmxepv-049\"><p data-block-id=\"mmszh95b-i979j3-180\"><strong>Visual Stories &amp; Social Media.</strong> Tipe konten visual stories &amp; social media, termasuk platform berbagi stories, social gaming, social networking dan social media.  <strong>Contoh: Snapchat, Hago, Bigo, LinkedIn.</strong></p></li></ol></th></tr></tbody></table></div><h2 data-block-id=\"mmkaxso0-42jzd5-050\"><a id=\"_yres7dyun87g\" display=\"false\"></a>Activation SLA</h2><p data-block-id=\"mmkaxso0-8re30k-051\">LinkAja activated in <strong>6 working days </strong>from the date MO submitted WCO form And QRIS to LinkAja.</p><h2 data-block-id=\"mmkaxso0-8hyct0-052\"><a id=\"_bz804q3qlp3k\" display=\"false\"></a>Onboarding Steps</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:50px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso0-2k2plr-053\">Category</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso0-j9kgoy-054\">No</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso0-3lxscj-055\">Steps</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso0-7cy33o-056\">Owner</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso1-b7fv5s-057\">Merchant applies for LinkAja</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso1-47ik9u-058\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso1-pjqrhv-059\">Merchant submit application from their Dashboard </p><p data-block-id=\"mmkaxso1-3qhevo-060\"><img data-block-id=\"mmkaxso1-6e6e41-061\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-nkclpmvp.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso1-xyhqic-062\">Merchant</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmszh95d-py44w5-181\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso2-mp6do4-063\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso2-lz45ym-064\">Once merchant clicks Activate, this request will come to slack <a href=\"https://app.slack.com/client/T02NB4B05/CHL089LRH\"><u>#product-Apl</u></a> and <a href=\"https://admin-dashboard.tidnex.com/channel-activations/alfamart?offset=0&amp;limit=10\"><u>Channel Activations</u></a> dashboard</p><p data-block-id=\"mmkaxso2-ub8q8f-065\"><img data-block-id=\"mmkaxso2-1ghfby-066\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-mv2l06kt.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso2-q7igv7-067\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"13\"><p data-block-id=\"mmkaxso2-85xskd-068\">MO Process Merchant’s Application</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso2-u5w9sv-069\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso2-534o6x-070\">MO check LinkAja submission in admin dashboard channel activation with status <em>New. </em>copy paste the BID and check website (for MDR categorized) from Admin dashboard (CM)</p><p data-block-id=\"mmkaxso2-pa9mg2-071\"><img data-block-id=\"mmkaxso2-k2tmrr-072\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-mcaur8fw.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso3-8jsamf-073\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso3-hszwp8-074\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso3-lca8rk-075\">Click download xlsx and choose the start date and end date based on the application you want to submit. </p><p data-block-id=\"mmkaxso3-06pxf0-076\"><img data-block-id=\"mmkaxso3-6p59c2-077\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-ucclqzi5.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxso3-xuoe4g-078\"><img data-block-id=\"mmkaxso3-ltxcfq-079\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-oij49xsw.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxso3-7xol33-080\">Our system will download all merchant data with New Status and automatically change the status from New to awaiting_feedback_from_linkaja. Auto Geocode will appear automatically on the sheet we download.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso3-q3q31s-081\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso3-yfpkik-082\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso3-pu40gu-083\">Open the downloaded file and copy paste data to LinkAja Adjustment Table sheet <a href=\"https://docs.google.com/spreadsheets/d/1QatI8ehwblfrKSc2Fjl96Ea-DKwDF3Bc9j4ehpXQBJI/edit?gid=0#gid=0\"><u>here</u></a>.</p><p data-block-id=\"mmkaxso4-l5uea8-084\"><img data-block-id=\"mmkaxso4-kys5zg-085\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-conzj3tc.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso4-c2rqom-086\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso4-6ds47n-087\">6</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso4-xgd829-088\">Login to OMS Link Aja portal with credentials below:</p><ul data-block-id=\"mmkaxso4-1dzx10-089\"><li data-block-id=\"mmkaxso4-w23eej-090\"><p data-block-id=\"mmszh95k-podow5-182\"><strong>User: Admin Xendit 11</strong></p></li><li data-block-id=\"mmkaxso4-fsy74k-091\"><p data-block-id=\"mmszh95k-zyiqn0-183\"><strong>Password: Ilovexendit1!</strong></p></li></ul><p data-block-id=\"mmkaxso4-98k3n4-092\"><img data-block-id=\"mmkaxso4-gav53u-093\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-020r8oev.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso6-prnl9p-094\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso7-g0c2vr-095\">7</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso7-45kxz1-096\">After login, go to Merchant Tab and click Download Template</p><p data-block-id=\"mmkaxso7-0sbra6-097\"><img data-block-id=\"mmkaxso7-n0ae6p-098\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-ppo8rto2.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"><br type=\"inline\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso7-ct3bqw-101\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso7-54e849-102\">8</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso8-yf8lnp-103\">Open File bulk_upload_store_agg and go to Upload Merchant sheet.</p><p data-block-id=\"mmkaxso8-77iro5-104\"><img data-block-id=\"mmkaxso8-8ik33s-105\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-gq0mdtg1.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso8-3hs8mh-106\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso8-c1oqtn-107\">9</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso8-03wx2p-108\">Back to LinkAja Adjustment Table file and go to OMS data sheet.</p><p data-block-id=\"mmkaxso8-ph5btf-109\"><img data-block-id=\"mmkaxso8-ka3pl1-110\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-idtv0inj.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso8-clwll2-111\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso9-r83b6l-112\">10</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso9-k8npgg-113\">Copy all the adjusted merchant data and paste it to bulk_upload_store_agg file.</p><p data-block-id=\"mmkaxso9-wkxcvo-114\"><img data-block-id=\"mmkaxso9-igq9ak-115\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-naescabn.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso9-9pk0fm-116\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxso9-f987wk-117\">11</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxso9-zrlgwc-118\">Please check on:</p><ul data-block-id=\"mmkaxso9-5e8752-119\"><li data-block-id=\"mmkaxso9-nll0z4-120\"><p data-block-id=\"mmszh95m-irwscn-184\">All numbering formats (KTP, NPWP, and NIB)</p></li><li data-block-id=\"mmkaxso9-n8i065-121\"><p data-block-id=\"mmszh95m-xe14d1-185\">Date format (you can copy date formatting from the sample merchant on the first row) Tanggal pendirian merchant dan Masa berlaku izin usaha merchant.</p></li><li data-block-id=\"mmkaxso9-3536p4-122\"><p data-block-id=\"mmszh95n-fviqez-186\">Please remove all the punctuation on every address (Alamat Merchant &amp; Alamat Pemilik)</p></li><li data-block-id=\"mmkaxsoa-zubw68-123\"><p data-block-id=\"mmszh95n-ik4jtj-187\">DoB Director</p></li></ul><p data-block-id=\"mmkaxsoa-02ecor-124\">Now you can delete the sample merchant row.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoa-gt2ecm-125\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsoa-oe4u51-126\">12</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoa-1ufjuz-127\">Save file and go to OMS portal, then click upload bulk and upload the file.</p><p data-block-id=\"mmkaxsoa-mnyx2r-128\"><img data-block-id=\"mmkaxsoa-2swazg-129\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-to7014ze.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoa-kgmv6q-130\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsoa-7wut1f-131\">13</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsob-vucobk-132\"> A new ticket will be created, click Edit Tiket to proceed the submission.</p><p data-block-id=\"mmkaxsob-kyvf8h-133\"><img data-block-id=\"mmkaxsob-84hnuy-134\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-lj330pzk.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsob-2bbhio-135\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsob-r4rqd5-136\">14</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsob-ltx8xa-137\">Click Pencil Icon on every merchant name.</p><p data-block-id=\"mmkaxsob-0b21w6-138\"><img data-block-id=\"mmkaxsob-6u558m-139\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-0pfs4pjn.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsob-rzkrhf-140\">Adjust all the requirements fields and upload NPWP &amp; Director’s KTP.</p><p data-block-id=\"mmkaxsob-uyepf5-141\"><img data-block-id=\"mmkaxsob-guzg4j-142\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-qwub4bcc.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsob-c922ns-143\"><img data-block-id=\"mmkaxsob-56lnth-144\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-mu3bk6r2.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsob-5om5xs-145\">Then click Simpan Merchant.</p><p data-block-id=\"mmkaxsob-cqrgmq-146\"><img data-block-id=\"mmkaxsoc-tvxtwo-147\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-ryzvo2wz.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsoc-mlydg8-148\">Repeat this step for every merchant until the status is Complete.</p><p data-block-id=\"mmkaxsoc-dqgj1r-149\"> <img data-block-id=\"mmkaxsoc-s6brh5-150\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-btycejg5.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoc-azp5u4-151\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsoc-ipwj2c-152\">15</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoc-4ep8sp-153\">After all the merchant status are completed, click Ajukan Merchant.</p><p data-block-id=\"mmkaxsoc-g6fx01-154\"><img data-block-id=\"mmkaxsoc-rw41tu-155\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-aa8rhkzp.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsoc-6xe0nz-156\">For Digital merchant, please list the merchant name on Catatan Tiket.</p><p data-block-id=\"mmkaxsoc-x6v7h1-157\"><img data-block-id=\"mmkaxsoc-rcl97k-158\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-v00iern7.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsoc-tjhvqu-159\">Then click Ya, Ajukan.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsod-l70cvr-160\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmszh95p-i6o9vb-188\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsod-2z03na-161\">16</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsod-o251gr-162\">Check on Ticket tab to find ticket number and status.</p><p data-block-id=\"mmkaxsod-5deof6-163\"><img data-block-id=\"mmkaxsod-iajkt1-164\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-0ir1pwll.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsod-zf8hiu-165\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsod-b0iw1v-166\">Account Activation</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsoe-abajja-167\">17</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoe-1pmw7h-168\">For activation, you can go to OMS &gt; Ticket and check the ticket status that has been Completed.<img data-block-id=\"mmkaxsoe-39dy95-169\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-hiua8gkb.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsoe-diqy68-170\">Click the eye icon beside the status to have list of merchant’s name that has been approved by Link Aja.</p><p data-block-id=\"mmkaxsoe-lz5gxn-171\"><img data-block-id=\"mmkaxsoe-9wlfu5-172\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-wd04s7pc.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoe-8sf9ah-173\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmszh95r-nffwd6-189\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsoe-zb6jx9-174\">18</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsof-q5mt7s-175\">Now go to Merchant Tab, search merchant’s name and click the eye icon.</p><p data-block-id=\"mmkaxsof-mqy0i1-176\"><img data-block-id=\"mmkaxsof-v4bb5l-177\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-gpr1pyzw.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsof-jnwsvw-178\">Copy Child Shortcode<img data-block-id=\"mmkaxsof-a5rzyl-179\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-tsqsdm01.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkaxsof-rbzmir-180\">Go to LinkAja channel approval on Xendit Dashboard, search the merchant’s name, and click Edit.</p><p data-block-id=\"mmkaxsof-p6b58f-181\"><img data-block-id=\"mmkaxsof-z43cjz-182\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-5rg23bzv.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsof-kmhn4b-183\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmszh95s-h5n8s0-190\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmkaxsof-q6x8pu-184\">19</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsof-8i0l3o-185\">Click Activate and paste on LinkAja MID field, then click Activate.</p><p data-block-id=\"mmkaxsof-su2u83-186\"><img data-block-id=\"mmkaxsog-nfday4-187\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-4a498xmc.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsog-mq352s-188\">MO</p></th></tr></tbody></table></div><h2 data-block-id=\"mmkaxsog-1j8y65-189\"><a id=\"_z7dhksnkde3\" display=\"false\"></a>Special Rate Flow</h2><p data-block-id=\"mmkaxsog-jwpa7q-190\">SLA 14 working days</p><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsog-qjilun-191\">Category</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsog-fhx4s1-192\">No</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsog-86oc96-193\">Steps</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoh-eyqngq-194\">Owner</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoh-ini7q6-195\">Merchant request special request for their rate</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoh-5qo83y-196\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoh-5jt9dh-197\">Sales/AM to post the request thru #mo-request and provide merchant’s data/info. Please detail below :<br type=\"inline\"></p><ul data-block-id=\"mmkaxsoh-zqd54m-199\"><li data-block-id=\"mmkaxsoh-jj4e1l-200\"><p data-block-id=\"mmszh95t-nfwnqh-191\">Merchant’s business size, monthly TPV and txn count, avg tix size</p></li><li data-block-id=\"mmkaxsoh-u4mvl4-201\"><p data-block-id=\"mmszh95t-gbvmh3-192\">Supporting info from merchant for LA channel</p></li><li data-block-id=\"mmkaxsoh-ui21rs-202\"><p data-block-id=\"mmszh95t-ye49yy-193\">Strategic added value</p></li><li data-block-id=\"mmkaxsoh-6k6kfb-203\"><p data-block-id=\"mmszh95t-6vophl-194\">Other eWallet pricing (benchmark)</p></li><li data-block-id=\"mmkaxsoh-5svzsv-204\"><p data-block-id=\"mmszh95t-71wdpq-195\">Business info (highlights)</p></li><li data-block-id=\"mmkaxsoh-1w0gfe-205\"><p data-block-id=\"mmszh95t-abbktb-196\">Opportunity info</p></li><li data-block-id=\"mmkaxsoh-9t81n5-206\"><p data-block-id=\"mmszh95t-6jduqi-197\">Expected Pricing from merchant</p></li></ul><p data-block-id=\"mmkaxsoh-jw950d-207\"><img data-block-id=\"mmkaxsoh-3upbe1-208\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-ijz5dosl.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoi-8vvdlq-209\">Sales/AM</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoi-ksb9jj-210\">MO send the submission request</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoi-5bprkm-211\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoi-8n0aqr-212\">MO send the submission request via email based on the segmentation.</p><ul data-block-id=\"mmkaxsoi-6azqa5-213\"><li data-block-id=\"mmkaxsoi-uyqi2r-214\"><p data-block-id=\"mmszh95u-6s3ig1-198\">Non-Digital merchant send to : <a><u>MerchantCommercial@linkaja.id</u></a>and <a><u>sukainah_a_alaydrus@linkaja.id</u></a>cc <a><u>Rio Ardian</u></a></p></li><li data-block-id=\"mmkaxsoi-ay2td0-215\"><p data-block-id=\"mmszh95u-wjl33y-199\">Digital merchant send to : <a><u>Windaryatno_Nugroho@linkaja.id</u></a>cc <a><u>sukainah_a_alaydrus@linkaja.id</u></a></p></li></ul></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoi-rep678-216\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoj-3sysdl-217\">Partner give feedback</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoj-ujy3j0-218\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoj-kkbu4i-219\">LA will set the new pricing internally and provide the approval/rejection info by email re effective date for new pricing</p><p data-block-id=\"mmkaxsoj-njad3a-220\"><img data-block-id=\"mmkaxsoj-m7vo3v-221\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-linkaja-image-zssiou3m.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoj-dij1ag-222\">LinkAja</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoj-vtlhz5-223\">MO updated in dashboard</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsoj-3i1xjd-224\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsok-nkk1uj-225\">Merchant Ops would be updated the merchant special request rate into our billing rates dashboard</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkaxsok-jhjxg3-226\">MO</p></th></tr></tbody></table></div><p data-block-id=\"mmszh95w-i0i6yx-200\"></p>","SeoTitle":"LinkAja","Description":null},{"Code":"id","Title":"LinkAja","Slug":"linkaja-1","ContentType":2,"Content":null,"SeoTitle":"LinkAja","Description":null},{"Code":"th","Title":"LinkAja","Slug":"linkaja-1","ContentType":2,"Content":null,"SeoTitle":"LinkAja","Description":null},{"Code":"es-mx","Title":"LinkAja","Slug":"linkaja-1","ContentType":2,"Content":null,"SeoTitle":"LinkAja","Description":null}]