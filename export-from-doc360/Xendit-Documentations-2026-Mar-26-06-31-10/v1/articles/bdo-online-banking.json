[{"Code":"en","Title":"BDO Online Banking","Slug":"bdo-online-banking","ContentType":2,"Content":"<p data-block-id=\"b1040702-ed6c-4864-84ff-67a01ba05fef\"><img data-block-id=\"ba18f63c-08bc-4a1b-b04a-ad3d40fabef1\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/BDO_Unibank_(logo).svg.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"249\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:249px;\"></p><p data-block-id=\"4211693a-308c-4068-9616-3e68df2e0e78\">BDO Unibank, the largest bank in the Philippines, offers BDO ePayment, a secure online payment solution designed to simplify transactions for businesses and consumers alike. This service allows customers to make payments directly from their BDO accounts during online purchases.</p><p data-block-id=\"d8636ee0-ede8-4af2-92b6-2311adbc4ee9\">This payment channel is primarily used by merchants who are offering our other online banking channels (with “ONLINE_BANKING” in the channel name). You can also integrate directly with our BDO direct debit channel.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Features</h2><div data-type=\"table-content\"><table width=\"550\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:550px;width:550px;\"><colgroup><col style=\"width:277px;\"><col style=\"width:273px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"402452f7-7a96-45f3-856a-beec3466fb7a\"><strong>Channel code</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\"><p data-block-id=\"648b3370-267a-47a5-bafd-0cfb81370827\"><code>BDO_ONLINE_BANKING</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"e924926f-9906-4496-af4a-b319c2a2c8d4\"><strong>Currency</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"89cc4585-3036-4f0a-847a-3a0f634c0a27\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6598736d-d850-48ae-b29e-ba649fb13157\"><strong>Minimum amount</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"f5c1c704-b8ae-4d25-8fd5-2694332b973d\">1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"93c4567d-ddd5-461c-8459-70cc0cce1024\"><strong>Maximum amount</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"182cd5d4-0077-4254-901f-9939ecae06f1\">2,000,000</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"73a8ce05-a222-44fb-b6c6-fa9069d5dfc4\"><strong>User approval flow</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"bb42dc08-4557-408e-985f-e98424855151\">REDIRECT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"4888d640-07c9-4a08-aa89-fd2f705958bd\"><strong>Save</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"de320cd4-3832-4edb-b65a-d9d2b0717696\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d4dd8a87-001f-4750-954f-3b945aba5e48\"><strong>Recurring</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"0a0ada44-cc78-4f92-b7e3-5d5f5fa029e6\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"1a306633-bbbe-4f04-bf87-db43583cea7b\"><strong>Auth &amp; capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"ac9af3d4-f692-4f73-aedb-7a6a4908a9a2\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6dafaffe-056c-47dd-9363-46082a9133f7\"><strong>Partial capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"60a306e9-b83b-4b04-b5bd-07ffe7fe7665\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"dce8b2c9-f302-4b39-b28f-1629758eefff\"><strong>Multiple partial capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"fce61d55-92ed-4dca-a2a6-29fb90d2557d\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"0cf87f08-cadc-4646-83a5-749b7c38114e\"><strong>Payment request expiry</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"a4bfae12-3af7-4be1-960f-9828b4252f1a\">1 hour</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"87ed7ee5-1a1d-45b0-92d9-7d7737e62cf8\"><strong>Payment token validity</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"68cffead-dea0-4e6c-8b72-99eca92d9b5e\"></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"ba0dce38-3f3e-49d7-ae0d-da0beca04eb7\"><strong>Settlement time</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"14e766a1-2c6e-480a-8f6b-6a62bb6258bf\">T+1 working day</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"94784d78-3f48-4267-bcfa-f5baf2381b19\"><strong>Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"323aad3c-8115-450e-9e69-5ddb6843d696\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"783f9060-f315-483c-b020-37f8079c7e5f\"><strong>Partial Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"cf665411-2c95-4a5d-b9e9-0d3ec39cf64a\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"55cbaf83-ec18-4147-8950-585e0c4aaba7\"><strong>Multiple Partial Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"957d2006-c589-4751-a1a0-174321a498e2\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"3795b679-c38a-4fae-88f4-7a3498c5b08e\"><strong>Refund Validity</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"9f5634ea-ac19-47ae-9a88-b4b2d4a3d107\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d1760170-fa28-4c8b-b533-419100be3192\"><strong>Compatible integration</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"60823a34-d1b1-427e-90ab-60a877255f19\">Payment API, Payment Link</p></td></tr></tbody></table></div><h2 data-block-id=\"85e36cde-597c-4afe-a0c5-1f9d43883307\"></h2><h2 data-block-id=\"7cacbff0-6097-4577-8bea-2670eefceb05\"></h2><p data-block-id=\"3a86b5ec-38da-4400-83d2-ef1024cbe6c9\"></p><p data-block-id=\"12295416-ce37-4b1f-ae9c-e422707d5254\"></p><p data-block-id=\"8e9aac87-b7ff-4f0e-b9c9-0178d8f76e42\"></p><p data-block-id=\"1fba7422-3f0f-475f-a3cd-ed72e33bce4f\"></p><p data-block-id=\"acd97665-43b1-498b-89ca-e66b24c0a68f\"></p><p data-block-id=\"490a489a-2a58-4dc9-96ea-9e5cc09fc8be\"></p>","SeoTitle":"BDO Online Banking","Description":null},{"Code":"id","Title":"BDO Online Banking","Slug":"bdo-online-banking","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><p data-block-id=\"b1040702-ed6c-4864-84ff-67a01ba05fef\"><img data-block-id=\"ba18f63c-08bc-4a1b-b04a-ad3d40fabef1\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/BDO_Unibank_(logo).svg.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"249\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:249px;\"></p><p data-block-id=\"4211693a-308c-4068-9616-3e68df2e0e78\">BDO Unibank, bank terbesar di Filipina, menawarkan BDO ePayment, sebuah solusi pembayaran online yang aman yang dirancang untuk menyederhanakan transaksi bagi bisnis dan konsumen. Layanan ini memungkinkan pelanggan untuk melakukan pembayaran langsung dari rekening BDO mereka saat melakukan pembelian online.</p><p data-block-id=\"d8636ee0-ede8-4af2-92b6-2311adbc4ee9\">Saluran pembayaran ini terutama digunakan oleh merchant yang menawarkan saluran perbankan online kami yang lain (dengan &#x201c;ONLINE_BANKING&#x201d; dalam nama salurannya). Anda juga dapat berintegrasi langsung dengan saluran debit langsung BDO kami.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Fitur</h2><div data-type=\"table-content\"><table width=\"550\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:550px;width:550px;\"><colgroup><col style=\"width:277px;\"><col style=\"width:273px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"402452f7-7a96-45f3-856a-beec3466fb7a\"><strong>Kode channel</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\"><p data-block-id=\"648b3370-267a-47a5-bafd-0cfb81370827\"><code>BDO_ONLINE_BANKING</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"e924926f-9906-4496-af4a-b319c2a2c8d4\"><strong>Mata uang</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"89cc4585-3036-4f0a-847a-3a0f634c0a27\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6598736d-d850-48ae-b29e-ba649fb13157\"><strong>Jumlah minimum</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"f5c1c704-b8ae-4d25-8fd5-2694332b973d\">1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"93c4567d-ddd5-461c-8459-70cc0cce1024\"><strong>Jumlah maksimum</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"182cd5d4-0077-4254-901f-9939ecae06f1\">2,000,000</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"73a8ce05-a222-44fb-b6c6-fa9069d5dfc4\"><strong>Alur persetujuan pengguna</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"bb42dc08-4557-408e-985f-e98424855151\">REDIRECT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"4888d640-07c9-4a08-aa89-fd2f705958bd\"><strong>Simpan</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"de320cd4-3832-4edb-b65a-d9d2b0717696\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d4dd8a87-001f-4750-954f-3b945aba5e48\"><strong>Berulang</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"0a0ada44-cc78-4f92-b7e3-5d5f5fa029e6\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"1a306633-bbbe-4f04-bf87-db43583cea7b\"><strong>Auth &amp; capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"ac9af3d4-f692-4f73-aedb-7a6a4908a9a2\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6dafaffe-056c-47dd-9363-46082a9133f7\"><strong>Partial capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"60a306e9-b83b-4b04-b5bd-07ffe7fe7665\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"dce8b2c9-f302-4b39-b28f-1629758eefff\"><strong>Multiple partial capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"fce61d55-92ed-4dca-a2a6-29fb90d2557d\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"0cf87f08-cadc-4646-83a5-749b7c38114e\"><strong>Kedaluwarsa permintaan pembayaran</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"a4bfae12-3af7-4be1-960f-9828b4252f1a\">1 jam</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"87ed7ee5-1a1d-45b0-92d9-7d7737e62cf8\"><strong>Validitas token pembayaran</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"68cffead-dea0-4e6c-8b72-99eca92d9b5e\"></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"ba0dce38-3f3e-49d7-ae0d-da0beca04eb7\"><strong>Waktu settlement</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"14e766a1-2c6e-480a-8f6b-6a62bb6258bf\">T+1 hari kerja</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"94784d78-3f48-4267-bcfa-f5baf2381b19\"><strong>Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"323aad3c-8115-450e-9e69-5ddb6843d696\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"783f9060-f315-483c-b020-37f8079c7e5f\"><strong>Partial Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"cf665411-2c95-4a5d-b9e9-0d3ec39cf64a\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"55cbaf83-ec18-4147-8950-585e0c4aaba7\"><strong>Multiple Partial Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"957d2006-c589-4751-a1a0-174321a498e2\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"3795b679-c38a-4fae-88f4-7a3498c5b08e\"><strong>Validitas Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"9f5634ea-ac19-47ae-9a88-b4b2d4a3d107\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d1760170-fa28-4c8b-b533-419100be3192\"><strong>Integrasi yang kompatibel</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"60823a34-d1b1-427e-90ab-60a877255f19\">Payment API, Payment Link</p></td></tr></tbody></table></div><h2 data-block-id=\"85e36cde-597c-4afe-a0c5-1f9d43883307\"></h2><h2 data-block-id=\"7cacbff0-6097-4577-8bea-2670eefceb05\"></h2><p data-block-id=\"3a86b5ec-38da-4400-83d2-ef1024cbe6c9\"></p><p data-block-id=\"12295416-ce37-4b1f-ae9c-e422707d5254\"></p><p data-block-id=\"8e9aac87-b7ff-4f0e-b9c9-0178d8f76e42\"></p><p data-block-id=\"1fba7422-3f0f-475f-a3cd-ed72e33bce4f\"></p><p data-block-id=\"acd97665-43b1-498b-89ca-e66b24c0a68f\"></p><p data-block-id=\"490a489a-2a58-4dc9-96ea-9e5cc09fc8be\"></p>","SeoTitle":"BDO Online Banking","Description":null},{"Code":"th","Title":"BDO ออนไลน์แบงก์กิ้ง","Slug":"bdo-online-banking","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><p data-block-id=\"b1040702-ed6c-4864-84ff-67a01ba05fef\"><img data-block-id=\"ba18f63c-08bc-4a1b-b04a-ad3d40fabef1\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/BDO_Unibank_(logo).svg.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt width=\"249\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link newtab style=\"width:249px;\"></p><p data-block-id=\"4211693a-308c-4068-9616-3e68df2e0e78\">BDO Unibank ซึ่งเป็นธนาคารที่ใหญ่ที่สุดในประเทศฟิลิปปินส์ ให้บริการ BDO ePayment ซึ่งเป็นโซลูชันการชำระเงินออนไลน์ที่ปลอดภัย ออกแบบมาเพื่อทำให้ธุรกรรมง่ายขึ้นสำหรับทั้งธุรกิจและผู้บริโภค บริการนี้ช่วยให้ลูกค้าสามารถชำระเงินได้โดยตรงจากบัญชี BDO ของตนในระหว่างการซื้อสินค้าออนไลน์</p><p data-block-id=\"d8636ee0-ede8-4af2-92b6-2311adbc4ee9\">ช่องทางการชำระเงินนี้ส่วนใหญ่ใช้โดยร้านค้าที่ให้บริการช่องทางการธนาคารออนไลน์อื่น ๆ ของเรา (ที่มีคำว่า “ONLINE_BANKING” อยู่ในชื่อช่องทาง) คุณยังสามารถเชื่อมต่อโดยตรงกับช่องทาง BDO direct debit ของเราได้อีกด้วย</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">คุณสมบัติ</h2><div data-type=\"table-content\"><table width=\"550\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:550px;width:550px;\"><colgroup><col style=\"width:277px;\"><col style=\"width:273px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"402452f7-7a96-45f3-856a-beec3466fb7a\"><strong>รหัสช่องทาง</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\"><p data-block-id=\"648b3370-267a-47a5-bafd-0cfb81370827\"><code>BDO_ONLINE_BANKING</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"e924926f-9906-4496-af4a-b319c2a2c8d4\"><strong>สกุลเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"89cc4585-3036-4f0a-847a-3a0f634c0a27\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6598736d-d850-48ae-b29e-ba649fb13157\"><strong>จำนวนเงินขั้นต่ำ</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"f5c1c704-b8ae-4d25-8fd5-2694332b973d\">1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"93c4567d-ddd5-461c-8459-70cc0cce1024\"><strong>จำนวนเงินสูงสุด</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"182cd5d4-0077-4254-901f-9939ecae06f1\">2,000,000</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"73a8ce05-a222-44fb-b6c6-fa9069d5dfc4\"><strong>ขั้นตอนการอนุมัติของผู้ใช้</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"bb42dc08-4557-408e-985f-e98424855151\">REDIRECT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"4888d640-07c9-4a08-aa89-fd2f705958bd\"><strong>บันทึก</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"de320cd4-3832-4edb-b65a-d9d2b0717696\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d4dd8a87-001f-4750-954f-3b945aba5e48\"><strong>การชำระเงินซ้ำ</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"0a0ada44-cc78-4f92-b7e3-5d5f5fa029e6\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"1a306633-bbbe-4f04-bf87-db43583cea7b\"><strong>การอนุมัติและการเรียกเก็บเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"ac9af3d4-f692-4f73-aedb-7a6a4908a9a2\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6dafaffe-056c-47dd-9363-46082a9133f7\"><strong>การเรียกเก็บเงินบางส่วน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"60a306e9-b83b-4b04-b5bd-07ffe7fe7665\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"dce8b2c9-f302-4b39-b28f-1629758eefff\"><strong>การเรียกเก็บเงินบางส่วนหลายครั้ง</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"fce61d55-92ed-4dca-a2a6-29fb90d2557d\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"0cf87f08-cadc-4646-83a5-749b7c38114e\"><strong>การหมดอายุของคำขอชำระเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"a4bfae12-3af7-4be1-960f-9828b4252f1a\">1 hour</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"87ed7ee5-1a1d-45b0-92d9-7d7737e62cf8\"><strong>ความถูกต้องของโทเค็นการชำระเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"68cffead-dea0-4e6c-8b72-99eca92d9b5e\"></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"ba0dce38-3f3e-49d7-ae0d-da0beca04eb7\"><strong>ระยะเวลาการชำระเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"14e766a1-2c6e-480a-8f6b-6a62bb6258bf\">T+1 working day</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"94784d78-3f48-4267-bcfa-f5baf2381b19\"><strong>การคืนเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"323aad3c-8115-450e-9e69-5ddb6843d696\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"783f9060-f315-483c-b020-37f8079c7e5f\"><strong>การคืนเงินบางส่วน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"cf665411-2c95-4a5d-b9e9-0d3ec39cf64a\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"55cbaf83-ec18-4147-8950-585e0c4aaba7\"><strong>การคืนเงินบางส่วนหลายครั้ง</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"957d2006-c589-4751-a1a0-174321a498e2\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"3795b679-c38a-4fae-88f4-7a3498c5b08e\"><strong>ความถูกต้องของการคืนเงิน</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"9f5634ea-ac19-47ae-9a88-b4b2d4a3d107\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d1760170-fa28-4c8b-b533-419100be3192\"><strong>การเชื่อมต่อที่เข้ากันได้</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"60823a34-d1b1-427e-90ab-60a877255f19\">Payment API, Payment Link</p></td></tr></tbody></table></div><h2 data-block-id=\"85e36cde-597c-4afe-a0c5-1f9d43883307\"></h2><h2 data-block-id=\"7cacbff0-6097-4577-8bea-2670eefceb05\"></h2><p data-block-id=\"3a86b5ec-38da-4400-83d2-ef1024cbe6c9\"></p><p data-block-id=\"12295416-ce37-4b1f-ae9c-e422707d5254\"></p><p data-block-id=\"8e9aac87-b7ff-4f0e-b9c9-0178d8f76e42\"></p><p data-block-id=\"1fba7422-3f0f-475f-a3cd-ed72e33bce4f\"></p><p data-block-id=\"acd97665-43b1-498b-89ca-e66b24c0a68f\"></p><p data-block-id=\"490a489a-2a58-4dc9-96ea-9e5cc09fc8be\"></p>","SeoTitle":"BDO ออนไลน์แบงก์กิ้ง","Description":null},{"Code":"es-mx","Title":"BDO Banca en Línea","Slug":"bdo-online-banking","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><p data-block-id=\"b1040702-ed6c-4864-84ff-67a01ba05fef\"><img data-block-id=\"ba18f3c-08bc-4a1b-b04a-ad3d40fabef1\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/BDO_Unibank_(logo).svg.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt width=\"249\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link newtab style=\"width:249px;\"></p><p data-block-id=\"4211693a-308c-4068-9616-3e68df2e0e78\">BDO Unibank, el banco más grande de Filipinas, ofrece BDO ePayment, una solución de Pago en línea segura diseñada para simplificar las Transacciones tanto para Comercios como para Clientes. Este servicio permite a los Clientes realizar Pagos directamente desde sus Cuentas BDO durante las compras en línea.</p><p data-block-id=\"d8636ee0-ede8-4af2-92b6-2311adbc4ee9\">Este Canal de Pago es utilizado principalmente por Comercios que ofrecen nuestros otros Canales de banca en línea (con \"ONLINE_BANKING\" en el Nombre del Canal). Usted también puede integrar directamente con nuestro Canal Direct Debit de BDO.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Características</h2><div data-type=\"table-content\"><table width=\"550\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:550px;width:550px;\"><colgroup><col style=\"width:277px;\"><col style=\"width:273px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"402452f7-7a96-45f3-856a-beec3466fb7a\"><strong>Código del Canal</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\"><p data-block-id=\"648b3370-267a-47a5-bafd-0cfb81370827\"><code>BDO_ONLINE_BANKING</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"e924926f-9906-4496-af4a-b319c2a2c8d4\"><strong>Moneda</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"89cc4585-3036-4f0a-847a-3a0f634c0a27\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"6598736d-d850-48ae-b29e-ba649fb13157\"><strong>Monto mínimo</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"f5c1c704-b8ae-4d25-8fd5-2694332b973d\">1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"93c4567d-ddd5-461c-8459-70cc0cce1024\"><strong>Monto máximo</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"182cd5d4-0077-4254-901f-9939ecae06f1\">2,000,000</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"73a8ce05-a222-44fb-b6c6-fa9069d5dfc4\"><strong>Flujo de aprobación del usuario</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"bb42dc08-4557-408e-985f-e98424855151\">REDIRECT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"4888d640-07c9-4a08-aa89-fd2f705958bd\"><strong>Guardar</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"de320cd4-3832-4edb-b65a-d9d2b0717696\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"d4dd8a87-001f-4750-954f-3b945aba5e48\"><strong>Recurrente</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273\" style=\"width:273px;\"><p data-block-id=\"0a0ada44-cc78-4f92-b7e3-5d5f5fa029e6\">&#x274c;</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"277\"><p data-block-id=\"1a306633-bbbe-4f04-bf87-db43583cea7b\"><strong>Auth &amp; capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"273