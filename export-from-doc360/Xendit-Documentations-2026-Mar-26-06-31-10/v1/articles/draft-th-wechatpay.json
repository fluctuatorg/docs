[{"Code":"en","Title":"TH WeChatPay","Slug":"draft-th-wechatpay","ContentType":2,"Content":"<p data-block-id=\"mmmw0dty-6ozijr-001\"><a id=\"_j5wih1vxvjn6\" display=\"false\"></a></p><h2 data-block-id=\"mmmw0dty-21csbi-002\"><a id=\"_ejxly55we75x\" display=\"false\"></a>Xendit Stakeholders</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dtz-3px12t-003\"><strong>Department</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du0-lshsmn-004\"><strong>PIC</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du0-3i2nt4-005\"><strong>PIC Role</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du0-fiue2e-006\">Sales/ CS</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdl-81g6ux-500\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du1-9lm06c-007\">Submitting the request</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du1-tvk0ki-008\">MO</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du1-mpfisu-009\">TH-MO</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du1-mafo4p-010\">Request MID and activate channels</p></th></tr></tbody></table></div><h1 data-block-id=\"mmmw0du1-z237mm-011\"><a id=\"_l0o6jdyv2txv\" display=\"false\"></a></h1><h2 data-block-id=\"mmmw0du2-spsaee-012\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a>Eligibility</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du2-wzvey5-014\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du3-m2q4d6-015\"><strong>Eligible</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du3-l43b7x-016\">Sole Proprietorship</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du3-fouapn-017\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du3-sriitp-018\">Corporation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du3-xghxqi-019\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du4-6gtrje-020\">Non-Local Entities</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du4-vn76q7-021\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du4-k341q0-022\">Partnership</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du4-fyzkq1-023\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du4-yx12v5-024\">Non-Profit</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du4-8kdwna-025\">❌</p></th></tr></tbody></table></div><h2 data-block-id=\"mmmw0du4-w4r68i-026\"><a id=\"_6c0oxkffxx60\" display=\"false\"></a>Merchant Requirements </h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du5-rv1ilz-028\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du5-zhfrvd-029\"><strong>Requirements</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du5-los27r-030\">Account Status</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du5-z1aaxq-031\">The merchant account must be<strong> LIVE</strong> before applying for WeChatPay activation.</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du5-0dr5d3-032\">Permitted and Restricted Categories</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du5-patl7b-033\">Can refer to the link here: <a href=\"https://pay.weixin.qq.com/index.php/public/wechatpay_en/proper_rule\"><u>https://pay.weixin.qq.com/index.php/public/wechatpay_en/proper_rule</u></a> </p></th></tr></tbody></table></div><h2 data-block-id=\"mmmw0du6-s2oiek-034\"><a id=\"_ujkex4eg0uw0\" display=\"false\"></a>SLA</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du6-0nbb9m-035\"><strong>Entity Origin</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du6-787dxs-036\"><strong>SLA</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du6-1ln3h8-037\">All Entities</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du6-d7qego-038\">7 Business Days</p></th></tr></tbody></table></div><h2 data-block-id=\"mmmw0du6-la2pjk-039\"><a id=\"_r0miqi6pvfyc\" display=\"false\"></a>Onboarding Flow</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:50px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du6-jcz3mj-040\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmmw0du6-t7ls6n-041\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du7-k1yze7-042\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du7-e9skp3-043\"><strong>Owner / PIC </strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du7-6uv7q1-044\">Channel Activation</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmmw0du7-eh8w76-045\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du7-4lw7q4-046\">Merchants submit requests via CS (<a><u>help@xendit.th</u></a>), MO (<a href=\"http://merchantops.th\"><u>merchantops.th</u></a>), or Sales/AM/BD team request for their merchant in<a href=\"https://xendit.slack.com/archives/CRCJ2E5CK\"> #mo-request</a> and<a href=\"https://xendit.slack.com/archives/C06338WEJ9M\"> #thailand-pg-activation-request</a></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du7-48bdd6-047\">Merchant</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdq-6t0bek-501\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmmw0du8-x53j72-048\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du8-v9zbag-049\">Submit merchant information through the designated<a href=\"https://pay.weixin.qq.com/index.php/public/wechatpay_en\"> <u>WeChat Partner Link</u></a>.</p></th><th colspan=\"1\" rowspan=\"3\"><p data-block-id=\"mmmw0du8-xui4bp-050\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdr-j0cjak-502\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmmw0du8-cgqa2f-051\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0du8-jyhriw-052\">From the website complete the following: </p><ul data-block-id=\"mmmw0du8-gsxw0e-053\"><li data-block-id=\"mmmw0du8-l8quba-054\"><p data-block-id=\"mmt00wdr-ojs3ik-503\"><strong>Data Entry:</strong> Fill in business details, registration details, and 1 Authorized Person’s info (Name, ID, Phone).</p></li><li data-block-id=\"mmmw0du9-6n7nul-055\"><p data-block-id=\"mmt00wdr-0izzef-504\"><strong>Document Upload:</strong> Upload the 1st page of Company Registration and the 3 required storefront photos (if applicable).</p><ul data-block-id=\"mmmw0du9-5k16i6-056\"><li data-block-id=\"mmmw0du9-1v9bqf-057\"><p data-block-id=\"mmt00wds-vpo9wh-505\">Storefront criteria: </p><ul data-block-id=\"mmmw0du9-vzueyp-058\"><li data-block-id=\"mmmw0du9-l3pq1o-059\"><p data-block-id=\"mmt00wds-kc7ky9-506\">A screenshot of their business's location on Google Maps.</p></li><li data-block-id=\"mmmw0du9-9p2wq3-060\"><p data-block-id=\"mmt00wds-sgijzq-507\">A picture of their store's exterior. This should show the front of the store and be taken from the street.</p></li><li data-block-id=\"mmmw0du9-1us0dp-061\"><p data-block-id=\"mmt00wds-1fre0u-508\">A picture of their checkout counter or cashier area.</p></li></ul></li></ul></li></ul></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wds-lv0vhh-509\"></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmmw0du9-0j4flt-062\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-j7aorv-063\">MO will be able to obtain the <strong>Sub-merchant ID</strong> immediately from the portal.</p></th></tr></tbody></table></div><h2 data-block-id=\"mmmw0dua-ok1slg-064\"><a id=\"_u96tqxtduroc\" display=\"false\"></a>Activation Flow</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-vkpnnc-065\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-y2d4yn-066\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-531crk-067\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-p4iigb-068\"><strong>Owner / PIC </strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-5ev4px-069\">Channel Activation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dua-bx9z0f-070\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dub-ddrcnx-071\">Once the MID is activated on the partner portal, proceed with internal activation using <a href=\"https://retool.tidnex.com/apps/cb87be2c-17f5-11ef-a73d-ffe38ac9a56b/Channel%20Approval/Internal%20Channel%20Activation%20v2\"><u>retool</u></a>.</p></th><th colspan=\"1\" rowspan=\"4\"><p data-block-id=\"mmmw0dub-13sn6b-072\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdu-fqudy2-510\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dub-0fuwid-073\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dub-n5sinq-074\">Navigate to the Channel Activation Tab, input the merchant’s BID, and select Transaction Entity (Xendit Thailand).</p><p data-block-id=\"mmmw0dub-1an197-075\"><img data-block-id=\"mmmw0dub-t7jds0-076\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-th-wechatpay-image-ldx0246v.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdu-pmq1y0-511\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0duc-wgr9ty-077\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0duc-owwspg-078\">Select <strong>EWALLET</strong> as the payment method and <strong>WeChatPay One Time Payment</strong> as the Channel. </p><p data-block-id=\"mmmw0duc-eevdf5-079\"><img data-block-id=\"mmmw0duc-pr5mn9-080\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-th-wechatpay-image-vvmhb5gq.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdv-ocsyqf-512\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0duc-vyin1w-081\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0duc-blcl67-082\">On the next page, Input credentials from the website:</p><ul data-block-id=\"mmmw0duc-3qgyky-083\"><li data-block-id=\"mmmw0duc-4a6p1n-084\"><p data-block-id=\"mmt00wdv-o3579k-513\">Merchant name = Merchant name</p></li><li data-block-id=\"mmmw0dud-55hvrn-085\"><p data-block-id=\"mmt00wdv-r782wu-514\">Wechat Submerchant ID = MerchantID</p></li><li data-block-id=\"mmmw0dud-jtsfo7-086\"><p data-block-id=\"mmt00wdv-ynwwc1-515\">Wechat private key = GlobalPrimeCorparationSecretKey1 <strong>(for all merchants)</strong></p></li></ul><p data-block-id=\"mmmw0dud-d3sn1h-087\"><strong><img data-block-id=\"mmmw0dud-5f2u15-088\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-th-wechatpay-image-qn5gvmve.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></strong></p><p data-block-id=\"mmmw0dud-kafyv7-089\"><strong>Sample MID from website:</strong></p><p data-block-id=\"mmmw0dud-iafh9y-090\"><strong><img data-block-id=\"mmmw0dud-lnv2te-091\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-th-wechatpay-image-ormfttf2.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdw-z8zrd5-516\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dud-vdw99a-092\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dud-izd6jl-093\">Click<strong> \"Activate\"</strong> to complete the process.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdw-rhhymm-517\"></p></th></tr></tbody></table></div><h2 data-block-id=\"mmmw0dud-8rbxsp-094\"><a id=\"_k7a5uinhlumg\" display=\"false\"></a>Rejection Flow</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0dud-45bzpd-095\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0due-f3epem-096\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0due-bllp78-097\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0due-6i60bv-098\"><strong>Owner / PIC </strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmt00wdx-1syw0q-518\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0due-uodahi-099\">1.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0due-lo1uzg-100\">If a merchant fails onboarding criteria, the MO agent notifies the requester via the original submission channel:</p><ul data-block-id=\"mmmw0due-sb88tt-101\"><li data-block-id=\"mmmw0due-1wm3pz-102\"><p data-block-id=\"mmt00wdx-lnv7v8-519\">CS: Inform the team to relay the result to the merchant.\t</p></li><li data-block-id=\"mmmw0due-p2ssk8-103\"><p data-block-id=\"mmt00wdx-f7r9nc-520\">Direct MO: Respond to the existing email thread.\t</p></li><li data-block-id=\"mmmw0due-z5aos8-104\"><p data-block-id=\"mmt00wdx-jap7i9-521\">Sales/Slack: Reply within the #mo-request or #thailand-pg-activation-request thread.</p></li></ul></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmmw0due-i040bx-105\">MO</p></th></tr></tbody></table></div><p data-block-id=\"mmt00wdy-klle3o-522\"></p>","SeoTitle":"TH WeChatPay","Description":null},{"Code":"id","Title":"TH WeChatPay","Slug":"th-wechatpay","ContentType":2,"Content":null,"SeoTitle":"TH WeChatPay","Description":null},{"Code":"th","Title":"TH WeChatPay","Slug":"th-wechatpay","ContentType":2,"Content":null,"SeoTitle":"TH WeChatPay","Description":null},{"Code":"es-mx","Title":"TH WeChatPay","Slug":"th-wechatpay","ContentType":2,"Content":null,"SeoTitle":"TH WeChatPay","Description":null}]