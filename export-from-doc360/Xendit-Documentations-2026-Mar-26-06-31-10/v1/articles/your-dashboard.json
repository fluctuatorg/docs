2Fupload%2Fc_fill%2Ch_1800%2Cw_2880%2Fv1%2FDashboard%2FScreenshot_2024-06-28_at_16.06.31_cptfcg%3F_a%3DBATCr5fi0&amp;w=3840&amp;q=75\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"2880\" height=\"1800\" dataalign=\"center\" datadisplay=\"inline\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"yes\" link=\"\" newtab=\"\" style=\"box-sizing:border-box;border:0px solid rgb(229, 231, 235);--tw-border-spacing-x:0;--tw-border-spacing-y:0;--tw-translate-x:0;--tw-translate-y:0;--tw-rotate:0;--tw-skew-x:0;--tw-skew-y:0;--tw-scale-x:1;--tw-scale-y:1;--tw-pan-x:;--tw-pan-y:;--tw-pinch-zoom:;--tw-scroll-snap-strictness:proximity;--tw-ordinal:;--tw-slashed-zero:;--tw-numeric-figure:;--tw-numeric-spacing:;--tw-numeric-fraction:;--tw-ring-inset:;--tw-ring-offset-width:0px;--tw-ring-offset-color:#fff;--tw-ring-color:rgba(59,130,246,.5);--tw-ring-offset-shadow:0 0 #0000;--tw-ring-shadow:0 0 #0000;--tw-shadow:0 0 #0000;--tw-shadow-colored:0 0 #0000;--tw-blur:;--tw-brightness:;--tw-contrast:;--tw-grayscale:;--tw-hue-rotate:;--tw-invert:;--tw-saturate:;--tw-sepia:;--tw-drop-shadow:;--tw-backdrop-blur:;--tw-backdrop-brightness:;--tw-backdrop-contrast:;--tw-backdrop-grayscale:;--tw-backdrop-hue-rotate:;--tw-backdrop-invert:;--tw-backdrop-opacity:;--tw-backdrop-saturate:;--tw-backdrop-sepia:;display:block;vertical-align:middle;max-width:100%;height:auto;margin-top:2em;margin-bottom:2em;font-family:ui-sans-serif, system-ui, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, Roboto, &quot;Helvetica Neue&quot;, Arial, &quot;Noto Sans&quot;, sans-serif, &quot;Apple Color Emoji&quot;, &quot;Segoe UI Emoji&quot;, &quot;Segoe UI Symbol&quot;, &quot;Noto Color Emoji&quot;;font-size:16px;font-style:normal;font-variant-ligatures:normal;font-variant-caps:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-indent:0px;text-transform:none;widows:2;word-spacing:0px;-webkit-text-stroke-width:0px;text-decoration-thickness:initial;text-decoration-style:initial;text-decoration-color:initial;color:transparent;\"></p><br type=\"block\"><p data-block-id=\"40082392-8fc4-49aa-be54-8bf93c508150\"></p>","SeoTitle":"แดชบอร์ดของคุณ","Description":null},{"Code":"es-mx","Title":"Tu dashboard","Slug":"your-dashboard","ContentType":2,"Content":"<p data-block-id=\"1baf028f-db08-459c-8a96-8e572e47a76a\">Una vez que hayas creado una cuenta, serás dirigido a tu dashboard. Antes de comenzar a <mark class=\"9ce23557-426e-44b1-8286-7710904343c8\" data-type=\"comment\" data-comment-id=\"9ce23557-426e-44b1-8286-7710904343c8\">crear</mark> transacciones, es importante entender que tu dashboard tiene dos modos:</p><ul data-block-id=\"db62505f-8847-4ea8-b55d-73a55ba93a01\"><li data-block-id=\"6db24df9-35b4-4fb2-983e-62ec68a36d78\" style=\"--pseudoBefore--fontWeight:bold;\"><p data-block-id=\"a69fd403-4dd4-4a5d-9194-4da35d60315b\"><strong>Test Mode</strong>: Experimenta y familiarízate con nuestras funciones o prueba tu integración a fondo utilizando fondos virtuales. En Test Mode, tus transacciones no se realizan con dinero real, por lo que puedes probar de forma segura diferentes <mark class=\"d9d42e60-7181-4a9b-80b9-d978aea8e0bd\" data-type=\"comment\" data-comment-id=\"d9d42e60-7181-4a9b-80b9-d978aea8e0bd\">características y</mark> funcionalidades antes de lanzar a producción en vivo.</p></li><li data-block-id=\"7b9091c2-a4d1-40f9-aa33-e94305dbad90\" style=\"--pseudoBefore--fontWeight:bold;\"><p data-block-id=\"6b68c8b3-00f0-4ade-b44c-71a902d5dfb6\"><strong>Live Mode</strong>: Acepta y procesa pagos reales de tus clientes. Este modo estará disponible una vez que tu cuenta haya sido activada.</p></li></ul><p data-block-id=\"c91cfcb6-83b1-4743-adee-5fc9deb347bd\">Verás una etiqueta en la esquina inferior izquierda de tu dashboard, debajo del logo de tu negocio, que indica claramente si te encuentras actualmente en Test Mode o Live Mode.</p><h2 data-block-id=\"731d01d2-ea77-4747-aeeb-51869049cd8c\" style=\"text-align:start;\"><mark class=\"f5e5c99b-efc4-4ea7-94a7-327f0e404ab7\" data-type=\"comment\" data-comment-id=\"f5e5c99b-efc4-4ea7-94a7-327f0e404ab7\"><strong>Cómo cambiar los modos del dashboard</strong></mark></h2><ol data-block-id=\"60b47698-460f-42f1-b8e8-5cf1e4b1aa46\" start=\"1\"><li data-block-id=\"f93aaf72-e8ea-49a0-9fc8-da4a8c9543ce\"><p data-block-id=\"05b55174-79a7-43fe-959e-d7b536e9d4b9\">Haz clic en el&nbsp;<strong>nombre de tu negocio</strong>&nbsp;en la esquina inferior izquierda del dashboard</p></li><li data-block-id=\"d51bd7e1-01ee-46d4-b770-dbdcd6b01f4c\"><p data-block-id=\"37b684b3-eff4-48f7-8564-6c3c98d09afe\">Activa o desactiva la opción&nbsp;<strong>Switch to Test / Live Mode&nbsp;</strong>según sea necesario</p></li><li data-block-id=\"55fc5990-d0e0-4d13-862e-4286d059fc20\"><p data-block-id=\"b178d42c-f2af-43c7-a153-cc92b6c3ae34\">Cuando cambies a Test Mode, solo se <strong>aplicará a tu propio dashboard y no al de los miembros de tu equipo</strong></p></li><li data-block-id=\"c3ee80af-ada5-4005-86ae-f9b148193956\"><p data-block-id=\"41e342db-5883-4a08-96cc-97cfbd1677aa\">En Live Mode, también puedes optar por volver a Test Mode; esto no borrará tu actividad en Live Mode</p></li></ol><h2 data-block-id=\"f516f836-6be5-4df1-91cc-17c001599550\"><mark class=\"9a2d82d0-988f-468f-adb3-e0abea15c4fe\" data-type=\"comment\" data-comment-id=\"9a2d82d0-988f-468f-adb3-e0abea15c4fe\">Tus detalles de negocio y perfil</mark></h2><p data-block-id=\"292d91b9-30bb-40e3-9cd4-a3d1677c9f04\">Para ver l<mark class=\"d6c0cfa6-35b2-47a5-ac7c-c4bfb2fabb31\" data-type=\"comment\" data-comment-id=\"d6c0cfa6-35b2-47a5-ac7c-c4bfb2fabb31\">os detalles de tu negocio y perfil</mark>, haz clic en <strong>Edit Profile</strong>. La información que enviaste al crear tu cuenta y <mark class=\"b46dca40-4ffc-41ac-a525-3ef95941170c\" data-type=\"comment\" data-comment-id=\"b46dca40-4ffc-41ac-a525-3ef95941170c\">verificar tus detalles</mark> se mostrará en <strong>Your Business</strong>. Si deseas <mark class=\"3315c7ad-27ba-4731-b23e-d7d9bb56125b\" data-type=\"comment\" data-comment-id=\"3315c7ad-27ba-4731-b23e-d7d9bb56125b\">actualizar alguno de estos detalles,</mark> por favor contacta a <a href=\"mailto:help@xendit.co\" translate=\"no\">help@xendit.co</a></p><p data-block-id=\"9538c31c-4c86-4f25-aa47-d534b7b4c7db\">En <strong>Your Profile</strong>, podrás ver los siguientes detalles:</p><ul data-block-id=\"8010ac86-272d-4906-b0a1-082b5dafc72c\"><li data-block-id=\"2a8971c4-1f68-41bb-b628-11d8cd604750\" style=\"--pseudoBefore--fontWeight:bold;\"><p data-block-id=\"667aecca-2868-4ae8-9a7b-6ac8e25f675b\"><strong>Email: </strong>El correo electrónico que <mark class=\"a17d6499-828f-4cb7-ae50-b694f570c042\" data-type=\"comment\" data-comment-id=\"a17d6499-828f-4cb7-ae50-b694f570c042\">usaste</mark> para iniciar sesión, no el correo electrónico de negocio de la cuenta.</p></li><li data-block-id=\"1556c310-8f2c-480c-b826-53be2159d13a\" style=\"--pseudoBefore--fontWeight:bold;\"><p data-block-id=\"b4683d00-2dd9-4ee3-87b6-55851457b1c7\"><strong>PIN: </strong>Un PIN de 6 dígitos utilizado para autorizar Payouts y reembolsar cargos de tarjeta.</p></li><li data-block-id=\"34d7cc87-21ed-4936-a623-b0f6399ad3dc\" style=\"--pseudoBefore--fontWeight:bold;\"><p data-block-id=\"4981b187-70fa-49f3-b32a-6e6fc5174d38\"><a href=\"/v1/docs/set-up-2fa\" target=\"_blank\" translate=\"no\"><strong>2FA Authentication</strong></a><strong>: </strong>Seguridad adicional para autenticar tu inicio de sesión.</p></li><li data-block-id=\"8e43d8c3-8887-4ede-bf89-2aa4cebf6bc0\" style=\"--pseudoBefore--fontWeight:bold;\"><p data-block-id=\"e009850e-fbcd-4ecb-b76b-2df98cc5639d\"><strong>Dashboard Timezone Preference: </strong>Esta configuración afectará la hora mostrada en tu dashboard y la hora en que se enviará tu <a href=\"/v1/docs/transactions-report\" target=\"_blank\" translate=\"no\">reporte de transacciones</a> (esto solo aplicará a tu cuenta, y no a la de los miembros de tu equipo).</p></li></ul><h2 data-block-id=\"734590ee-e371-44f0-8274-451a59c77888\">Actualización de una cuenta de negocio no incorporado a una cuenta de negocio incorporado</h2><p data-block-id=\"1837f697-b272-48f1-8435-03fe8f6422c8\">Puede actualizar su cuenta de una cuenta individual a una cuenta de negocio contactando a help@xendit.co. <mark class=\"c3518fd3-a0f6-40c7-96c6-acdbb28856b0\" data-type=\"comment\" data-comment-id=\"c3518fd3-a0f6-40c7-96c6-acdbb28856b0\">Asegúrese</mark> de <mark class=\"842f5cfe-bf68-407f-95e2-06aa598535af\" data-type=\"comment\" data-comment-id=\"842f5cfe-bf68-407f-95e2-06aa598535af\">haber preparado la</mark> <a href=\"https://xendit-docs.document360.io/docs/create-account\" target=\"_blank\" translate=\"no\">información y documentos requeridos</a>.</p><p data-block-id=\"d1962286-8192-4415-ba2c-508527e7dd1f\"></p>","SeoTitle":"Tu dashboard","Description":null}]