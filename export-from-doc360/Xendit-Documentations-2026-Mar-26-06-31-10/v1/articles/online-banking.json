[{"Code":"en","Title":"FPX Online Banking","Slug":"online-banking","ContentType":2,"Content":"<p data-block-id=\"mhyacs1h-df7vo0-629\"><img data-block-id=\"mhybjcby-dbrm1q-235\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image(162).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"72\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:72px;\"></p><p data-block-id=\"mhyacs1h-df7vo0-629\">FPX is an online payment service that allows customers to pay for purchases and bills in real-time by debiting their bank account directly through their internet banking portal. It is a secure and reliable payment gateway, operated by <span class=\"s1\" type=\"spanMark\">PayNet,</span> a subsidiary of Bank Negara Malaysia, that enables secure and direct crediting to the merchant's account.</p><p data-block-id=\"mhyaih1d-1zxwe7-842\"><span type=\"spanMark\" style=\"color:rgb(174, 171, 171);\">________________________________________________________________________________________________________________________________</span></p><h2 data-block-id=\"mhyajwc9-shm02e-968\">Features</h2><div data-type=\"table-content\"><table width=\"878\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:878px;width:878px;\"><colgroup><col style=\"width:300px;\"><col style=\"width:578px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsl-ynnjy7-095\"><strong>Channel Code</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsm-hlsaat-096\"><span type=\"spanMark\" style=\"color:rgb(17, 24, 39);background:rgb(243, 244, 246);font-size:12px;font-weight:600;letter-spacing:0.02em;display:inline-block;padding:4px 8px;border-radius:6px;\">{Bank Name}_FPX, {Bank Name}_FPX_BUSINESS</span></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyaqe2g-mtas2k-162\"><strong>Bank Name</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyaqtxe-1jm4j3-163\">AFFIN, AGRO, ALLIANCE, AMBANK, BNP (FPX_BUSINESS only), BOC (FPX only), BSN (FPX only), CIMB, CITIBANK (FPX_BUSINESS only), DEUTSCHE (FPX_BUSINESS only), HLB, HSBC, ISLAM, KFH, MAYB2E, MAYB2U (FPX only), MUAMALAT, OCBC, PUBLIC, RAKYAT, RHB, SCH, UOB</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsm-v5hue1-097\"><strong>Display Name</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsn-bapaod-098\">{Bank Name} FPX or {Bank Name} FPX (Business)</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsn-vbnvlo-099\"><strong>Currency</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsn-gg4ix7-100\">MYR</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbso-d1ncah-101\"><strong>Country</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbso-zwv4l2-102\">MY</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbso-m4rtwx-103\"><strong>Type</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbso-rb6thb-104\">ONLINE BANKING</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsp-wzle38-105\"><strong>Min Amount</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsp-7q8d4p-106\">1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsp-etadgp-107\"><strong>Max Amount (FPX)</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsq-bmxpzc-108\">30,000.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyb4zaa-wknwhu-171\"><strong>Max Amount (FPX Business)</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyb59ih-3wl92l-172\">1,000,000.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsq-v91vwe-109\"><strong>User Approval Flow</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsq-eibfvc-110\">REDIRECT, SKIP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsr-is8sby-111\"><strong>Reusable Payment Code</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsr-9mqlkg-112\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsr-0hchwp-113\"><strong>Save</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbss-d6flww-114\">✓</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbss-6bv05t-115\"><strong>Merchant Initiated Transaction</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbss-kij841-116\">✓</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbst-99qofp-117\"><strong>Auth &amp; Capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbst-jh7414-118\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbst-mhbzho-119\"><strong>Partial Capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbst-u3c63h-120\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsu-a6hsx0-121\"><strong>Multiple Partial Capture</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsu-6pii60-122\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsu-xpuvfp-123\"><strong>Desktop Support</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsv-9od8x8-124\">WEB URL</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsv-mwpux6-125\"><strong>Mobile Support</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsv-5jif6l-126\">MOBILE WEB URL</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsw-2fjiog-127\"><strong>Custom Payment Code</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsw-zbvahj-128\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsw-q0iezn-129\"><strong>Display Merchant Name</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsx-4l8kes-130\">MERCHANT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsx-g5a094-131\"><strong>Display User Name</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsx-gadzyt-132\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsy-04uype-133\"><strong>Set Expiry</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsy-fl86dv-134\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsy-6fs6gf-135\"><strong>Payment Request Expiry (hours)</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsy-487o60-136\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsz-m3arg4-137\"><strong>Payment Token Validity (years)</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbsz-7r3kph-138\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbsz-0swfs6-139\"><strong>Payment Processing Time (hours)</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt0-ub18rw-140\">INSTANT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt0-64v21a-141\"><strong>Settlement Time</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt0-5xdc99-142\">T+2 CALENDAR DAYS</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt1-giriob-143\"><strong>Installments</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt1-vpzxn1-144\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt1-sboqdm-145\"><strong>Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt2-3xjvjt-146\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt2-65nhl9-147\"><strong>Partial Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt2-uo9nq1-148\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt3-f7of2v-149\"><strong>Multiple Partial Refund</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt3-xa2c46-150\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt3-29v8zc-151\"><strong>Refund Validity (days)</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt3-b2ryfx-152\">-</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt4-ffhet1-153\"><strong>Payment Link</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt4-5vcdja-154\">✓</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"300\" style=\"background-color:rgb(242, 242, 242);\"><p data-block-id=\"mhyakbt4-mn6g5d-155\"><strong>Fund Flow</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"578\"><p data-block-id=\"mhyakbt5-tgd9n2-156\">AGGREGATOR, SWITCHER</p></td></tr></tbody></table></div><h2 data-block-id=\"mhyhmwjc-9ipcrb-373\">Payment flow</h2><p data-block-id=\"mhyhtr5g-624bjs-376\">Step 1: Select FPX Online banking and choose the required bank.<br type=\"inline\"><br type=\"inline\"><img src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image(198).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"526\" dataalign=\"center\" datadisplay=\"inline\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" style=\"width:526px;\"></p><p data-block-id=\"mhyhuo97-55fgy3-377\">Step 2: You will be redirected to the chosen bank online banking page. Login with banking credentials (example Maybank).</p><p data-block-id=\"mhyhuo97-55fgy3-377\"><img data-block-id=\"mhyi9z0q-bbe9t7-510\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/Screenshot 2025-11-14 at 2.42.47 pm(1).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"340\" height=\"420\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:340px;height:420px;\"></p><p data-block-id=\"mhyhuo97-55fgy3-377\">Step 3: Select the account, click “Continue” and complete the 3DS (example Maybank).<br type=\"inline\"><br type=\"inline\"><img data-block-id=\"mhyi9z0q-cztvbd-511\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/Screenshot 2025-11-14 at 2.43.30 pm.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"343\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:343px;\"></p><p data-block-id=\"mhyi38j4-ehi5qy-383\">Step 4: Payment completed.</p><p data-block-id=\"mmk9663i-d49ab2-002\"><img src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image(199).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"431\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" style=\"width:431px;\"></p><p data-block-id=\"mhyi36vu-7udvso-382\"></p>","SeoTitle":"FPX Online Banking","Description":null},{"Code":"id","Title":"Online Banking","Slug":"online-banking","ContentType":2,"Content":null,"SeoTitle":"Online Banking","Description":null},{"Code":"th","Title":"Online Banking","Slug":"online-banking","ContentType":2,"Content":null,"SeoTitle":"Online Banking","Description":null},{"Code":"es-mx","Title":"Online Banking","Slug":"online-banking","ContentType":2,"Content":null,"SeoTitle":"Online Banking","Description":null}]