[{"Code":"en","Title":"CVM","Slug":"cvm","ContentType":2,"Content":"<p data-block-id=\"0ea65c3d-a38c-40be-a208-d546ab91ccec\"><img data-block-id=\"ddc1ed3e-11cd-4537-bffb-fa882bb16eac\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/CVM Pawnshop Home.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" title=\"image(23).png\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"40d09386-139f-4cf1-8307-2c85d716974e\">CVM Pawnshop, with its extensive network of branches across the Philippines, enables businesses to accept over-the-counter payments from customers who prefer offline transactions. Customers can settle online purchases by providing a transaction reference number at any CVM branch, making it a convenient option for those without bank accounts or who favor cash payments.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Features</h2><div data-type=\"table-content\"><table width=\"735\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:735px;width:735px;\"><colgroup><col style=\"width:463px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"db4dfef8-c563-4305-8c29-ef2b1aa63d40\">Channel Code</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"e1e6e1e6-c602-409f-9e71-21f3f2b349df\"><code>CVM</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"05742465-0957-4c43-b4a1-a714d1ec5bd9\">Currency</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"3f8936e1-14e1-4482-860e-cd08d70c3f38\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"216547ce-9149-4c98-863b-af7a9b417559\">Minimum Amount</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"17190da0-2088-4c47-9f9a-c92fafebdd48\">50.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"917595fc-cd1e-4638-a3ac-8c763018c400\">Maximum Amount</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"2760134e-54b9-4aaa-9d81-734957700cdf\">30,000.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"dd693bd7-6fa5-470c-a762-3bd25581ee55\">User Approval Flow</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"171da64c-8dad-441b-8a44-dc494f51d517\">PRESENT TO CUSTOMER</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"00b142a2-96d8-469f-a603-d7f653f2f6a6\">Reusable Payment Code</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"c221f08c-7f47-4f90-8365-ce103ec676ed\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"a15e3b11-bb7c-4496-bbdd-cbc61b5faf78\">Custom Payment Code</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overf