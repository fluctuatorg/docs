gn:bottom;\"><p data-block-id=\"e763223f-2dbe-41be-84b3-3f5eb0ddb4d4\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"0baabc7e-a92b-49d0-af45-796c16289f04\">Partial Refund</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"8d7ea2ae-48b1-4f75-a0c5-f0ad349be77d\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"166f9598-76a9-48a7-b24b-9c06b9f896ce\">Multiple Partial Refund</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"caa96435-1191-4058-9ebc-afd3a21a945a\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"256467fa-b7fd-45f2-b88e-195088282404\">Refund Validity (days)</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"4f7f6f8a-2e73-4aa5-8176-f3341285afc1\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"5c93e485-a74d-4a50-8a1b-9bba2a9f420b\">Compatible integration</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"637ff717-8b2b-4064-8310-d9c57c754e25\">Payment API</p></td></tr></tbody></table></div><h2 data-block-id=\"2b081c08-ffd2-493a-b253-c4931f5f1c75\">How to pay</h2><ol data-block-id=\"7d99ad68-e560-4694-8e5e-5aace1ffb55e\" start=\"1\"><li data-block-id=\"fcdd7171-436b-4481-a75d-b1ca8510cef6\"><p data-block-id=\"72545818-c18b-4e6f-a493-1f8f83e7e6a5\">Visit your nearest CVM pawnshop branch before payment code expires.</p></li><li data-block-id=\"4e1d5fc1-c71e-4fd2-99a3-6a62970879b2\"><p data-block-id=\"f3b42f26-0ed5-46da-b12c-71ac5af9327a\">Tell the cashier/staff that you will be making a Dragonpay Payment</p></li><li data-block-id=\"8dc8811b-8e9d-4a37-8f38-bbdc6c6f7af2\"><p data-block-id=\"f4ff179b-fc93-4b18-bad4-c7a50a8e462f\">You will be asked to write on a piece of paper these following details:</p><ol data-block-id=\"b2ee998a-c99e-4a26-9297-871134de94f8\" start=\"1\"><li data-block-id=\"da0bc416-4aa3-47bc-8f83-2c70ed10789a\"><p data-block-id=\"e0c810c4-bed1-417a-bd49-b27f4009ca3f\">Your Name</p></li><li data-block-id=\"a50f731b-4940-449c-8ef8-e94e75576a7b\"><p data-block-id=\"cd7ce936-ed55-43bb-9b1f-84bb9dea21de\">Your Mobile Number</p></li><li data-block-id=\"a4119b46-cfca-43f0-a0d1-f3890282ff9d\"><p data-block-id=\"9d581cc2-369c-493e-9b14-831a0bec3638\">Your Birthday</p></li><li data-block-id=\"9efd745a-2b90-40ce-811a-0ab98a682d3b\"><p data-block-id=\"83f779aa-eed6-4c02-ab3d-01fc455107c1\">Payment Code given by Merchant</p></li><li data-block-id=\"3f1fe4c9-e053-4bf1-ab5d-4201c15a2774\"><p data-block-id=\"d68abcd7-2abb-4a3a-9129-5e26145f0564\">Amount</p></li><li data-block-id=\"52dcf67c-03b9-4fa9-b2f5-218a4dd89d4e\"><p data-block-id=\"be2d0b18-e68f-4ec4-86e4-4fd757e32f65\">Purpose of Payment</p></li></ol></li><li data-block-id=\"67127e7b-41aa-4724-8c08-727d8498f2a7\"><p data-block-id=\"196802d1-6d53-44aa-831f-4709cfc36225\">Give the filled out paper to the cashier/staff with your payment (cash only)</p></li><li data-block-id=\"846ed916-1c1a-4ea0-b1d5-8c908dad3646\"><p data-block-id=\"aebc9379-337d-48c1-820a-119afd96a756\">You will receive a receipt as proof of payment<br type=\"inline\"><img data-block-id=\"9600be3e-c91f-47ea-86a8-8a8593ebb598\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/Screenshot 2025-01-05 at 09.47.30.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"415\" height=\"auto\" dataalign=\"center\" datadisplay=\"inline\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:415px;\"></p></li></ol><p data-block-id=\"8e9aac87-b7ff-4f0e-b9c9-0178d8f76e42\"></p><p data-block-id=\"1fba7422-3f0f-475f-a3cd-ed72e33bce4f\"></p><p data-block-id=\"acd97665-43b1-498b-89ca-e66b24c0a68f\"></p><p data-block-id=\"490a489a-2a58-4dc9-96ea-9e5cc09fc8be\"></p>","SeoTitle":"CVM","Description":null},{"Code":"id","Title":"CVM","Slug":"payment-channel-page-push-9","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><p data-block-id=\"0ea65c3d-a38c-40be-a208-d546ab91ccec\"><img data-block-id=\"ddc1ed3e-11cd-4537-bffb-fa882bb16eac\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/CVM Pawnshop Home.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" title=\"image(23).png\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"40d09386-139f-4cf1-8307-2c85d716974e\">CVM Pawnshop, dengan jaringan cabangnya yang luas di seluruh Filipina, memungkinkan bisnis untuk menerima pembayaran over-the-counter dari pelanggan yang lebih memilih transaksi offline. Pelanggan dapat menyelesaikan pembelian online dengan memberikan nomor referensi transaksi di cabang CVM mana pun, menjadikannya pilihan yang nyaman bagi mereka yang tidak memiliki rekening bank atau yang lebih menyukai pembayaran tunai.</p><hr class=\"hr-divider1\"><h2 data-block-id=\"6146dcc6-4245-4158-a034-de0971f8c50b\">Fitur</h2><div data-type=\"table-content\"><table width=\"735\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:735px;width:735px;\"><colgroup><col style=\"width:463px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"db4dfef8-c563-4305-8c29-ef2b1aa63d40\">Kode Channel</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"e1e6e1e6-c602-409f-9e71-21f3f2b349df\"><code>CVM</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"05742465-0957-4c43-b4a1-a714d1ec5bd9\">Mata Uang</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"3f8936e1-14e1-4482-860e-cd08d70c3f38\">PHP</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"216547ce-9149-4c98-863b-af7a9b417559\">Jumlah Minimum</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"17190da0-2088-4c47-9f9a-c92fafebdd48\">50.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"917595fc-cd1e-4638-a3ac-8c763018c400\">Jumlah Maksimum</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"2760134e-54b9-4aaa-9d81-734957700cdf\">30,000.00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"dd693bd7-6fa5-470c-a762-3bd25581ee55\">Alur Persetujuan Pengguna</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"171da64c-8dad-441b-8a44-dc494f51d517\">PRESENT TO CUSTOMER</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"00b142a2-96d8-469f-a603-d7f653f2f6a6\">Kode Pembayaran yang Dapat Digunakan Kembali</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"c221f08c-7f47-4f90-8365-ce103ec676ed\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"a15e3b11-bb7c-4496-bbdd-cbc61b5faf78\">Kode Pembayaran Kustom</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"e53056c4-5e78-4685-9d39-02c9fa8420b2\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"d4fc461e-77d4-4e93-b6a4-95652e301b57\">Tampilkan Nama Merchant</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"b4f8a664-8a7f-4f0b-ab84-3300e08a00a1\">XENDIT</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"260ee695-3783-478d-b6ce-168812cf5235\">Tampilkan Nama Pengguna</p></td><td colspan=\"1\" rowspan=\"1\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"3f6d647e-1833-437d-9371-94b019551449\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding: