[{"Code":"en","Title":"[WIP] top-up table","Slug":"wip-top-up-table","ContentType":2,"Content":"<div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:113px;\"><col style=\"width:92px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm0rah-qt4k29-220\">Country</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74c9-ygfh54-221\">Currency</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74c9-bxm6ow-222\">Top-Up Method(s)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74c9-z4jvi0-223\">Processing Time</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ca-3ov9cz-224\">Notes</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74ca-4pdij6-225\"><strong>Indonesia</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74ca-xnwbmq-226\">IDR</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cb-bwub65-227\">Virtual Account (VA)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cb-6u0jbd-228\">Instant (same-bank)<br type=\"inline\">≈ 5 min (inter-bank)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cb-5ex2db-229\">Not supported for LLG/RTGS networks. Find your VA in the Dashboard.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cc-2qei1i-230\"><strong>Philippines</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cc-49qlrb-231\">PHP</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cc-pkkkrq-232\">UBP Bills Payment (Recommended)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cc-3gupfv-233\">≤ 5 min, 24/7</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cd-zpsujz-234\">Select \"XENDIT BALANCE TOP-UP\" as the biller.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cd-nv1n5g-235\"></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cd-30757h-236\"></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ce-zf5cry-237\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ce-akhq3t-238\">Varies by method (5 min - 3-5 biz days)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ce-bzslqu-239\">Processed weekdays 9:00 - 18:00 GMT+8.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cf-gdc3by-240\"><strong>Malaysia</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cf-q2b6h2-241\">MYR</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cf-mhg01w-242\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cf-m6fbts-243\">Processed weekdays 9:00 - 18:00 GMT+8</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cg-vwbzbq-244\">After-hours requests are processed by 12:00 the next business day.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cg-20fhym-245\"><strong>Thailand</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cg-1uwirr-246\">THB</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ch-q03kvb-247\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ch-sxq8th-248\">Processed weekdays 9:00 - 16:30 GMT+7</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ch-zducxa-249\">Confirmation email is sent on credit.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74ci-o2t7d5-250\"><strong>Vietnam</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74ci-f02dvi-251\">VND</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ci-csoox3-252\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ci-x8sfcq-253\">≤ 500M VND: Instant<br type=\"inline\">&gt; 500M VND: 30 min (Mon-Fri 8:30 - 16:00)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cj-h865vq-254\"></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cj-v9m906-255\"><strong>Foreign</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cj-set2cp-256\">USD to Local</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ck-99xnzm-257\">SWIFT Wire Transfer</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ck-prbtqz-258\">3-7 banking days</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ck-0hyqng-259\">Requires an email notification with proof of transfer. You must approve the FX rate.</p></td></tr></tbody></table></div><p data-block-id=\"mdsm0oam-7nei79-219\"></p><p data-block-id=\"mdsm76fa-6o93q3-260\"></p><h3 data-block-id=\"mdsm76so-xh5lh1-262\">Global Processing-Time Reference</h3><div data-type=\"table-content\"><table width=\"954\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:954px;width:954px;\"><colgroup><col style=\"width:318px;\"><col style=\"width:318px;\"><col style=\"width:318px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sp-7lc9kg-263\">Country</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sp-bvwqed-264\">Method</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sp-eiiaki-265\">Posting time</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sq-kihmzy-266\">Indonesia</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sq-tjjtun-267\">Same bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sq-urxymq-268\">Instant</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-vq5t41-269\">Indonesia</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-9j80lb-270\">Inter-bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-qx1cw5-271\">Up to T+1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-ramuzs-272\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-0tkkip-273\">UBP Bills Payment</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-i0aqhp-274\">5-10 min</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-4kn0sc-275\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-zq94fd-276\">Same bank / InstaPay</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76st-ou9jnp-277\">5-10 min</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76st-g821s4-278\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76st-ocput6-279\">PESONet ≤ 15:00</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-5gez3n-280\">By 19:00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-r31wx6-281\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-0j69em-282\">PESONet &gt; 15:00</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-i8c7fw-283\">By 12:00 next biz day</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-buaihn-284\">Malaysia</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-f296s1-285\">Same / inter-bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-l1yn9n-286\"><em>TBD</em></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-x04jbz-287\">Thailand</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sw-f6yfbd-288\">Same / inter-bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sw-48a6wy-289\"><em>TBD</em></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sw-ydafvx-290\">Vietnam</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-h688zu-291\">≤ 500 M VND</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-l2k1fb-292\">Instant</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-6qnr93-293\">Vietnam</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-3fidny-294\">&gt; 500 M VND</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sy-p7cy0l-295\">30 min (Mon-Fri 08:30-16:00)</p></td></tr></tbody></table></div><p data-block-id=\"mdsm76sy-4mfgl0-296\"></p><h2 data-block-id=\"mdsm76sy-dafpwk-297\">Global Accounts</h2><p data-block-id=\"mdsm76sy-s0lc17-298\">For Global Accounts, you can top up your balance in two ways:</p><div data-type=\"table-content\"><table width=\"904\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:904px;width:904px;\"><colgroup><col style=\"width:226px;\"><col style=\"width:226px;\"><col style=\"width:226px;\"><col style=\"width:226px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sy-tqdr9l-299\">Funding method</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sy-bv1thc-300\">Balance availability</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sz-80yzch-301\">Fees</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sz-n3dttc-302\">Where to initiate</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76sz-2l4sui-303\">Topping up from an external account</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sz-io5dje-304\">Varies between instant to 5 business days, depending on method</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t0-fnkol6-305\">Varies depending on method, charged by your bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t0-g7aij7-306\">Your bank</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t0-0bn48o-307\">Collections from your payments balance</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t1-zin5jf-308\">Instant</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t1-tz9c7v-309\">Free</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t1-fhwx6b-310\">Automatically accumulated in your balance with each payment received</p></td></tr></tbody></table></div><section class=\"internal-notes\" data-permitted-all-team-members=\"true\"><p data-block-id=\"mdsm76t1-awfvu2-311\"><strong>Internal - Top up channels supported</strong></p><p data-block-id=\"mdsm76t1-9gc05f-312\">We support the following payment methods for top ups on the regional dashboard:</p><div data-type=\"table-content\"><table width=\"633\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:633px;width:633px;\"><colgroup><col style=\"width:101px;\"><col style=\"width:153px;\"><col style=\"width:143px;\"><col style=\"width:236px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76t2-8drq5b-313\">Currency balance</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t2-i8td2w-314\">Method</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t2-kofzlv-315\">Channel</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t2-mmqb96-316\">Account holder</p></th></tr><tr><td colspan=\"1\" rowspan=\"3\" colwidth=\"101\"><p data-block-id=\"mdsm76t3-pgx5zt-317\">IDR</p></td><td colspan=\"1\" rowspan=\"3\" colwidth=\"153\"><p data-block-id=\"mdsm76t3-sm2zrf-318\">Virtual account*</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t3-mzpdzs-319\">BRI</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t4-8urp0s-320\">PT Sinar Digital Terdepan</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t4-b5f1q8-321\">Mandiri</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t4-14jkcw-322\">PT Sinar Digital Terdepan</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t4-wq4782-323\">BNI</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t5-vjjdg6-324\">PT Sinar Digital Terdepan</p></td></tr><tr><td colspan=\"1\" rowspan=\"4\" colwidth=\"101\"><p data-block-id=\"mdsm76t5-9r2un5-325\">PHP</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t5-up4raw-326\">Bill payment</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t5-m6qn55-327\">UBP App</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t6-qsjba9-328\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"3\" colwidth=\"153\"><p data-block-id=\"mdsm76t6-ul8639-329\">Bank transfer</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t6-jsd69p-330\">UnionBank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t6-ap2sp5-331\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t7-xs5bwz-332\">Metrobank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t7-kk0gc0-333\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t7-e9ytop-334\">BDO</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t8-966uzp-335\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76t8-b8n6d2-336\">THB</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t8-ed2fw7-337\">Bank Transfer</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t8-3o7yb7-338\">CIMB</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t9-ijvnno-339\">Xendit Wallet Co., Ltd.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76t9-xbqkze-340\">MYR</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t9-jsak5n-341\">Bank Transfer</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t9-gpmktz-342\">UOB</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76ta-gkolp8-343\">Xendit Sdn Bhd</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76ta-21eg3p-344\">VND</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76ta-ao88oc-345\">Virtual Account*</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76ta-rpscle-346\">Woori Bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76tb-j2axsp-347\">Appotapay</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76tb-davjep-348\">USD</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76tb-96eia0-349\">SWIFT</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76tc-aa409p-350\">DBS Bank Singapore</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76tc-bgd81e-351\">Xendit Payments Singapore Pte. Ltd.</p></td></tr></tbody></table></div><p data-block-id=\"mdsm76tc-xccjrw-352\">*The Virtual Account Name is the merchant’s Business Name</p></section><h2 data-block-id=\"mdsm76tc-abf3i7-353\">Topping up from an external account</h2><p data-block-id=\"mdsm76tc-elch2e-354\">You can transfer funds from your external bank account to top up your balance. Funds topped up into your balance must belong to your business. Funds received from a bank account that does not match the registered name of your business will lead to processing delays or refunds. </p><p data-block-id=\"mdsm76tc-ljs8j2-355\">You may find top up details for each balance by clicking on the “Top Up” button of each balance.</p><ol data-block-id=\"mdsm76tc-00qyoz-356\" start=\"1\" style=\"\"><li data-block-id=\"mdsm76tc-qvbyem-357\"><p data-block-id=\"mdsm76tc-d5zmf5-358\">Navigate to your balance by clicking <strong>Top Up</strong> on the Homepage, or going to <strong>Balance</strong> &gt; the balance you intend to fund. </p><p data-block-id=\"mdsm76tc-spjmzz-359\">Please note that the top up feature may not be available for certain balances. <a href=\"/docs/documentation-template-2\" target=\"_self\" translate=\"no\">See what’s available per each balance</a>. </p></li><li data-block-id=\"mdsm76tc-r8zr0a-360\"><p data-block-id=\"mdsm76tc-rnmba6-361\">Where necessary, choose your top up method.</p></li><li data-block-id=\"mdsm76tc-7ylfru-362\"><p data-block-id=\"mdsm76tc-7lms4u-363\">Follow the funding instructions clearly. Take note that we may require the following to aid in the identification of your payment:</p><ul data-block-id=\"mdsm76tc-akklci-364\" style=\"\" data-indent=\"1\"><li data-block-id=\"mdsm76tc-mhmjmp-365\"><p data-block-id=\"mdsm76tc-t64278-366\">Adding a reference to your bank transfer</p></li><li data-block-id=\"mdsm76tc-6rfp42-367\"><p data-block-id=\"mdsm76td-eh5ban-368\">Submitting proof of your bank transfer</p></li></ul><p data-block-id=\"mdsm76td-ycc9bk-369\"><span type=\"spanMark\">Failure to follow all of the funding instructions may result in delays in processing your top up. </span></p></li></ol><p data-block-id=\"mdsm76td-ko1v79-370\"><span style=\"color:rgb(0, 0, 0);background:transparent;font-family:Roboto;font-size:10pt;font-weight:300;background-color:transparent;font-style:normal;font-variant:normal;text-decoration:none;vertical-align:baseline;\" type=\"spanMark\"><span style=\"border:none;display:inline-block;overflow:hidden;width:421px;height:354px;\" type=\"spanNode\"><img data-block-id=\"mdsm76td-kb6xeb-371\" src=\"https://lh7-rt.googleusercontent.com/docsz/AD_4nXfa44vjz-1qOtQ_LHBap9taZAWCbCPEYzDdkbPLNbwbd1-rhll6kWd6tlPNRPC7Q0GExgcRjZBrkbfomo7oraOUXiV3KVBo5S2iA8owEIr_NhbfQw5sDrmYnTyC9s-s6O5LBM5Nvg?key=-sCRALoqPGXPKm_M4fvtqw\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"421\" height=\"354\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"margin-left:0px;margin-top:0px;\"></span></span></p><h3 data-block-id=\"mdsm76td-nlutsd-372\">Collections from your payments balance</h3><p data-block-id=\"mdsm76td-eegdax-373\">Collections from your payments balance will be automatically available for conversions and payouts. The currency of settlement from your payments balance depends on <a href=\"/docs/documentation-template-4\" target=\"_self\" translate=\"no\">how you’ve set up your balances for settlement</a>. </p><h2 data-block-id=\"mdsm76td-ktalxk-374\">View top up status</h2><h3 data-block-id=\"mdsm76td-e2jhjk-375\">Settlement time for top ups</h3><p data-block-id=\"mdsm76td-a72n3t-376\">Depending on your top up method, top ups may take up to several business days to process. </p><p data-block-id=\"mdsm76td-elz4w5-377\">Contact <a href=\"mailto:help@xendit.co\" translate=\"no\">help@xendit.co</a> if you are having trouble with your top up, or if:</p><ul data-block-id=\"mdsm76td-iup87i-378\" style=\"\"><li data-block-id=\"mdsm76td-ty4ukx-379\"><p data-block-id=\"mdsm76td-oytoex-380\">Your top up has not appeared in your balance after 24 hours for a top up via a local bank transfer.</p></li><li data-block-id=\"mdsm76te-vc36wl-381\"><p data-block-id=\"mdsm76te-j9lcjy-382\">Your top up has not appeared in your balance after 72 hours for a top up via SWIFT.</p></li></ul><p data-block-id=\"mdsm76te-gawgtj-383\">Only successful top ups are displayed - <strong>you will not see a pending top up on your dashboard. </strong></p><h3 data-block-id=\"mdsm76te-g3u79u-384\">Viewing top up status on the dashboard</h3><p data-block-id=\"mdsm76te-lcsvwb-385\">To view the status of your top up on your dashboard:</p><ol data-block-id=\"mdsm76te-i0pa3t-386\" start=\"1\" style=\"\"><li data-block-id=\"mdsm76te-yq42wh-387\"><p data-block-id=\"mdsm76te-b1n2ab-388\">You may check the <strong>Recent Transactions</strong> section on your Home Page if a top up has been recently performed. Alternatively, you may navigate to <strong>Transactions</strong> for a consolidated view of all transactions. </p></li><li data-block-id=\"mdsm76te-cpijc7-389\"><p data-block-id=\"mdsm76te-vd326a-390\">You may also navigate to <strong>Balances</strong> and click on each Balance to see information about each fund movement. </p></li></ol><h3 data-block-id=\"mdsm76te-pca0xw-391\">Viewing top up status via API</h3><p data-block-id=\"mdsm76te-6cqjem-392\">To retrieve the status of a top up, you may call the:</p><ol data-block-id=\"mdsm76te-o6eax9-393\" start=\"1\" style=\"\"><li data-block-id=\"mdsm76te-zu3l2h-394\"><p data-block-id=\"mdsm76te-3nrt2s-395\">Get /Balance API of your account to view the latest balance in your account</p></li><li data-block-id=\"mdsm76te-dl3u1l-396\"><p data-block-id=\"mdsm76te-rw5ich-397\">List /Transactions API of your account to view the line by line transaction of your account. Pass the balance currency as a query parameter. </p></li></ol><p data-block-id=\"mdsm76te-mv4fsa-398\">We currently do not support deposit callbacks for funds deposited into your Xendit balances.</p><p data-block-id=\"mdsm76te-j3ls2h-399\"></p>","SeoTitle":"[WIP] top-up table","Description":null},{"Code":"id","Title":"[WIP] top-up table","Slug":"wip-top-up-table","ContentType":2,"Content":null,"SeoTitle":"[WIP] top-up table","Description":null},{"Code":"th","Title":"[WIP] top-up table","Slug":"wip-top-up-table","ContentType":2,"Content":null,"SeoTitle":"[WIP] top-up table","Description":null},{"Code":"es-mx","Title":"[WIP] top-up table","Slug":"wip-top-up-table","ContentType":2,"Content":"<div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:113px;\"><col style=\"width:92px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm0rah-qt4k29-220\">Country</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74c9-ygfh54-221\">Currency</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74c9-bxm6ow-222\">Top-Up Method(s)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74c9-z4jvi0-223\">Processing Time</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ca-3ov9cz-224\">Notes</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74ca-4pdij6-225\"><strong>Indonesia</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74ca-xnwbmq-226\">IDR</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cb-bwub65-227\">Virtual Account (VA)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cb-6u0jbd-228\">Instant (same-bank)<br type=\"inline\">≈ 5 min (inter-bank)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cb-5ex2db-229\">Not supported for LLG/RTGS networks. Find your VA in the Dashboard.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cc-2qei1i-230\"><strong>Philippines</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cc-49qlrb-231\">PHP</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cc-pkkkrq-232\">UBP Bills Payment (Recommended)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cc-3gupfv-233\">≤ 5 min, 24/7</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cd-zpsujz-234\">Select \"XENDIT BALANCE TOP-UP\" as the biller.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cd-nv1n5g-235\"></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cd-30757h-236\"></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ce-zf5cry-237\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ce-akhq3t-238\">Varies by method (5 min - 3-5 biz days)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ce-bzslqu-239\">Processed weekdays 9:00 - 18:00 GMT+8.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cf-gdc3by-240\"><strong>Malaysia</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cf-q2b6h2-241\">MYR</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cf-mhg01w-242\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cf-m6fbts-243\">Processed weekdays 9:00 - 18:00 GMT+8</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cg-vwbzbq-244\">After-hours requests are processed by 12:00 the next business day.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cg-20fhym-245\"><strong>Thailand</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cg-1uwirr-246\">THB</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ch-q03kvb-247\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ch-sxq8th-248\">Processed weekdays 9:00 - 16:30 GMT+7</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ch-zducxa-249\">Confirmation email is sent on credit.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74ci-o2t7d5-250\"><strong>Vietnam</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74ci-f02dvi-251\">VND</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ci-csoox3-252\">Bank Transfer + Upload</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ci-x8sfcq-253\">≤ 500M VND: Instant<br type=\"inline\">&gt; 500M VND: 30 min (Mon-Fri 8:30 - 16:00)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74cj-h865vq-254\"></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"113\"><p data-block-id=\"mdsm74cj-v9m906-255\"><strong>Foreign</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"92\"><p data-block-id=\"mdsm74cj-set2cp-256\">USD to Local</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ck-99xnzm-257\">SWIFT Wire Transfer</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ck-prbtqz-258\">3-7 banking days</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mdsm74ck-0hyqng-259\">Requires an email notification with proof of transfer. You must approve the FX rate.</p></td></tr></tbody></table></div><p data-block-id=\"mdsm0oam-7nei79-219\"></p><p data-block-id=\"mdsm76fa-6o93q3-260\"></p><h3 data-block-id=\"mdsm76so-xh5lh1-262\">Global Processing-Time Reference</h3><div data-type=\"table-content\"><table width=\"954\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:954px;width:954px;\"><colgroup><col style=\"width:318px;\"><col style=\"width:318px;\"><col style=\"width:318px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sp-7lc9kg-263\">Country</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sp-bvwqed-264\">Method</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sp-eiiaki-265\">Posting time</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sq-kihmzy-266\">Indonesia</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sq-tjjtun-267\">Same bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sq-urxymq-268\">Instant</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-vq5t41-269\">Indonesia</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-9j80lb-270\">Inter-bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-qx1cw5-271\">Up to T+1</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sr-ramuzs-272\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-0tkkip-273\">UBP Bills Payment</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-i0aqhp-274\">5-10 min</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-4kn0sc-275\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76ss-zq94fd-276\">Same bank / InstaPay</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76st-ou9jnp-277\">5-10 min</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76st-g821s4-278\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76st-ocput6-279\">PESONet ≤ 15:00</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-5gez3n-280\">By 19:00</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-r31wx6-281\">Philippines</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-0j69em-282\">PESONet &gt; 15:00</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76su-i8c7fw-283\">By 12:00 next biz day</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-buaihn-284\">Malaysia</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-f296s1-285\">Same / inter-bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-l1yn9n-286\"><em>TBD</em></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sv-x04jbz-287\">Thailand</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sw-f6yfbd-288\">Same / inter-bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sw-48a6wy-289\"><em>TBD</em></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sw-ydafvx-290\">Vietnam</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-h688zu-291\">≤ 500 M VND</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-l2k1fb-292\">Instant</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-6qnr93-293\">Vietnam</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sx-3fidny-294\">&gt; 500 M VND</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"318\"><p data-block-id=\"mdsm76sy-p7cy0l-295\">30 min (Mon-Fri 08:30-16:00)</p></td></tr></tbody></table></div><p data-block-id=\"mdsm76sy-4mfgl0-296\"></p><h2 data-block-id=\"mdsm76sy-dafpwk-297\">Global Accounts</h2><p data-block-id=\"mdsm76sy-s0lc17-298\">For Global Accounts, you can top up your balance in two ways:</p><div data-type=\"table-content\"><table width=\"904\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:904px;width:904px;\"><colgroup><col style=\"width:226px;\"><col style=\"width:226px;\"><col style=\"width:226px;\"><col style=\"width:226px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sy-tqdr9l-299\">Funding method</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sy-bv1thc-300\">Balance availability</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sz-80yzch-301\">Fees</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sz-n3dttc-302\">Where to initiate</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76sz-2l4sui-303\">Topping up from an external account</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\"><p data-block-id=\"mdsm76sz-io5dje-304\">Varies between instant to 5 business days, depending on method</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t0-fnkol6-305\">Varies depending on method, charged by your bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t0-g7aij7-306\">Your bank</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t0-0bn48o-307\">Collections from your payments balance</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t1-zin5jf-308\">Instant</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t1-tz9c7v-309\">Free</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"226\" style=\"vertical-align:top;\"><p data-block-id=\"mdsm76t1-fhwx6b-310\">Automatically accumulated in your balance with each payment received</p></td></tr></tbody></table></div><section class=\"internal-notes\" data-permitted-all-team-members=\"true\"><p data-block-id=\"mdsm76t1-awfvu2-311\"><strong>Internal - Top up channels supported</strong></p><p data-block-id=\"mdsm76t1-9gc05f-312\">We support the following payment methods for top ups on the regional dashboard:</p><div data-type=\"table-content\"><table width=\"633\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:633px;width:633px;\"><colgroup><col style=\"width:101px;\"><col style=\"width:153px;\"><col style=\"width:143px;\"><col style=\"width:236px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76t2-8drq5b-313\">Currency balance</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t2-i8td2w-314\">Method</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t2-kofzlv-315\">Channel</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t2-mmqb96-316\">Account holder</p></th></tr><tr><td colspan=\"1\" rowspan=\"3\" colwidth=\"101\"><p data-block-id=\"mdsm76t3-pgx5zt-317\">IDR</p></td><td colspan=\"1\" rowspan=\"3\" colwidth=\"153\"><p data-block-id=\"mdsm76t3-sm2zrf-318\">Virtual account*</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t3-mzpdzs-319\">BRI</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t4-8urp0s-320\">PT Sinar Digital Terdepan</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t4-b5f1q8-321\">Mandiri</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t4-14jkcw-322\">PT Sinar Digital Terdepan</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t4-wq4782-323\">BNI</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t5-vjjdg6-324\">PT Sinar Digital Terdepan</p></td></tr><tr><td colspan=\"1\" rowspan=\"4\" colwidth=\"101\"><p data-block-id=\"mdsm76t5-9r2un5-325\">PHP</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t5-up4raw-326\">Bill payment</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t5-m6qn55-327\">UBP App</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t6-qsjba9-328\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"3\" colwidth=\"153\"><p data-block-id=\"mdsm76t6-ul8639-329\">Bank transfer</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t6-jsd69p-330\">UnionBank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t6-ap2sp5-331\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t7-xs5bwz-332\">Metrobank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t7-kk0gc0-333\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t7-e9ytop-334\">BDO</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t8-966uzp-335\">Xendit Philippines Inc</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76t8-b8n6d2-336\">THB</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t8-ed2fw7-337\">Bank Transfer</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t8-3o7yb7-338\">CIMB</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76t9-ijvnno-339\">Xendit Wallet Co., Ltd.</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76t9-xbqkze-340\">MYR</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76t9-jsak5n-341\">Bank Transfer</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76t9-gpmktz-342\">UOB</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76ta-gkolp8-343\">Xendit Sdn Bhd</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76ta-21eg3p-344\">VND</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76ta-ao88oc-345\">Virtual Account*</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76ta-rpscle-346\">Woori Bank</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76tb-j2axsp-347\">Appotapay</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"101\"><p data-block-id=\"mdsm76tb-davjep-348\">USD</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"153\"><p data-block-id=\"mdsm76tb-96eia0-349\">SWIFT</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"143\"><p data-block-id=\"mdsm76tc-aa409p-350\">DBS Bank Singapore</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"236\"><p data-block-id=\"mdsm76tc-bgd81e-351\">Xendit Payments Singapore Pte. Ltd.</p></td></tr></tbody></table></div><p data-block-id=\"mdsm76tc-xccjrw-352\">*The Virtual Account Name is the merchant’s Business Name</p></section><h2 data-block-id=\"mdsm76tc-abf3i7-353\">Topping up from an external account</h2><p data-block-id=\"mdsm76tc-elch2e-354\">You can transfer funds from your external bank account to top up your balance. Funds topped up into your balance must belong to your business. Funds received from a bank account that does not match the registered name of your business will lead to processing delays or refunds. </p><p data-block-id=\"mdsm76tc-ljs8j2-355\">You may find top up details for each balance by clicking on the “Top Up” button of each balance.</p><ol data-block-id=\"mdsm76tc-00qyoz-356\" start=\"1\" style=\"\"><li data-block-id=\"mdsm76tc-qvbyem-357\"><p data-block-id=\"mdsm76tc-d5zmf5-358\">Navigate to your balance by clicking <strong>Top Up</strong> on the Homepage, or going to <strong>Balance</strong> &gt; the balance you intend to fund. </p><p data-block-id=\"mdsm76tc-spjmzz-359\">Please note that the top up feature may not be available for certain balances. <a href=\"/docs/documentation-template-2\" target=\"_self\" translate=\"no\">See what’s available per each balance</a>. </p></li><li data-block-id=\"mdsm76tc-r8zr0a-360\"><p data-block-id=\"mdsm76tc-rnmba6-361\">Where necessary, choose your top up method.</p></li><li data-block-id=\"mdsm76tc-7ylfru-362\"><p data-block-id=\"mdsm76tc-7lms4u-363\">Follow the funding instructions clearly. Take note that we may require the following to aid in the identification of your payment:</p><ul data-block-id=\"mdsm76tc-akklci-364\" style=\"\" data-indent=\"1\"><li data-block-id=\"mdsm76tc-mhmjmp-365\"><p data-block-id=\"mdsm76tc-t64278-366\">Adding a reference to your bank transfer</p></li><li data-block-id=\"mdsm76tc-6rfp42-367\"><p data-block-id=\"mdsm76td-eh5ban-368\">Submitting proof of your bank transfer</p></li></ul><p data-block-id=\"mdsm76td-ycc9bk-369\"><span type=\"spanMark\">Failure to follow all of the funding instructions may result in delays in processing your top up. </span></p></li></ol><p data-block-id=\"mdsm76td-ko1v79-370\"><span style=\"color:rgb(0, 0, 0);background:transparent;font-family:Roboto;font-size:10pt;font-weight:300;background-color:transparent;font-style:normal;font-variant:normal;text-decoration:none;vertical-align:baseline;\" type=\"spanMark\"><span style=\"border:none;display:inline-block;overflow:hidden;width:421px;height:354px;\" type=\"spanNode\"><img data-block-id=\"mdsm76td-kb6xeb-371\" src=\"https://lh7-rt.googleusercontent.com/docsz/AD_4nXfa44vjz-1qOtQ_LHBap9taZAWCbCPEYzDdkbPLNbwbd1-rhll6kWd6tlPNRPC7Q0GExgcRjZBrkbfomo7oraOUXiV3KVBo5S2iA8owEIr_NhbfQw5sDrmYnTyC9s-s6O5LBM5Nvg?key=-sCRALoqPGXPKm_M4fvtqw\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"421\" height=\"354\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"margin-left:0px;margin-top:0px;\"></span></span></p><h3 data-block-id=\"mdsm76td-nlutsd-372\">Collections from your payments balance</h3><p data-block-id=\"mdsm76td-eegdax-373\">Collections from your payments balance will be automatically available for conversions and payouts. The currency of settlement from your payments balance depends on <a href=\"/docs/documentation-template-4\" target=\"_self\" translate=\"no\">how you’ve set up your balances for settlement</a>. </p><h2 data-block-id=\"mdsm76td-ktalxk-374\">View top up status</h2><h3 data-block-id=\"mdsm76td-e2jhjk-375\">Settlement time for top ups</h3><p data-block-id=\"mdsm76td-a72n3t-376\">Depending on your top up method, top ups may take up to several business days to process. </p><p data-block-id=\"mdsm76td-elz4w5-377\">Contact <a href=\"mailto:help@xendit.co\" translate=\"no\">help@xendit.co</a> if you are having trouble with your top up, or if:</p><ul data-block-id=\"mdsm76td-iup87i-378\" style=\"\"><li data-block-id=\"mdsm76td-ty4ukx-379\"><p data-block-id=\"mdsm76td-oytoex-380\">Your top up has not appeared in your balance after 24 hours for a top up via a local bank transfer.</p></li><li data-block-id=\"mdsm76te-vc36wl-381\"><p data-block-id=\"mdsm76te-j9lcjy-382\">Your top up has not appeared in your balance after 72 hours for a top up via SWIFT.</p></li></ul><p data-block-id=\"mdsm76te-gawgtj-383\">Only successful top ups are displayed - <strong>you will not see a pending top up on your dashboard. </strong></p><h3 data-block-id=\"mdsm76te-g3u79u-384\">Viewing top up status on the dashboard</h3><p data-block-id=\"mdsm76te-lcsvwb-385\">To view the status of your top up on your dashboard:</p><ol data-block-id=\"mdsm76te-i0pa3t-386\" start=\"1\" style=\"\"><li data-block-id=\"mdsm76te-yq42wh-387\"><p data-block-id=\"mdsm76te-b1n2ab-388\">You may check the <strong>Recent Transactions</strong> section on your Home Page if a top up has been recently performed. Alternatively, you may navigate to <strong>Transactions</strong> for a consolidated view of all transactions. </p></li><li data-block-id=\"mdsm76te-cpijc7-389\"><p data-block-id=\"mdsm76te-vd326a-390\">You may also navigate to <strong>Balances</strong> and click on each Balance to see information about each fund movement. </p></li></ol><h3 data-block-id=\"mdsm76te-pca0xw-391\">Viewing top up status via API</h3><p data-block-id=\"mdsm76te-6cqjem-392\">To retrieve the status of a top up, you may call the:</p><ol data-block-id=\"mdsm76te-o6eax9-393\" start=\"1\" style=\"\"><li data-block-id=\"mdsm76te-zu3l2h-394\"><p data-block-id=\"mdsm76te-3nrt2s-395\">Get /Balance API of your account to view the latest balance in your account</p></li><li data-block-id=\"mdsm76te-dl3u1l-396\"><p data-block-id=\"mdsm76te-rw5ich-397\">List /Transactions API of your account to view the line by line transaction of your account. Pass the balance currency as a query parameter. </p></li></ol><p data-block-id=\"mdsm76te-mv4fsa-398\">We currently do not support deposit callbacks for funds deposited into your Xendit balances.</p><p data-block-id=\"mdsm76te-j3ls2h-399\"></p>","SeoTitle":"[WIP] top-up table","Description":null}]