[{"Code":"en","Title":"Direct Debit - Recurring","Slug":"direct-debit-merchant-prod-credentials-sop-ph","ContentType":2,"Content":"<p data-block-id=\"ml41hy5h-wsfind-001\"><a id=\"_s6tqfgcj75rk\" display=\"false\"></a></p><h2 data-block-id=\"ml41hy5j-xn4yai-002\"><a id=\"_vxli4z8mw7iu\" display=\"false\"></a>Versioning</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5k-mwrjrn-004\"><strong>Ver.</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5l-ini1gx-005\"><strong>Date</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5l-021ht3-006\"><strong>Description</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5l-iw1r96-007\">1.0</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5l-fqf5y2-008\">07/28/2022</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5l-8rkof1-009\">SOP Creation</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5m-9berzl-010\">2.0</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5m-l1nt2y-011\">12/22/2025</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5m-kxhiuh-012\">Updates</p></td></tr></tbody></table></div><h2 data-block-id=\"ml41hy5m-x9yk9h-013\"><a id=\"_lwcgkt1531pw\" display=\"false\"></a>Glossary and Documents</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5n-wriihd-015\"><strong>Terms</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5n-nftioj-016\"><strong>Description</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5n-4zwlc8-017\"><a href=\"https://docs.google.com/document/d/1iRSEFEEMloh2XAC1kWGTHre47RJFUWrCdbO1YjfJMeY/edit?tab=t.0#heading=h.rfq099m7upuw\"><u>[Running List] DD BPI Recurring - Merchant Own Creds</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5n-mxb506-018\">UAT and PROD credentials for sending to partner for BPI</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5o-9vokyp-019\"><a href=\"https://docs.google.com/document/d/1eMPXkY-Q_rSVYKOwDy9lNVd-c88two74cERvu2LGZDY/edit\"><u>UBP x Xendit Merchant Name Change MO</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5o-ubziyb-020\">UBP Email Template and Letter of Intent to be sent to merchant</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5o-ywc4pr-021\"><a href=\"https://docs.google.com/document/d/11tjhYD6paNci1NcTupWB94ZnPKOcGPzh/edit\"><u>Client PROD Environment Request Form v1.1.docx</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5o-0duzvt-022\">UBP Client Prod Credetial Request Form</p></td></tr></tbody></table></div><h2 data-block-id=\"ml41hy5o-ghidfh-023\"><a id=\"_87m7mijh6lkd\" display=\"false\"></a>Xendit Stakeholders</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5o-qs16hk-024\"><strong>Department</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5o-037ffz-025\"><strong>PIC</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5p-43dpnr-026\"><strong>PIC Role</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5p-znk4zo-027\">MO</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5p-1653rp-028\"><a><u>Yanticha Isyandini</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5p-34hx09-029\">Responsible for activating the channel</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5p-ql7m6z-030\">Partnerships</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5p-i043ht-031\"><a><u>Mica Rose NopuenteIan Carlo AriasVince Arellano</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5q-4h51vc-032\">Communicate any concern and issues and changes to partners</p></td></tr></tbody></table></div><h2 data-block-id=\"ml41hy5q-e8ewut-033\">Eligibity</h2><h3 data-block-id=\"ml41hy5q-2hkgd0-035\"><a id=\"_pm046hila1sg\" display=\"false\"></a>Entity Type</h3><h1 data-block-id=\"ml41hy5q-xvygjl-036\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5q-5rwuuv-037\"><strong>Entity Type</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5q-k9s8ey-038\"><strong>Can Apply</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5q-cxe1gh-039\">PH Individual (Social Sellers)</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5r-1kb2gg-040\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5r-k5g9u7-041\">PH Sole Proprietor</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5r-oz5j3u-042\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5r-cmpvqb-043\">PH Partnership</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5r-8r3ya7-044\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5s-77t88w-045\">PH Corporation</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5s-9qdcly-046\">✅</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5s-e66h2z-047\">Foreign Entity</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5s-uochpa-048\">✅</p></td></tr></tbody></table></div><h3 data-block-id=\"ml41hy5s-ptnx2g-049\"><a id=\"_matmus3lgjyu\" display=\"false\"></a>Available Banks</h3><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5s-0wna7a-050\"><strong>Bank</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5s-olkjse-051\"><strong>SLA</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-9cajhl-052\"><strong>Status</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-6dsk6f-053\"><a href=\"#_5in0ljky700u\"><u>BPI</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-8tevu4-054\">30-40 Business Days</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-mbsl7p-055\">Live</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-fq2yue-056\"><a href=\"#_f5s6aan2vrtr\"><u>Unionbank</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-rnnkk7-057\">14 Business Days</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5t-5sdy4s-058\">Live</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5u-w45uw8-059\"><a href=\"#_xe92rwonnx62\"><u>RCBC</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5u-fimnq4-060\">6-8 weeks</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5u-y76erm-061\">On Hold</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5u-t28to6-062\"><a href=\"#_i7c0lb1brxnz\"><u>Chinabank</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5u-anv5m9-063\">90 business days</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5v-eijxcz-064\">On Hold</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5v-50lfsd-065\"><a href=\"#_fr1b1a2dcdqf\"><u>BDO ePayments</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5v-i6gd34-066\">4-5 weeks</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5v-xmgngb-067\">On Hold</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5v-v7p88d-068\">Metrobank**</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5v-zlix10-069\">TBD</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5w-a2up5c-070\">On Hold</p></td></tr></tbody></table></div><h2 data-block-id=\"ml41hy5w-dlqgpt-071\"><a id=\"_8wanhk5ri6bj\" display=\"false\"></a>General Onboarding Flow</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5w-ajoivk-073\"><strong>Step</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5w-cm9bev-074\"><strong>Process</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5w-p12hzx-075\"><strong>PIC</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5w-6p2rn8-076\">1</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5x-l9bypp-077\">Sales/CS to request activation on the #autodebit-activation-requests channel.</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5x-0vqr9v-078\">Sales/CS</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5x-ybnx3w-079\">2</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5x-0jm9w3-080\">MO to process the request based on the channel and activation steps, and activate the merchant once approved by the partner.</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5x-oueen6-081\">MO</p></td></tr></tbody></table></div><h2 data-block-id=\"ml41hy5x-o7ykrn-082\">Activation Process</h2><h3 data-block-id=\"ml41hy5x-7wms8v-084\"><a id=\"_5in0ljky700u\" display=\"false\"></a>BPI</h3><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:135px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy5x-bflxuz-085\"><strong>Step</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5y-jd1fgu-086\"><strong>Process</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5y-79q3yj-087\"><strong>Description</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5y-b0v2x5-088\"><strong>PIC</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy5y-5rrqan-089\">1</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5y-ase0kw-090\">Fill out merchant name in <a href=\"https://docs.google.com/document/d/1Ncnhkkh39wXXXNybBQ6IxvhH6caxTpRebiTgeZQh5fM/edit#heading=h.iwoyiugj1wg\"><u>BPI credentials sheet</u></a></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy5y-51s0pj-091\">Create a new entry for your merchant in <a href=\"https://docs.google.com/document/d/1iRSEFEEMloh2XAC1kWGTHre47RJFUWrCdbO1YjfJMeY/edit?tab=t.0#heading=h.rfq099m7upuw\"><u>[Running List] DD BPI Recurring - Merchant Own Creds</u></a> with the official merchant name and redirect url</p><p data-block-id=\"ml41hy5z-7h7qlo-092\">Format:</p><ul data-block-id=\"ml41hy5z-8h2i3n-093\"><li data-block-id=\"ml41hy5z-awqvjk-094\"><p data-block-id=\"mmsymsqs-e15z2h-199\">Biller Name = Business Name</p></li><li data-block-id=\"ml41hy5z-o7lju6-095\"><p data-block-id=\"mmsymsqs-uxdhzs-200\">Redirect URL UAT = https://link-web-staging.xendit.co/oauth/bpi/<strong>businessname</strong>/redirect</p></li><li data-block-id=\"ml41hy5z-d95sha-096\"><p data-block-id=\"mmsymsqt-nsvqhe-201\">Redirect URL Prod = https://link-web.xendit.co/oauth/bpi/<strong>businessname</strong>/redirect</p></li></ul><p data-block-id=\"ml41hy5z-lepx5n-097\">Once done, tag @direct-debit-expert on the Slack request, mention that the URLs are completed, and request the generation of certificates.</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy60-0dur09-098\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy60-p38yg4-099\">2</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy60-ajpo9k-100\">Certificate Generation</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy60-wm0r5o-101\">@direct-debit-expert will share certificate via keeper once done</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy60-5nwjcs-102\">@direct-debit-expert or <a><u>Juancho Ariola</u></a></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy60-1klnw1-103\">3</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy61-7wixtd-104\">Credential Request</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy61-o0aj9h-105\">MO to requests for credentials to BPI attached the certificates generated by @direct-debit-expert via email<br type=\"inline\"><br type=\"inline\">Send to: \"Allan Gerard V. Francisco\" &lt;agvfrancisco@bpi.com.ph&gt;, Partner_Management@bpi.com.ph , Merchant Ops PH &lt;merchantops@xendit.ph&gt;, </p><p data-block-id=\"ml41hy61-4j1k5k-108\">Mica &lt;mica.nopuente@xendit.co&gt;, </p><p data-block-id=\"ml41hy61-mchch2-109\">Juancho Ariola &lt;juancho@xendit.co&gt;, </p><p data-block-id=\"ml41hy61-lou0sp-110\">cc: \"Ryan Y. Balce\" &lt;rybalce@bpi.com.ph&gt;, </p><p data-block-id=\"ml41hy61-cv1y4t-111\">Partnerships PH &lt;partnerships@xendit.ph&gt;, </p><p data-block-id=\"ml41hy61-24cxwi-112\">Nigel Yeo &lt;nigel@xendit.co&gt;, </p><p data-block-id=\"ml41hy61-3cxhft-113\">Partner Management &lt;Partner_Management@bpi.com.ph&gt; </p><p data-block-id=\"ml41hy61-tq95rw-114\"><br type=\"inline\">Subject: BPI Autodebit Activation Request -<strong>  Merchant Name</strong></p><p data-block-id=\"ml41hy61-fai58c-116\"><br type=\"inline\">Body: </p><p data-block-id=\"ml41hy61-wv355u-118\"><em>Hi BPI Team,</em></p><p data-block-id=\"ml41hy61-blwfvu-119\"><em>Good day!</em></p><p data-block-id=\"ml41hy61-f5i8zj-120\"><em>Kindly need your help to activate BPI Direct Debit Recurring for our merchant </em><strong><em>Merchant Name</em></strong></p><p data-block-id=\"ml41hy62-4bb8f4-121\"><em>Details as follows:</em></p><p data-block-id=\"ml41hy62-4jn8py-122\"><em>Business Name: </em></p><p data-block-id=\"ml41hy62-58q31a-123\"><em>Website url:</em></p><p data-block-id=\"ml41hy62-eiadvg-124\"><em>Use case: </em></p><p data-block-id=\"ml41hy62-6zea26-125\"><em>Payment Frequency: </em></p><p data-block-id=\"ml41hy62-27plmo-126\"><em>Here is the technical requirement:</em></p><p data-block-id=\"ml41hy62-o9et1x-127\"><em>UAT</em></p><p data-block-id=\"ml41hy62-c3mq3y-128\"><em>IP address:</em></p><p data-block-id=\"ml41hy62-3q2cnj-129\"><em>54.169.108.158</em></p><p data-block-id=\"ml41hy62-goffpa-130\"><em>13.213.218.164</em></p><p data-block-id=\"ml41hy62-0lla1i-131\"><em>47.129.28.140</em></p><p data-block-id=\"ml41hy62-q4er7i-132\"><em>Redirect URL:</em><strong><em> paste uat url </em></strong></p><p data-block-id=\"ml41hy62-r3wi0p-133\"><em>PROD</em></p><p data-block-id=\"ml41hy62-mxqw3g-134\"><em>IP address:</em></p><p data-block-id=\"ml41hy62-u1ybv0-135\"><em>13.250.160.212</em></p><p data-block-id=\"ml41hy62-8hxlmd-136\"><em>13.213.99.178</em></p><p data-block-id=\"ml41hy62-i9ngvo-137\"><em>52.221.83.12</em></p><p data-block-id=\"ml41hy62-3hgr14-138\"><em>Redirect URL: </em><strong><em>paste prod url </em></strong></p><p data-block-id=\"ml41hy62-hr1rjg-139\"><em>Cert is attached for your reference. </em></p><p data-block-id=\"ml41hy62-1m9npd-140\"><em>Please kindly help to proceed with this request. Thank you!</em></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy63-hoevh5-141\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy63-yh8lnk-142\">4</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy63-zqkpbt-143\">Credentials</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy63-bvtchc-144\">BPI will send credentials for UAT and will request UAT results. Send/Inform UAT credentials to @direct-debit-expert or use the slack request</p><p data-block-id=\"ml41hy63-g2k8h0-145\">The UAT credential will sent in separate email</p><p data-block-id=\"ml41hy63-5re4k6-146\">with subject email : [External] [codes] -API UAT - Client ID - Secret - PUBKEY - [Merchant Name]</p><p data-block-id=\"ml41hy63-obwmez-147\"><img data-block-id=\"ml41hy63-1ojt79-148\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/direct-debit-merchant-prod-credentials-sop-ph-image-c05una73.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"ml41hy63-k9s8ou-149\">MO will download the attachment and share through Keeper to Juancho Ariola</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy64-lhp2cc-150\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy64-4d53xv-151\">5</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy64-aw71vk-152\">UAT Results</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy64-kolsae-153\">@direct-debit-expert will send UAT results to MO on the channel once done</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy64-7t7l1f-154\">@direct-debit-expert </p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy64-mbdhwp-155\">6</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy64-iixo78-156\">Send UAT Results</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy65-qvfkjg-157\">MO to send UAT results to BPI. Once approved by BPI, BPI will provide PROD credentials via email.</p><p data-block-id=\"ml41hy65-ztmm19-158\">In parallel, MO will request payment flow to merchant before GL</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy65-sn5ekj-159\">BPI</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"135\"><p data-block-id=\"ml41hy65-09qhw3-160\">7</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy65-dd16b2-161\">Activation</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy65-76s2aq-162\">MO to activate channels in Retool and inform BPI of the target implementation date (+7 business days from the day of activation).</p><p data-block-id=\"ml41hy65-fcgd1z-163\">Once approved by BPI, inform CS/Sales on the Slack request of the target implementation date.</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy65-bzj5pc-164\">MO</p></td></tr></tbody></table></div><h3 data-block-id=\"ml41hy65-oj10ej-165\"><a id=\"_w1iehe1jhew9\" display=\"false\"></a>UBP</h3><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:144px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:50px;\"></colgroup><tbody><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"144\"><p data-block-id=\"ml41hy66-3k2d5a-166\"><strong>Step</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy66-sgh0rx-167\"><strong>Process</strong></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy66-blqu3u-168\"><strong>Description</strong></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"ml41hy66-a3t6jj-169\"><strong>PIC</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"144\"><p data-block-id=\"ml41hy66-sltkw1-170\">1</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy66-ohmwpm-171\">Fill out letter of intent for UBP credentials</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy67-tgh4et-172\">Send an email to your merchant using the template provided in page 1 of <a href=\"https://docs.google.com/document/d/1eMPXkY-Q_rSVYKOwDy9lNVd-c88two74cERvu2LGZDY/edit\"><u>UBP letter of intent</u></a>. Fill out all relevant details and attach page 2 of <a href=\"https://docs.google.com/document/d/1eMPXkY-Q_rSVYKOwDy9lNVd-c88two74cERvu2LGZDY/edit\"><u>UBP letter of intent</u></a> for your merchant to sign. </p><p data-block-id=\"ml41hy67-j5alat-173\">Once your merchant signs page 2 of the above document, upload the file to the <a href=\"https://drive.google.com/drive/u/2/folders/1riRsPdFIlc-UDX1FF92HDei1dGKw9TLB\"><u>UBP Partner ID Request folder</u></a> using the following convention: UBPLetterOfIntent_MerchantName_YYYYMMDD</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"ml41hy67-r0oszj-174\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"144\"><p data-block-id=\"ml41hy67-wg9vv3-175\">2</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy67-3bfder-176\">Fill out UBP Client Prod Request form</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy67-4sobm9-177\">Create a copy of the <a href=\"https://docs.google.com/document/d/11tjhYD6paNci1NcTupWB94ZnPKOcGPzh/edit\"><u>UBP Client Prod request form</u></a> and fill out all details for your merchant.</p><p data-block-id=\"ml41hy67-nr8d8n-178\">Name the document in the <a href=\"https://drive.google.com/drive/u/2/folders/1riRsPdFIlc-UDX1FF92HDei1dGKw9TLB\"><u>UBP Partner ID Request folder</u></a> using the following convention: <br type=\"inline\">UBPClientProdRequest_MerchantName_YYYYMMDD</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"ml41hy68-tnuxu8-180\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"144\"><p data-block-id=\"ml41hy68-r9uzi3-181\">3</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy68-9gzysd-182\">Request Reyes signature on the documents</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy68-92d3eo-183\">Raise a request to #mo-ph-request and attach the letter of intent and partner ID request for signature of Reyes. (c/o Raffy and Lala)</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"ml41hy68-ha0z4x-184\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"144\"><p data-block-id=\"mmsymsqz-x2lbsn-202\"></p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy68-t8oeme-185\">MO to send out email to UBP for your merchant</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy69-3et3rf-186\">MO to send email to UBP for the credentials request.<br type=\"inline\"><br type=\"inline\">Subject: [UBP] Request for Direct Debit e-ADA (Recurring) Partner ID for <strong>Merchant Name</strong><br type=\"inline\"><br type=\"inline\">Email guidelines: <a href=\"https://docs.google.com/document/d/1J1nfj8IEnQlwR0n5WJo2nTNzt5FzKS4LLlVQakcM9kQ/edit#heading=h.nlcqidro65j2\"><u>Email Format for Prod Credentials Request</u></a></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"ml41hy69-7mhpwt-191\">MO</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"144\"><p data-block-id=\"ml41hy69-weac7f-192\">4</p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy69-6502qh-193\">UBP to send credentials </p></td><td colspan=\"1\" rowspan=\"1\"><p data-block-id=\"ml41hy6a-xtdtti-194\">Once UBP approves and shares the credentials, activate the channel in Retool using the provided credentials.</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"50\"><p data-block-id=\"mmsymsr0-yvblz1-203\"></p></td></tr></tbody></table></div><h1 data-block-id=\"ml41hy6a-9ftk86-195\"><a id=\"_c8zoxgltnh60\" display=\"false\"></a></h1><p data-block-id=\"mmsymsr0-7th0kt-204\"></p>","SeoTitle":"Direct Debit - Recurring","Description":null},{"Code":"id","Title":"Direct Debit - Recurring","Slug":"direct-debit-recurring","ContentType":2,"Content":null,"SeoTitle":"Direct Debit - Recurring","Description":null},{"Code":"th","Title":"Direct Debit - Recurring","Slug":"direct-debit-recurring","ContentType":2,"Content":null,"SeoTitle":"Direct Debit - Recurring","Description":null},{"Code":"es-mx","Title":"Direct Debit - Recurring","Slug":"direct-debit-recurring","ContentType":2,"Content":null,"SeoTitle":"Direct Debit - Recurring","Description":null}]