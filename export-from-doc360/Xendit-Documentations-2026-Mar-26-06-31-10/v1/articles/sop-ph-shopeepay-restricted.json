[{"Code":"en","Title":"Shopeepay","Slug":"sop-ph-shopeepay-restricted","ContentType":2,"Content":"<p data-block-id=\"mlqwuu5o-m0kj4x-002\"><a id=\"_vpxm85nexyyh\" display=\"false\"></a></p><h2 data-block-id=\"mlqwuu5q-53dnl5-006\"><a id=\"_vxli4z8mw7iu\" display=\"false\"></a>Versioning</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5r-zb1f5t-007\"><strong>Ver.</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5s-trr5et-008\"><strong>Date</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5s-d8rgll-009\"><strong>Description</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5s-50sf7j-010\">1.0</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5t-hdvex3-011\">26 Jun 2022</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5t-mbwe8f-012\">Template and SOP update</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5t-76dvau-013\">2.0</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5t-zxyjqe-014\">18 Nov 2025</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5u-hpybz6-015\">Update</p></th></tr></tbody></table></div><h1 data-block-id=\"mlqwuu5u-blxoxy-016\"><a id=\"_df9ij9biwbs1\" display=\"false\"></a></h1><h2 data-block-id=\"mlqwuu5u-ri205l-017\"><a id=\"_ejxly55we75x\" display=\"false\"></a>Xendit Stakeholders</h2><div data-type=\"table-content\"><table width=\"1377\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:1377px;width:1377px;\"><colgroup><col style=\"width:459px;\"><col style=\"width:459px;\"><col style=\"width:459px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5u-h3a4j3-018\"><strong>Department</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5u-rcpak4-019\"><strong>PIC</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5u-83k9lj-020\"><strong>PIC Role</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5v-holij0-021\">Partnership</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5v-au357i-022\"><a><u>Mica Rose Nopuente</u></a></p><p data-block-id=\"mlqwuu5v-au357i-022\"><a><u>Ian Carlo Arias</u></a></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5v-n0frw4-023\">Partnership PIC for Shopeepay</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5v-9yy2uf-024\">Digipay</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5w-raj769-025\"><a><u>Sekar Hapsari</u></a></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5w-de6vcy-026\">Product Manager (Digipay)</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5w-0l0t73-027\">NUX CA</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5w-l2o4zc-028\"><a><u>Clara Cynthia</u></a></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwuu5w-11gmfs-029\">Product Manager (Merchant Dashboard)</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwwnff-3jqj62-216\">Merchant Ops</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwwlrg-kd4s03-214\"><u>Imaculata Visar</u></p><p data-block-id=\"mlqwy09q-l9dlre-217\"><u>Raffy John Panes</u></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"459\"><p data-block-id=\"mlqwwlrh-f2vi8i-215\">Channel Activation</p></th></tr></tbody></table></div><h1 data-block-id=\"mlqwuu5w-0synf4-030\"><a id=\"_li62zw85vogf\" display=\"false\"></a></h1><h2 data-block-id=\"mlqwuu5w-up5ww2-031\"><a id=\"_d758rtuj0pwc\" display=\"false\"></a>Partner PIC</h2><p data-block-id=\"mlqwuu5w-oncywh-032\"><em>Email : please send email to ask anything related to ShopeePay</em></p><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5x-hdgirs-033\"><strong>Name</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5x-0jltm4-034\"><strong>Email</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5x-dmjand-035\">Adriane Verdeflor</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5x-t3iiw6-036\">adriane.verdeflor@shopee.com</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5x-mqou1d-037\">Miguel Andre Ermita</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5y-k2fq5i-038\"><a><u>miguel.ermita@shopee.com</u></a></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5y-4lskc8-039\">SPP Onboarding</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5y-7nogwe-040\"><a><u>spponboarding@shopee.com</u></a></p></th></tr></tbody></table></div><h1 data-block-id=\"mlqwuu5y-6mk6au-041\"><a id=\"_wp9lmquxuf6p\" display=\"false\"></a></h1><h2 data-block-id=\"mlqwuu5y-5stq8c-042\"><a id=\"_kn21a7755xth\" display=\"false\"></a>Related Documents</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5y-j7mr0j-043\"><strong>Document name</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5z-wgcmbe-044\"><strong>Description</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5z-lvwewr-045\"><strong>Link to document</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5z-ea5hdx-046\">Xendit Store Enrollment Form ISV API</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5z-b9kkq6-047\">An enrollment form for requesting to activate their ShopeePay as merchant payment</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu5z-81qmrc-048\"><a href=\"https://docs.google.com/spreadsheets/d/1eSEsFbGLUBJB4V3dwciDms9weq2J3tx7TIe4ySWECm8/edit?gid=572940445#gid=572940445\"><u>[Xendit] Shared ISV Store Enrollment Form</u></a></p></th></tr></tbody></table></div><h1 data-block-id=\"mlqwuu5z-vxmyg7-049\"><a id=\"_j6s90xew1zp5\" display=\"false\"></a></h1><h2 data-block-id=\"mlqwuu5z-d0e0bc-050\"><a id=\"_owb1e8ihnjl8\" display=\"false\"></a>Eligibility</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu60-5fsome-051\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu60-n85kef-052\"><strong>Can Apply for Shopeepay</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu60-dcye78-053\">PH Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu60-qimmep-054\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu60-qlm9i3-055\">PH Corporation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu61-4s2hzs-056\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu61-r6mwdd-057\">PH Sole Prop</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu61-6i3co1-058\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu61-vnon77-059\">PH Partnership</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu61-66mobx-060\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu61-gt0fk5-061\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu62-fffi9j-062\">✅</p></th></tr></tbody></table></div><h2 data-block-id=\"mlqwuu62-z5zlj9-063\"><a id=\"_ua1gk41r86em\" display=\"false\"></a>Industry Restriction</h2><ul data-block-id=\"mlqwuu62-tdeckq-064\"><li data-block-id=\"mlqwuu62-ddckiq-065\"><p data-block-id=\"mmsyy2qm-n7x1gz-561\">May see the restricted Industry in this <a href=\"https://docs.google.com/spreadsheets/d/1hoO2b2SfFpRprMVTAUfu39zUQ6tseCj2/edit?usp=sharing&amp;ouid=111970509107447363252&amp;rtpof=true&amp;sd=true\"><u>[SPP] Prohibited List (2).xlsx</u></a> (updated as of 13 Mar 2025) (old reference: <a href=\"https://drive.google.com/file/d/19Lq3o527fWVdpEoCOcdaTorKH12JOzJh/view?usp=sharing\"><u>document</u></a>)</p></li></ul><h2 data-block-id=\"mlqwuu62-d92347-066\"><a id=\"_vh4spbuoxgkj\" display=\"false\"></a>Additional License</h2><p data-block-id=\"mlqwuu62-mquxde-067\">There are some industries that require an additional license before a partner onboard the merchant. Please see below the list :</p><p data-block-id=\"mlqwuu63-0f1u5g-068\"><img data-block-id=\"mlqwuu63-5c4g32-069\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/sop-ph-shopeepay-restricted-image-wbfw2ed8.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><h2 data-block-id=\"mlqwuu63-ma4n04-070\"><a id=\"_2y0zbi9md2e4\" display=\"false\"></a>Merchant Requirements </h2><p data-block-id=\"mlqwuu63-lli1it-071\">Below are the requirements that a merchant has to submit</p><h3 data-block-id=\"mlqwuu63-pwg7fj-072\"><a id=\"_4fvvkngdnkxt\" display=\"false\"></a>Onboarding</h3><h1 data-block-id=\"mlqwuu63-3qi575-073\"><a id=\"_4fvvkngdnkxt\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu63-ts8zsr-074\">Category</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu64-u3zi6d-075\">Requirements</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu64-ilnqk8-076\">Eligibility of entity</p></th><th colspan=\"1\" rowspan=\"1\"><ol data-block-id=\"mlqwuu64-jje0ec-077\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mlqwuu64-7n1al8-078\"><p data-block-id=\"mmsyy2qn-nxjmqc-562\">PH Individual</p></li><li data-block-id=\"mlqwuu64-44ggvy-079\"><p data-block-id=\"mmsyy2qn-idqysi-563\">PH Entity (Sole Proprietorship/Corporation/Partnerships)</p></li><li data-block-id=\"mlqwuu64-vgshsh-080\"><p data-block-id=\"mmsyy2qn-2k0pi0-564\">Foreign Entity</p></li></ol></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mlqwuu64-xqrxdy-081\">Website</p></th><th colspan=\"1\" rowspan=\"1\"><ul data-block-id=\"mlqwuu65-f8phc8-082\"><li data-block-id=\"mlqwuu65-fvv6av-083\"><p data-block-id=\"mmsyy2qn-xmpx2h-565\">As long as pass BDD parameter</p></li></ul></th></tr></tbody></table></div><h1 data-block-id=\"mlqwuu65-cvaqao-084\"><a id=\"_uud9e0o6t4io\" display=\"false\"></a></h1><h2 data-block-id=\"mlqx483d-20oq2n-219\"><a id=\"_2y0zbi9md2e4\" display=\"false\"></a>Activation SLA</h2><p data-block-id=\"mlqwuu65-5mc9ix-085\"><a id=\"_rgb93unqkj02\" display=\"false\"></a><span type=\"spanMark\" style=\"color:rgb(0, 0, 0);font-size:16px;\">SLA is 1-3 working days</span></p><h1 data-block-id=\"mlqwuu65-fdgq85-088\"><a id=\"_3os7h6oc8yhm\" display=\"false\"></a></h1><h1 data-block-id=\"mlqwuu65-0441ce-089\"><a id=\"_wo1uxc7c9mu1\" display=\"false\"></a></h1><h2 data-block-id=\"mlqwuu65-3mmon0-090\"><a id=\"_sp3gbghu3qbv\" display=\"false\"></a>Onboarding Flow</h2><h3 data-block-id=\"mlqwuu65-9fq57x-091\"><a id=\"_4ggq08710acq\" display=\"false\"></a>New</h3><p data-block-id=\"mlqwuu65-tnewmz-092\"><img data-block-id=\"mlqwuu65-1901a3-093\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/sop-ph-shopeepay-restricted-image-q81wyj0u.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><div data-type=\"table-content\"><table width=\"1390\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:1390px;width:1390px;\"><colgroup><col style=\"width:271px;\"><col style=\"width:90px;\"><col style=\"width:888px;\"><col style=\"width:141px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"271\" style=\"background-color:rgb(226, 239, 217);\"><p data-block-id=\"mlqwuu66-waflsw-100\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\" style=\"background-color:rgb(226, 239, 217);\"><p data-block-id=\"mlqwuu66-p3hkbf-101\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\" style=\"background-color:rgb(226, 239, 217);\"><p data-block-id=\"mlqwuu66-ukuxxx-102\"><strong>Action</strong></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\" style=\"background-color:rgb(226, 239, 217);\"><p data-block-id=\"mlqwuu66-b6ygzs-103\"><strong>Process Owner</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"271\"><p data-block-id=\"mlqwuu66-iayxvc-104\">Merchant applies Shopeepay</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\"><p data-block-id=\"mlqwuu67-30x68m-105\">1</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\"><p data-block-id=\"mlqwuu67-yc7ag2-106\">Merchant to click activate button from their dashboard</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\"><p data-block-id=\"mlqwuu67-ymtch3-107\">Merchant</p></th></tr><tr><th colspan=\"1\" rowspan=\"2\" colwidth=\"271\"><p data-block-id=\"mlqwuu67-30qc4h-108\">MO Process Merchant’s Application</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\"><p data-block-id=\"mlqwuu67-y128hh-109\">2</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\"><p data-block-id=\"mlqwuu67-p10311-110\">MO will process the application from CA Tab - ShopeePay PH</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\"><p data-block-id=\"mlqwuu68-4l6fvd-111\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\"><p data-block-id=\"mlqwuu68-tyrql6-112\">3</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\"><p data-block-id=\"mlqwuu68-1y3nka-113\">MO to check if all details have been filled then click <strong>Export and Update Status</strong> and choose the date of submission.</p><p data-block-id=\"mlqwuu68-0807dc-114\">The sheet will only download BIDs with status <em>new_submission</em></p><p data-block-id=\"mmsyy2qq-mh87zz-566\"><img data-block-id=\"mmsyy2qq-858640-567\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image(190).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mlqwuu68-vvjp7u-117\"><br type=\"inline\"><img data-block-id=\"mmsyy2qq-qiljc8-568\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image(191).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"center\" datadisplay=\"inline\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"><br type=\"inline\">Once sheet has been downloaded, status of BIDs will change automatically to<em> awaiting_partner_action</em></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\"><p data-block-id=\"mlqwuu68-t4kn89-118\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"271\"><p data-block-id=\"mlqwuu68-zp9thc-119\">Fill Tracker</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\"><p data-block-id=\"mlqwuu69-rsjtm5-120\">4</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\"><p data-block-id=\"mlqwuu69-echsci-121\">MO copy paste from the sheet to the <a href=\"https://docs.google.com/spreadsheets/d/1eSEsFbGLUBJB4V3dwciDms9weq2J3tx7TIe4ySWECm8/edit?gid=572940445#gid=572940445\"><u>Store Enrollment Form</u></a> as the tracker<img data-block-id=\"mlqwuu69-f6pff5-122\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/sop-ph-shopeepay-restricted-image-1z9n5c5g.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mlqwuu69-ocynjt-123\"></p><p data-block-id=\"mlqwuu69-nui9hs-125\"><strong>Note</strong>:<em> Ensure all the details are fulfilled not only for the BID’s or merchant name</em></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\"><p data-block-id=\"mlqwuu69-9uhz6d-126\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"271\"><p data-block-id=\"mlqwuu69-xawl3z-127\">Inform Email</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\"><p data-block-id=\"mlqwuu69-owgitb-128\">5</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\"><p data-block-id=\"mlqwuu6a-zzo3oz-129\">Every Monday and Thursday, MO needs to send an email to SPP informing that we’ve added new merchants.<br type=\"inline\"></p><p data-block-id=\"mlqwuu6a-2kw9fp-131\"><strong>1 email for the whole month</strong>, please reply from the first email only.</p><p data-block-id=\"mlqwuu6a-rgbgqy-132\">To : Shopee SPP Onboarding &lt;<a><u>spponboarding@shopee.com</u></a>&gt;</p><p data-block-id=\"mlqwuu6a-h62tt2-133\">CC : Patricia Angela Rosario &lt;patricia.rosario@shopee.com&gt;,</p><p data-block-id=\"mlqwuu6a-o36a6t-134\">Pia Maree Mendoza &lt;pia.mendoza@shopee.com&gt;,</p><p data-block-id=\"mlqwuu6a-a1ltor-135\"><em>Subject : [ISV - Online] Xendit - Batch (Month &amp; Year)</em></p><p data-block-id=\"mlqwuu6a-fcp9go-136\"><em>Dear ShopeePay Team,</em></p><p data-block-id=\"mlqwuu6a-zzqv45-137\"><em>Good afternoon.</em></p><p data-block-id=\"mlqwuu6a-swgif7-138\"><em>We have added new merchants under row xxx-xxx (column A), below is the store name :</em></p><p data-block-id=\"mlqwuu6a-thdznq-139\"><em>[copy paste the store name here]</em></p><p data-block-id=\"mlqwuu6a-80diyy-140\"><em>Please kindly acknowledge once you’ve received this email.</em></p><p data-block-id=\"mlqwuu6a-7a9zww-141\"><em>Thank you.</em></p><p data-block-id=\"mlqwuu6a-jlk5mh-142\">Once sent, please put green highlight the merchants on the Enrollment Form.</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\"><p data-block-id=\"mlqwuu6a-31akem-143\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"271\"><p data-block-id=\"mlqwuu6b-lx08iu-144\">Activation</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"90\"><p data-block-id=\"mlqwuu6b-bxbx81-145\">6</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"888\"><p data-block-id=\"mlqwuu6b-ophfrj-146\">ShopeePay PH team will check the Form and process for the activation by filling the column V with Successfully onboarded.</p><p data-block-id=\"mlqwuu6b-0pb2gj-147\">Our crawler will runs every day at 12PM for the activation.</p><p data-block-id=\"mlqwuu6b-uepbgl-148\"><strong><em>Note</em></strong><em> : there will be some cases when crawler won’t work properly, if merchant/AM/SR reach out to MO asking for activation, MO can check the Form and activate manually once column V has been filled.</em></p><p data-block-id=\"mlqwuu6b-6zwgqk-149\"><em><img data-block-id=\"mlqwuu6b-1cy1vs-150\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/sop-ph-shopeepay-restricted-image-nmm3dqp3.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></em></p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"141\"><p data-block-id=\"mlqwuu6b-4m1zvx-151\">Partner &amp; DigiPay</p></th></tr></tbody></table></div><h3 data-block-id=\"mlqwuu65-y8c10x-094\"><a id=\"_s2qbn6gq9vr2\" display=\"false\"></a></h3><h1 data-block-id=\"mlqwuu66-0jeo5j-099\"><a id=\"_ykfatqmpkank\" display=\"false\"></a></h1><h1 data-block-id=\"mlqwuu6b-2unhnr-152\"><a id=\"_ggtxk6e5we9w\" display=\"false\"></a></h1><h1 data-block-id=\"mlqwuu6b-n91c1a-154\"><a id=\"_qn0mmtfunx4k\" display=\"false\"></a></h1><h2 data-block-id=\"mlqwuu6i-8ptofo-183\"><a id=\"_fp2agn1zgl47\" display=\"false\"></a>ShopeePay PH Tokenization Flow</h2><ol data-block-id=\"mlqwuu6j-uvi7pu-184\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mlqwuu6j-1egxn9-185\"><p data-block-id=\"mlqx9nyg-p7ae5d-220\">ShopeePay One-Time Payment should be activated first. The same credentials are used for ShopeePay Tokenization Payment (Auto Debit)</p></li><li data-block-id=\"mlqwuu6j-yf6kks-186\"><p data-block-id=\"mlqxa4w8-x2cysq-221\">You need to raise this to L2 or #product-issues and ask @cs-l2-subscriptions or @payments-on-shift to enabled their autodebit credentials for Subscriptions payment. </p></li></ol><h2 data-block-id=\"mlqwuu6j-2d9pek-187\"><a id=\"_ppotmtgbv2dj\" display=\"false\"></a>Edge Case</h2><h2 data-block-id=\"mlqwuu6j-5nv16j-188\"><a id=\"_x80zwol6oqsd\" display=\"false\"></a></h2><h3 data-block-id=\"mlqwuu6j-m0lm4x-196\"><a id=\"_tprx7inlqvtu\" display=\"false\"></a>Store ID can’t be found on SPP’s end</h3><ol data-block-id=\"mlqwuu6j-5n5xqn-197\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mlqwuu6j-vxln5c-198\"><p data-block-id=\"mmsyy2qt-ur1imj-569\">Check if after download the sheet, status properly changed to awaiting_partner_action</p></li><li data-block-id=\"mlqwuu6j-2awy1g-199\"><p data-block-id=\"mmsyy2qt-eyh4lg-570\">If not, please try to change manually and if not possible please raise to #product-issues (<a href=\"https://xendit.slack.com/archives/C06L0DLT48Z/p1724818622778409\"><u>ref</u></a>)</p></li><li data-block-id=\"mlqwuu6j-vww7lr-200\"><p data-block-id=\"mmsyy2qt-y1vgmc-571\">Submit as usual and if partner mentioned no MID found, MO needs to replicate the MID on dashboard</p></li><li data-block-id=\"mlqwuu6j-1kibff-202\"><p data-block-id=\"mlqxmigr-tbmxtm-227\">Click Pencil button</p></li><li data-block-id=\"mlqwuu6k-ep1quu-203\"><p data-block-id=\"mlqxmhpn-df6p3v-226\">Add “<strong>M</strong>” at the end of external ID</p></li><li data-block-id=\"mlqwuu6k-qdy8jo-204\"><p data-block-id=\"mlqxlqo3-fsalui-224\">&nbsp;<br type=\"inline\"><img data-block-id=\"mlqwuu6k-dj0na8-205\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/sop-ph-shopeepay-restricted-image-7by3j518.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mlqxmw7l-4997u8-228\"></p></li><li data-block-id=\"mlqwuu6k-d2pgcn-206\"><p data-block-id=\"mlqxmw7l-4997u8-228\">Submit as usual</p></li></ol><h3 data-block-id=\"mlqwuu6k-m865k7-207\"><a id=\"_ormam3v6jkrr\" display=\"false\"></a>Duplicate Store Name</h3><ol data-block-id=\"mlqwuu6k-vyjhi6-208\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mlqwuu6k-ripa1g-209\"><p data-block-id=\"mmsyy2qt-wcob62-572\">Happened as some merchants are already onboarded via another aggregator</p></li><li data-block-id=\"mlqwuu6k-xqlfme-210\"><p data-block-id=\"mlqwuu6m-tzof53-211\">MO need to email merchant asking for an alternative name and submit as usual</p></li></ol><p data-block-id=\"mmsyy2qt-klr867-573\"></p>","SeoTitle":"Shopeepay","Description":null},{"Code":"id","Title":"Shopeepay","Slug":"shopeepay-2","ContentType":2,"Content":null,"SeoTitle":"Shopeepay","Description":null},{"Code":"th","Title":"Shopeepay","Slug":"shopeepay-2","ContentType":2,"Content":null,"SeoTitle":"Shopeepay","Description":null},{"Code":"es-mx","Title":"Shopeepay","Slug":"shopeepay-2","ContentType":2,"Content":null,"SeoTitle":"Shopeepay","Description":null}]