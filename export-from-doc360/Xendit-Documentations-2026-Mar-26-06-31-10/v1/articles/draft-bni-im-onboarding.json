[{"Code":"en","Title":"BNI Instamoney Onboarding","Slug":"draft-bni-im-onboarding","ContentType":2,"Content":"<p data-block-id=\"mmkb8nrc-tlwjyl-741\"><a id=\"_j5wih1vxvjn6\" display=\"false\"></a></p><p data-block-id=\"mmkb8nrc-jz4bme-742\"><a id=\"_l05hjyqn0fsh\" display=\"false\"></a></p><p data-block-id=\"mmkb8nrc-ee6bbq-743\"><a id=\"_8uw0d3uumh8v\" display=\"false\"></a></p><h1 data-block-id=\"mmkb8nrc-fcm4oq-744\"><a id=\"_rgwl05coo69f\" display=\"false\"></a></h1><h2 data-block-id=\"mmkb8nrc-8e5o0t-745\"><a id=\"_9j6h54imkhti\" display=\"false\"></a>Glossary</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrd-oix3ta-746\"><strong>Terms</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrd-040lsa-747\"><strong>Description</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrd-aw9ysr-748\">AM / SR</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrd-rrv80d-749\">Account Manager / Sales Representative</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nre-lysnwg-750\">MO</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nre-m7k8ee-751\">Merchant Ops</p></th></tr></tbody></table></div><h1 data-block-id=\"mmkb8nre-nn9q1z-752\"><a id=\"_dr5r8606tnd\" display=\"false\"></a></h1><h2 data-block-id=\"mmkb8nre-2sxyr8-753\"><a id=\"_x5gzec6f0lg\" display=\"false\"></a>Related Documents</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nre-jmtwki-754\"><strong>Document name</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrf-hsr5lq-755\"><strong>Description</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrf-wda8jd-756\"><strong>Link to document</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrf-0zxlul-757\">SOP Merchant Onboarding</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrf-jt2kg0-758\">Latest SOP for Instamoney Merchant Onboarding</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrf-xhtqx8-759\"><a href=\"https://docs.google.com/document/u/0/d/1U6eCqAAyt322aV9fOU4hTfVI1GXmPFtG5THHtlfOUYc/edit\"><u>Instamoney MO Guideline [WIP]</u></a></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrg-auvk8n-760\">P2P/KSP Email templates</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrg-9u3ru2-761\">P2P/KSP Email templates</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrg-xuenlk-762\"><a href=\"https://docs.google.com/document/d/17SLXk1CUZyt1gLU8LpIvDWJL-sdjcoFCYSYv87N25M0/edit?tab=t.0#heading=h.kfsz4quxgvp7\"><u>P2P/KSP Email templates</u></a></p></th></tr></tbody></table></div><h1 data-block-id=\"mmkb8nrg-0vd2tc-763\"><a id=\"_mz8l663xf94n\" display=\"false\"></a></h1><h2 data-block-id=\"mmkb8nrg-fssfce-764\"><a id=\"_owb1e8ihnjl8\" display=\"false\"></a>Eligibility</h2><h2 data-block-id=\"mmkb8nrg-q93r8w-765\"><a id=\"_dv9fvn39cs6e\" display=\"false\"></a></h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrh-j0w5dy-766\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrh-662rxx-767\"><strong>Can Apply for BNI Escrow?</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrh-yw1ia6-768\">Indonesian Entity (PT/CV/Yayasan)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrh-byr159-769\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nri-phd3el-770\">Indonesian Entity (Perseroan perorangan/PP)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nri-y5efif-771\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nri-90twep-772\">Indonesian Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nri-wgzsj5-773\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nri-gib0lc-774\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrj-4cgmm8-775\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrj-0h3yaz-776\">Foreign Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrj-79zo3o-777\">❌</p></th></tr></tbody></table></div><h1 data-block-id=\"mmkb8nrj-i17yui-778\"><a id=\"_a3zdas7auo5\" display=\"false\"></a></h1><h2 data-block-id=\"mmkb8nrj-zax2eg-779\"><a id=\"_87m8kmnlsgvo\" display=\"false\"></a>Legal Requirement</h2><h2 data-block-id=\"mmkb8nrj-digub9-780\"><a id=\"_p64fjcd0qwwm\" display=\"false\"></a></h2><ol data-block-id=\"mmkb8nrj-ed0cxe-781\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mmkb8nrj-s08mbo-782\"><p data-block-id=\"mmsz1jty-ndad3s-802\">Deed of Establishment &amp; Changes (if any) / Akta Pendirian &amp; Perubahan (jika ada)</p></li><li data-block-id=\"mmkb8nrj-5zycmd-783\"><p data-block-id=\"mmsz1jty-xg1bq3-803\">Decree of the Ministry of Justice and Human Rights &amp; Changes (if any) / SK Menhukham Pendirian &amp; Perubahan (jika ada)</p></li><li data-block-id=\"mmkb8nrj-5g7uyy-784\"><p data-block-id=\"mmsz1jty-up0ojv-804\">Trading Business License /  Surat Izin Usaha Perdagangan (SIUP)</p></li><li data-block-id=\"mmkb8nrj-e5ydw8-785\"><p data-block-id=\"mmsz1jty-vgcnsy-805\">Certificate of Company Registration / Tanda Daftar Perusahaan / (TDP)</p></li><li data-block-id=\"mmkb8nrj-o4kngm-786\"><p data-block-id=\"mmsz1jty-bprkzr-806\">Company Registration Number / Nomor Induk Bersertifikat (NIB) </p></li><li data-block-id=\"mmkb8nrk-dp1kho-787\"><p data-block-id=\"mmsz1jty-vryl92-807\">Certificate of Domicile / Surat Keterangan Domisili </p></li><li data-block-id=\"mmkb8nrk-x1nd7l-788\"><p data-block-id=\"mmsz1jty-55rjkn-808\">Tax ID of Company / NPWP Perusahaan</p></li><li data-block-id=\"mmkb8nrk-jkimte-789\"><p data-block-id=\"mmsz1jty-1a3eip-809\">Identity Card of all shareholders / KTP Direktur</p></li><li data-block-id=\"mmkb8nrk-e58at4-790\"><p data-block-id=\"mmsz1jty-hfvxva-810\">Tax ID of all shareholders / NPWP Direktur</p></li><li data-block-id=\"mmkb8nrk-hepilu-791\"><p data-block-id=\"mmsz1jty-ipozqz-811\">OJK License KEP-95/ (Input bahasa name)</p></li></ol><p data-block-id=\"mmkb8nrk-fcfi1r-792\"><em>Note:</em></p><ul data-block-id=\"mmkb8nrk-qrybsy-793\"><li data-block-id=\"mmkb8nrk-0v3sf7-794\"><p data-block-id=\"mmsz1jtz-uiv8ep-812\"><em>If merchant is having NIB (#5), there is no need to upload SIUP (#3) &amp; TDP (#4)</em></p></li></ul><h1 data-block-id=\"mmkb8nrk-xkblrr-795\"><a id=\"_z5wqouo7g6n2\" display=\"false\"></a></h1><h2 data-block-id=\"mmkb8nrk-zc7adk-796\"><a id=\"_5hdtq7i5d3gt\" display=\"false\"></a>SLA</h2><h2 data-block-id=\"mmkb8nrk-l80zv1-797\"><a id=\"_s5rz97koiqic\" display=\"false\"></a></h2><p data-block-id=\"mmkb8nrk-s9ngk6-798\">1 -  3 Working Days</p><h2 data-block-id=\"mmkb8nrk-crc5b4-799\"><a id=\"_qn0mmtfunx4k\" display=\"false\"></a>Onboarding Steps </h2><h2 data-block-id=\"mmkb8nrk-u9gxrq-800\"><a id=\"_6oazw8dhfnn1\" display=\"false\"></a></h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrk-btsp63-801\">Category</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrl-kjko2k-802\">Action</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrl-jtvmnn-803\">Process Owner</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrm-q0nes2-804\">Merchant applies for IM Account </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrn-ct5q95-805\">Request for the following documents from the merchant for account activation. Refer to the email templates <a href=\"https://docs.google.com/document/d/17SLXk1CUZyt1gLU8LpIvDWJL-sdjcoFCYSYv87N25M0/edit#heading=h.kfsz4quxgvp7\"><u>here</u></a> for reference </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nro-sp2y3c-806\">AM/SR</p></th></tr><tr><th colspan=\"1\" rowspan=\"2\"><p data-block-id=\"mmkb8nro-e8ue89-807\">Submitting LDD and BDD to dashboard</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrp-vhvlyp-808\">After salesperson receives the required information from the merchant, go to admin dashboard <a href=\"https://admin-dashboard.tidnex.com/\"><u>https://admin-dashboard.tidnex.com/</u></a> , search for the BID or email address given by the merchant to key in all the information merchant has provided <strong>AND</strong> upload all relevant documents to <a href=\"https://drive.google.com/open?id=1e7ZFD87rHc84VAcoMvRtkbDl5lre8KKC\"><u>Instamoney Gdrive</u></a></p><p data-block-id=\"mmkb8nrp-2kwffd-809\"><img data-block-id=\"mmkb8nrq-s05v04-810\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-br9sjvxi.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrq-wznrdr-811\">AM/SR</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrq-y6z8kh-812\">Under General Information, key in the following information</p><ul data-block-id=\"mmkb8nrq-16k97q-813\"><li data-block-id=\"mmkb8nrq-lahz41-814\"><p data-block-id=\"mmsz1ju0-nk8rke-813\">Merchant Internal Name</p></li><li data-block-id=\"mmkb8nrq-987cmq-815\"><p data-block-id=\"mmsz1ju1-lu8bf5-814\">Business Development Manager (if any)</p></li><li data-block-id=\"mmkb8nrq-qdokyt-816\"><p data-block-id=\"mmsz1ju1-5oh0hz-815\">Channel Partnership Manager (if any)</p></li></ul><p data-block-id=\"mmkb8nrq-txajck-817\"><img data-block-id=\"mmkb8nrq-6m0pao-818\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-132pwjgt.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkb8nrq-mg94e5-819\">Under ‘Authorized Signatory’, key in the following information</p><ul data-block-id=\"mmkb8nrq-4ogtd4-820\"><li data-block-id=\"mmkb8nrq-pfanh0-821\"><p data-block-id=\"mmsz1ju1-4v2o8b-816\">Director Name</p></li><li data-block-id=\"mmkb8nrq-h6a136-822\"><p data-block-id=\"mmsz1ju1-t4y8ns-817\">Director Email</p></li><li data-block-id=\"mmkb8nrq-s44n24-823\"><p data-block-id=\"mmsz1ju1-mzbqb2-818\">Director Title</p></li><li data-block-id=\"mmkb8nrr-vm3ydq-824\"><p data-block-id=\"mmsz1ju1-chn7lj-819\">Director NPWP</p></li><li data-block-id=\"mmkb8nrr-z3vcie-825\"><p data-block-id=\"mmsz1ju1-77wp7s-820\">Director Identification File/KTP </p></li></ul><p data-block-id=\"mmkb8nrr-1ervmm-826\"><img data-block-id=\"mmkb8nrr-zdevrt-827\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-165d562r.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkb8nrr-mcs5fz-828\">Under ‘PIC’, key in the following information</p><ul data-block-id=\"mmkb8nrr-p3zums-829\"><li data-block-id=\"mmkb8nrr-uptbqp-830\"><p data-block-id=\"mmsz1ju1-k6se4t-821\">PIC Name</p></li><li data-block-id=\"mmkb8nrr-n3l0g3-831\"><p data-block-id=\"mmsz1ju1-m4g9qx-822\">PIC Email</p></li><li data-block-id=\"mmkb8nrr-el13kv-832\"><p data-block-id=\"mmsz1ju1-wgjsx7-823\">PIC Phone Number</p></li></ul><p data-block-id=\"mmkb8nrr-ew9iel-833\"><img data-block-id=\"mmkb8nrr-7vi1fy-834\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-s42nd5p1.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrs-juqfsq-835\">AM/SR</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmsz1ju2-egiv8z-824\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrs-jsniob-836\">Once documents have been uploaded, salesperson has to go to <strong>#im-onboarding</strong> to request for account activation from MO</p><p data-block-id=\"mmkb8nrt-rgs1z9-837\">Type / in the messaging  box to see a pop up and select ‘Activation Account’</p><p data-block-id=\"mmkb8nrt-seglr1-838\"><img data-block-id=\"mmkb8nrt-wkkmgk-839\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-ohwfs7k8.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkb8nrt-s36dan-840\">Key in all the required information and click submit</p><p data-block-id=\"mmkb8nrt-7rmw7z-841\"><img data-block-id=\"mmkb8nrt-5rmg19-842\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-q0jxkcgu.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrt-ctk7yj-843\">AM/SR</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrt-c9texc-844\">KYC LDD BDD via CM</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nrt-b571z9-845\">MO will KYC as usual terms via CM:<br type=\"inline\">Checking for Match information with LDD and BDD that sales given in the CM dashboard.</p><p data-block-id=\"mmkb8nru-rxashq-847\">MO will <strong>NOT</strong> inform you after account activation completion. Instead, they will respond with a ✓ on the request once it has been completed. Please take your own initiative to check back on the slack channel to see the status of your request.</p><p data-block-id=\"mmkb8nru-xfpf2s-848\"><img data-block-id=\"mmkb8nru-lgqpmk-849\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-bni-im-onboarding-image-q63w2k80.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mmkb8nru-odj3cv-850\">The account is now activated!</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mmkb8nru-jrr35t-851\">MO</p></th></tr></tbody></table></div><h1 data-block-id=\"mmkb8nru-r37e3z-852\"><a id=\"_7bbswee84iy4\" display=\"false\"></a></h1><p data-block-id=\"mmsz1ju3-ul5kf6-825\"></p>","SeoTitle":"BNI Instamoney Onboarding","Description":null},{"Code":"id","Title":"BNI Instamoney Onboarding","Slug":"bni-instamoney-onboarding","ContentType":2,"Content":null,"SeoTitle":"BNI Instamoney Onboarding","Description":null},{"Code":"th","Title":"BNI Instamoney Onboarding","Slug":"bni-instamoney-onboarding","ContentType":2,"Content":null,"SeoTitle":"BNI Instamoney Onboarding","Description":null},{"Code":"es-mx","Title":"BNI Instamoney Onboarding","Slug":"bni-instamoney-onboarding","ContentType":2,"Content":null,"SeoTitle":"BNI Instamoney Onboarding","Description":null}]