[{"Code":"en","Title":"Billease Onboarding","Slug":"billease-onboarding-restricted","ContentType":2,"Content":"<p data-block-id=\"mk3dxqcx-mk0se5-002\"><em>Last Update : Nov 13, 2025</em></p><p data-block-id=\"mk3dxqcy-4u51xu-003\"><em>MO PIC :  </em><a><em><u>Raffy John Panes</u></em></a></p><h2 data-block-id=\"mk3dxqcy-2tli83-004\"><a id=\"_vxli4z8mw7iu\" display=\"false\"></a>Versioning</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd0-nbn4n7-005\"><strong>Ver.</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd0-tyv0hb-006\"><strong>Date</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd0-ii2ttd-007\"><strong>Description</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd0-58zmca-008\">1.0</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd1-9wkjl2-009\">Mar 21, 2022</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd1-li3qiy-010\">Template and SOP update</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd1-otbsw0-011\">2.0</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd1-l2excd-012\">Jul 26, 2022</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd1-aaf4xs-013\">Instant Activation</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd2-pgtn89-014\">3.0</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd2-3obver-015\">Date</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd2-5q2z55-016\">Restrictions for Sole Prop and Individual</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd2-7efxvd-017\">4.0</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd2-blmlx4-018\">Nov 13, 2025</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd2-s6e2as-019\">Update</p></th></tr></tbody></table></div><h1 data-block-id=\"mk3dxqd2-n9b5ro-020\"><a id=\"_ywv39cug39bx\" display=\"false\"></a></h1><h2 data-block-id=\"mk3dxqd3-e3vako-021\"><a id=\"_9j6h54imkhti\" display=\"false\"></a>Glossary</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd3-z88but-022\"><strong>Terms</strong></p></th><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd3-1kh3v9-023\"><strong>Description</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd3-nytivo-024\">MO</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd3-wh14gm-025\">Merchant Operations</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd3-4aoxs6-026\">AM</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd4-aa5per-027\">Account Manager</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd4-70pl9w-028\">CA</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd4-ot1mjn-029\">Channel Activation</p></th></tr></tbody></table></div><h1 data-block-id=\"mk3dxqd4-dzi6t7-030\"><a id=\"_49nd097njvij\" display=\"false\"></a></h1><h2 data-block-id=\"mk3dxqd4-i5njsn-031\"><a id=\"_ejxly55we75x\" display=\"false\"></a>Xendit Stakeholders</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd4-xszi48-032\"><strong>Department</strong></p></th><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd4-u70ono-033\"><strong>PIC</strong></p></th><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd4-44kv12-034\"><strong>PIC Role</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd5-l60cbn-035\">Partnership</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd5-btu00z-036\"><a><u>Mica Rose Nopuente</u></a></p><p data-block-id=\"mk3dxqd5-btu00z-036\"><a><u>Ian Carlo Arias</u></a></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd5-z90s7i-037\">Partnerships PIC for Billease</p></th></tr></tbody></table></div><h1 data-block-id=\"mk3dxqd5-oychka-038\"><a id=\"_l0o6jdyv2txv\" display=\"false\"></a></h1><h2 data-block-id=\"mk3dxqd5-dyi2yb-039\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a>Eligibility</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:621px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"621\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd5-tewtud-040\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd5-wfc1e4-041\"><strong>Can Apply</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"621\"><p data-block-id=\"mk3dxqd5-jlju9s-042\">PH Individual (Social Sellers)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd6-6ymqts-043\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"621\"><p data-block-id=\"mk3dxqd6-p0ykkg-044\">PH Sole Proprietor</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd6-njhru3-045\">⚠️*</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"621\"><p data-block-id=\"mk3dxqd6-8ykjcb-046\">PH Partnership</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd6-hqk7zf-047\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"621\"><p data-block-id=\"mk3dxqd6-92adqv-048\">PH Corporation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd6-ffr30v-049\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"621\"><p data-block-id=\"mk3dxqd7-iafs71-050\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd7-9hyz7c-051\">❌</p></th></tr></tbody></table></div><p data-block-id=\"mk3dxqd7-rnojtj-052\"><br type=\"inline\">*Required approval from BillEase</p><h1 data-block-id=\"mk3dxqd7-z0jnii-054\"><a id=\"_w2g1ajchr0f\" display=\"false\"></a></h1><h2 data-block-id=\"mk3dxqd7-f6gz0m-055\"><a id=\"_6c0oxkffxx60\" display=\"false\"></a>Merchant Requirements </h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:230px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"230\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd8-0tsd0k-057\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\" style=\"background-color:rgb(222, 235, 246);\"><p data-block-id=\"mk3dxqd8-zuxq5p-058\"><strong>Requirements</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"230\"><p data-block-id=\"mk3dxqd8-xvmqkv-059\">Special Case</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd8-v417y7-060\">Instant Activation flow only applicable for PH Corporations &amp; PH Partnership that do not fall under Restricted Industries</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"230\"><p data-block-id=\"mk3dxqd8-t5h98b-061\">Restricted Industries</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqd8-2q1iif-062\"><a href=\"https://billease.ph/merchant-terms-of-service/\"><u>https://billease.ph/merchant-terms-of-service/</u></a> <br type=\"inline\"></p><ul data-block-id=\"mk3dxqd9-jwwfus-064\"><li data-block-id=\"mk3dxqd9-ptbf80-065\"><p data-block-id=\"mk3ifq8t-j4z2a1-034\">Products and/or services intended to be used to create or trade illegal drugs and controlled substances or ingredients or paraphernalia for such</p></li><li data-block-id=\"mk3dxqd9-x0x21e-066\"><p data-block-id=\"mk3ifq8t-wzmhu9-035\">Cryptocurrencies, Non-Fungible Tokens (NFTs) or any highly speculative digital assets;</p></li><li data-block-id=\"mk3dxqd9-w6tw8n-067\"><p data-block-id=\"mk3ifq8t-fv7hd5-036\">Pyramid schemes which include selling of products or services;</p></li><li data-block-id=\"mk3dxqd9-9sf8em-068\"><p data-block-id=\"mk3ifq8t-7i0gtl-037\">Escort agencies, sexual services, and/or massage parlors that offer similar services;</p></li><li data-block-id=\"mk3dxqd9-areqvg-069\"><p data-block-id=\"mk3ifq8u-r9ikm2-038\">Refinancing loans, payday loans, unsecured loans, or any line of credit;</p></li><li data-block-id=\"mk3dxqd9-ipdwtf-070\"><p data-block-id=\"mk3ifq8u-h0ltdh-039\">Counterfeit goods/replicas or those infringing intellectual property (IP) rights;</p></li><li data-block-id=\"mk3dxqd9-6osqym-071\"><p data-block-id=\"mk3ifq8u-y6mvii-040\">Weapons, ammunition, military arms, explosive devices and/or firearm parts;</p></li><li data-block-id=\"mk3dxqd9-wbrr6g-072\"><p data-block-id=\"mk3ifq8u-43cpph-041\">Products and services that promote hate, violence, discrimination, terrorism, harassment or abuse;</p></li><li data-block-id=\"mk3dxqd9-phw0sy-073\"><p data-block-id=\"mk3ifq8u-fx3suk-042\">Products that circumvent copyright protection or that facilitate the unlicensed use of copyrighted materials and other intellectual property;</p></li><li data-block-id=\"mk3dxqd9-7tbs3r-074\"><p data-block-id=\"mk3ifq8u-vwje5v-043\">Gambling activities, licensed or otherwise;</p></li><li data-block-id=\"mk3dxqd9-h87g61-075\"><p data-block-id=\"mk3ifq8u-xfc08u-044\">Illegal products/services or any service providing peripheral support of illegal activities under Applicable Law;</p></li><li data-block-id=\"mk3dxqd9-cmutox-076\"><p data-block-id=\"mk3ifq8u-eprh91-045\">Products, services, or activities that engaged in any form of deceptive marketing practices;</p></li><li data-block-id=\"mk3dxqd9-teevi2-077\"><p data-block-id=\"mk3ifq8u-32ufje-046\">Jammers or devices that are designed to block, jam or interfere with personal communication devices that can be used for terrorism or violence and activities to violate Applicable Law.</p></li><li data-block-id=\"mk3dxqd9-d9mlq9-078\"><p data-block-id=\"mk3ifq8u-cvfc16-047\">Jewelries and high-value items that can be easily sold and are often associated with scams, fraud, or illicit trade.</p></li><li data-block-id=\"mk3dxqd9-rchfib-079\"><p data-block-id=\"mk3ifq8v-5xryk8-048\">The sale of any tobacco product, e-cigarettes, vapes, and the likes are not allowed.</p></li><li data-block-id=\"mk3dxqda-guiuyg-080\"><p data-block-id=\"mk3ifq8v-nf2ppr-049\">Jewelry and high-value items possessing facile marketability, commonly correlated with deceptive schemes, fraudulent activities, or unlawful commerce. This includes, but is not restricted to, precious metals such as gold and gemstones like diamonds.</p></li></ul></th></tr></tbody></table></div><h2 data-block-id=\"mk3dxqda-28tgvo-081\"><a id=\"_ujkex4eg0uw0\" display=\"false\"></a>SLA</h2><ul data-block-id=\"mk3dxqda-m91rhu-082\"><li data-block-id=\"mk3dxqda-jk2tlb-083\"><p data-block-id=\"mk3ifq8v-my5tv0-050\">Instant Activation Flow: immediate (during Go-Live)</p></li><li data-block-id=\"mk3dxqda-jbio6j-084\"><p data-block-id=\"mk3e1qmu-2cd8m3-162\">Non Instant Activation: 3 - 5 working day (7 - 10 <span contenteditable=\"false\" translate=\"no\" data-glossary=\"working days\" data-glossary-name=\"working days\" id=\"blockglossary\" class=\"fr-deletable popover__title\">{{glossary.working days}}</span> if there are delays)</p></li></ul><h2 data-block-id=\"mk5sxto5-veqvpi-014\"><a id=\"_r0miqi6pvfyc\" display=\"false\"></a>Onboarding &amp; Activation</h2><h3 data-block-id=\"mk5sxto5-1vcfmd-015\"><a id=\"_5106ufdwjqsi\" display=\"false\"></a>Instant Activation Flow </h3><ol data-block-id=\"mk3dxqda-d4146h-087\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mk3dxqda-8otfru-088\"><p data-block-id=\"mk3ifq8w-2fod6c-051\">MO performs go live onboarding as usual</p></li><li data-block-id=\"mk3dxqda-uwwtpy-089\"><p data-block-id=\"mk3ifq8w-cif9zb-052\">MO vets merchant against Billease restricted categories list in existing SOP list &amp; not Sole Proprietorship / Individual merchants </p><ol data-block-id=\"mk3dxqda-qhjzib-090\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mk3dxqda-oif30i-091\"><p data-block-id=\"mk3ifq8w-wbyjq6-053\">If merchant is not in the restricted categories list, MOs can toggle billease button to activate the merchant</p></li></ol></li></ol><p data-block-id=\"mk3dxqda-ub5bbd-092\"><img data-block-id=\"mk3ifq8w-jvwv3w-054\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/image(179).png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"true\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><div text=\"Loading text...\"><p data-block-id=\"mk5su5q2-2ri51f-013\"></p></div><h1 data-block-id=\"mk3dxqdb-bu3aud-094\"><a id=\"_tbhjlay56b8x\" display=\"false\"></a></h1><h3 data-block-id=\"mk3dxqdb-112k77-095\"><a id=\"_sh5jlfrjx55i\" display=\"false\"></a>Non-Instant Activation Flow</h3><p data-block-id=\"mk3dxqdb-hgiok7-096\">Due to the recent fraud-cases, BillEase activation for Sole Proprietorship will be subjected to approval from BillEase:</p><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:84px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3e1c6h-eisdzp-161\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdb-955qsc-097\"><strong>Steps</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdb-nzmr43-098\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdb-n0zalm-099\">Merchant is LIVE with Xendit</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdc-2ai9mf-100\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdc-uj8j9p-101\">If merchant <strong>is not a Sole Prop</strong> (e.g: Corporation/Partnership) and does not fall under <a href=\"#_6c0oxkffxx60\"><u>prohibited industries</u></a>, can proceed <strong>for activation in Step 6</strong></p><p data-block-id=\"mk3dxqdc-nzh2uc-102\">If merchant <strong>is a Sole Prop - please proceed with step 3 onwards</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdc-9z4hl1-103\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdc-9rvpoq-104\">CS/SR/CPS is requesting on behalf of merchant for BillEase activation in #mo-request</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdc-f6ty7g-105\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdc-mb9fhs-106\">Make sure to ask the following details:</p><ol data-block-id=\"mk3dxqdc-x8chcw-107\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mk3dxqdc-bm92so-108\"><p data-block-id=\"mk3ifq9w-twhl2w-055\">Department of Trade and Industry’s Certificate of Business Name Registration - <strong>available in OM</strong></p></li><li data-block-id=\"mk3dxqdc-lbc1v8-109\"><p data-block-id=\"mk3ifq9w-lvuzsg-056\">Business Permit/Mayor’s Permit</p></li><li data-block-id=\"mk3dxqdd-0ek219-110\"><p data-block-id=\"mk3ifq9w-8efjyq-057\">Bureau of Internal Revenue’s Certificate of Registration (BIR Form 2303) - <strong>available in OM</strong></p></li><li data-block-id=\"mk3dxqdd-gz2wmb-111\"><p data-block-id=\"mk3ifq9w-yzeiz4-058\">Latest Annual Financial Statement (AFS) - if a merchant is unable to provide the latest AFS, they would require their bank statement with records in the past 6 months as an alternative</p></li><li data-block-id=\"mk3dxqdd-1l85jd-112\"><p data-block-id=\"mk3ifq9w-15cum0-059\">Average Monthly Gross Income</p></li><li data-block-id=\"mk3dxqdd-9dloir-113\"><p data-block-id=\"mk3ifq9w-k6r50l-060\">Operating for how many months/years</p></li></ol><p data-block-id=\"mk3dxqdd-nojq64-114\">MO to fill in the details in <a href=\"https://docs.google.com/spreadsheets/d/1rna2KIhl7OL2_hlhxxvnGcGbQbJrs3shlBMaUqapCnM/edit?gid=1109044654#gid=1109044654\"><u>BillEase Onboarding Form_Xendit Philippines Inc.</u></a></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdd-3c24w4-115\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdd-v6kirp-116\">Once completed, MO to send an email to Manzil Balani &lt;<a><u>manzil.balani@billease.ph</u></a>&gt; with the subject \"Onboarding_Xendit Philippines Inc_Date\" including the required merchant's documents.</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdd-dhjmg9-117\">6</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdd-gh39xi-118\">Once approved, please proceed activation using this <strong>Retool: <br type=\"inline\"></strong></p><p data-block-id=\"mk3dxqdd-t9f9ey-119\"><a href=\"https://retool.tidnex.com/apps/0399be74-38c2-11ed-a00f-3b3d46c4786b/Digipay%20-%20Apps/Paylater%20Merchant%20Activation\"><strong><u>https://retool.tidnex.com/apps/0399be74-38c2-11ed-a00f-3b3d46c4786b/Digipay%20-%20Apps/Paylater%20Merchant%20Activation</u></strong></a><strong> </strong></p><p data-block-id=\"mk3dxqdd-gof10g-120\"><strong>Step:</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqde-77echj-121\">6a</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqde-gg7khl-122\">Click on <strong>Load Channels </strong>first</p><p data-block-id=\"mk3dxqde-pahxah-123\"><img data-block-id=\"mk3dxqde-xlzsba-124\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-mzmufp43.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqde-7helha-125\">6b</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqde-gju93d-126\">Choose the Channel Code: PH_Billease</p><p data-block-id=\"mk3dxqde-dmrv04-127\">And enter the Business ID</p><p data-block-id=\"mk3dxqde-57rfht-128\">Then proceed with clicking Search</p><p data-block-id=\"mk3dxqde-zes4qd-129\"><img data-block-id=\"mk3dxqde-9ca1gy-130\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-pwyogq9c.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqde-op8n1l-131\">6c</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdf-ithgzb-132\">For Step 3.1 - <strong>Common Onboarding</strong>:</p><p data-block-id=\"mk3dxqdf-sxinli-133\"><img data-block-id=\"mk3dxqdf-ghp9vn-134\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-bhkddftj.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><ul data-block-id=\"mk3dxqdf-gepjte-135\"><li data-block-id=\"mk3dxqdf-crx2y4-136\"><p data-block-id=\"mk3ifqa2-pao670-061\">Make sure that this is <strong>activated</strong> - so status will be reflected on Customer &amp; Admin Dashboard: Click Activate &gt; Change the status to Live &gt; Click Update</p></li><li data-block-id=\"mk3dxqdf-k5d07g-137\"><p data-block-id=\"mk3ifqa2-nookpf-062\">P.s: For instances where Common Onboarding is already activated, just need to make sure status is updated to Live. </p></li></ul><p data-block-id=\"mk3dxqdf-recrlm-138\"><img data-block-id=\"mk3dxqdf-7l0wkz-139\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-x2y9qwko.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><p data-block-id=\"mk3dxqdf-abbwxm-140\">Click <strong>Next </strong>after</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdf-dcdoet-141\">6d</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdf-0f7amz-142\">For Step 3.2 - <strong>Paylater</strong>:</p><ul data-block-id=\"mk3dxqdf-fenosp-143\"><li data-block-id=\"mk3dxqdf-3k88j2-144\"><p data-block-id=\"mk3ifqa3-ja9f4x-063\">Make sure that we click <strong>Create </strong>for these 2 steps:</p></li></ul><p data-block-id=\"mk3dxqdf-7ivf6y-145\"><img data-block-id=\"mk3dxqdg-6yhrry-146\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-iz048j8r.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p><ul data-block-id=\"mk3dxqdg-9xz5ik-147\"><li data-block-id=\"mk3dxqdg-0qy72z-148\"><p data-block-id=\"mk3ifqa3-y3jcow-064\">Click <strong>Next</strong></p></li></ul><p data-block-id=\"mk3dxqdg-w8zez1-149\"><img data-block-id=\"mk3dxqdg-weq4ua-150\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-r3k5z1h2.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdg-tl5ex9-151\">6e</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdg-haf9h5-152\">For Step 3.3: <strong>Invoice</strong></p><ul data-block-id=\"mk3dxqdg-i9apmf-153\"><li data-block-id=\"mk3dxqdg-g3yy2f-154\"><p data-block-id=\"mk3ifqa4-13xph1-065\">Make sure that status invoice is active (this is actually linked to Step 3.1 and 3.2)</p></li><li data-block-id=\"mk3dxqdg-e3uw9o-155\"><p data-block-id=\"mk3ifqa4-raglc1-066\">If the<strong> invoice</strong> is already <strong>active</strong>, <strong>no further action required on this step</strong></p></li></ul><p data-block-id=\"mk3dxqdg-805n8r-156\"><img data-block-id=\"mk3dxqdg-9styyq-157\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/billease-onboarding-restricted-image-dgkngw5v.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"84\"><p data-block-id=\"mk3dxqdg-kvgttq-158\">6f</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mk3dxqdg-fgcig6-159\">Done! Billease is activated</p></th></tr></tbody></table></div><p data-block-id=\"mk3dxqdh-firzhz-160\">`</p>","SeoTitle":"Billease Onboarding","Description":null},{"Code":"id","Title":"Billease","Slug":"billease-1","ContentType":2,"Content":null,"SeoTitle":"Billease","Description":null},{"Code":"th","Title":"Billease","Slug":"billease-1","ContentType":2,"Content":null,"SeoTitle":"Billease","Description":null},{"Code":"es-mx","Title":"Billease","Slug":"billease-1","ContentType":2,"Content":null,"SeoTitle":"Billease","Description":null}]