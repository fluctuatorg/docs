gn:top;\"><p data-block-id=\"mei91um2-6wu9ip-031\">Any</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\" style=\"box-sizing:border-box;padding:10px;vertical-align:top;\"><p data-block-id=\"mei91um2-adqxgq-032\">รหัสช่องทางของบัญชีผู้รับ</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\" style=\"box-sizing:border-box;padding:10px;vertical-align:top;\"><p data-block-id=\"mei91um2-ajge3l-033\"><code>account_number</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\" style=\"box-sizing:border-box;padding:10px;vertical-align:top;\"><p data-block-id=\"mei91um3-804vme-034\">Any</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\" style=\"box-sizing:border-box;padding:10px;vertical-align:top;\"><p data-block-id=\"mei91um3-268r2g-035\">หมายเลขบัญชีของบัญชีผู้รับ</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"mei91um3-9sgkou-036\"><code>account_holder_name</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\" style=\"box-sizing:border-box;padding:10px;vertical-align:top;\"><p data-block-id=\"mei91um3-fuaag5-037\">Any</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"mei956w7-at2pl3-048\">ชื่อเจ้าของบัญชีของบัญชีผู้รับ</p></td></tr></tbody></table></div><p data-block-id=\"a4c63523-3ae0-48b1-ab17-71efa43fc5c6\"></p>","SeoTitle":"มาเลเซีย","Description":null},{"Code":"es-mx","Title":"Malasia","Slug":"payouts-coverage-malaysia","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><div data-type=\"table-content\"><table width=\"632\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:632px;width:632px;\"><colgroup><col style=\"width:316px;\"><col style=\"width:316px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"a46799c5-79e7-4b42-bf44-04ebb1f006a9\">Esquema de Pago</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"fefedcf9-06c0-4b8e-b1d8-275d8dbbad10\">Vías Locales</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"7b54e4a3-e12a-41a7-b779-eb458513d305\">Monedas Compatibles</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"ee3cc23e-f3fe-472e-9314-0bb21cba57f9\">MYR</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"ca23e1b3-66d8-4b3d-bfa5-46d250a8e7ac\">Tiempo Estimado de Llegada</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"2a7800a0-08a0-4a4e-b853-a8e9ab33ecf7\">15 minutos</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"aaa3529a-0e88-40ad-94bc-2e2618fd5094\">Hora Límite</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"3f1f6a57-7f89-45c2-839d-a8d96f406ac1\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"0dc221e0-31e5-40c6-b34e-cfb4561ce9b0\">Límite de Transacción</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"a51c7e2a-9356-4752-aefe-3d424e870aa7\">10,000,000</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"15da2347-b5e2-459c-81bf-c1c2efadc5e9\">Soporte de Descripción</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"83ec00f0-fac3-460d-b550-3f7efe973029\">No</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"e6aa451a-2f43-4e3a-ae85-f5b8184a1495\">Casos de Uso Compatibles</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"0664b24b-fd31-476e-a5b3-8f4045eeccb7\">Payout, Cross Border Payout, Payout Link</p></td></tr></tbody></table></div><h2 data-block-id=\"7ae25833-1a45-4534-8566-fc8d06501a1e\">Códigos de Canal</h2><p data-block-id=\"be1814c3-09d8-4b27-b64e-855ab92603ef\">Conozca los diferentes destinos de Payout que admitimos junto con su información específica de destino en la siguiente tabla:</p><p data-block-id=\"f2691562-8574-49b0-a304-9ea461bdebff\"><iframe src=\"https://airtable.com/embed/appYc7UnQq5CmKe0G/shreOseokgEGz9fMg?viewControls=on\" frameborder=\"0\" allowfullscreen=\"true\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" title style=\"background:transparent;border:1px solid #ccc;width:100%;height:533px;display:flex;margin-right:auto;\" width=\"100%\" height=\"533\" onmousewheel></iframe>  </p><h2 data-block-id=\"mei91ulz-j8gayp-001\">Valores Requeridos para Cross-Border Payouts</h2><p data-block-id=\"mei91ulz-ffpu5f-002\">Como requisito previo para crear un Cross-Border Payout, se le solicita que nos envíe la información del remitente y del destinatario final. Conozca la información requerida para la región para comenzar a enviar Payouts:</p><h3 data-block-id=\"mei91ulz-locd5d-003\">Remitente</h3><div data-type=\"table-content\"><table width=\"948\" class=\"editor360-table\" borderstyle=\"solid\" style=\"max-width:948px;width:948px;\"><colgroup><col style=\"width:316px;\"><col style=\"width:316px;\"><col style=\"width:316px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"mei91um0-7crnz0-004\">Parámetro de Campo</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"mei91um0-kig7go-005\">Tipo</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id=\"mei91um0-s9yzol-006\">Descripción</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\" style=\"vertical-align:middle;box-sizing:border-box;padding:10px;\"><p data-block-id=\"mei91um0-j1vncd-007\"><code>first_name</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"316\"><p data-block-id