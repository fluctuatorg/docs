[{"Code":"en","Title":"Mandiri Cards - Switcher","Slug":"draft-mandiri-cards-switcher","ContentType":2,"Content":"<p data-block-id=\"mm2yg5ua-ox7djp-093\"><a id=\"_vpxm85nexyyh\" display=\"false\"></a></p><h1 data-block-id=\"mm2yg5ub-xu5mpm-094\"><a id=\"_cgq5oqxzdqds\" display=\"false\"></a></h1><h1 data-block-id=\"mm2yg5ub-pddkat-095\"><a id=\"_ejxly55we75x\" display=\"false\"></a>Xendit Stakeholders</h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ub-qzo4ba-096\"><strong>Department</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uc-t0hfb1-097\"><strong>PIC</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uc-ni6gg9-098\"><strong>PIC Role</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uc-23fs5g-099\">Partnership</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uc-vt90wk-100\"><a><u>Ferdinand Kusuma</u></a></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uc-h9hx6f-101\">Partnership PIC for Mandiri</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ud-0owc46-102\">Cards Team</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ud-wfk2rr-103\"><u>Simon</u></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ud-pxlz5l-104\">Product Manager (Cards)</p></th></tr></tbody></table></div><h1 data-block-id=\"mm2yg5ud-pigy50-105\"><a id=\"_eo72pz5za9ta\" display=\"false\"></a></h1><h1 data-block-id=\"mm2yg5ud-835bf4-106\"><a id=\"_x5gzec6f0lg\" display=\"false\"></a>Related Documents</h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ud-fhzsta-107\"><strong>Document name</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ud-a6ug95-108\"><strong>Description</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ue-jyxq7z-109\"><strong>Link to document</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ue-rfpy6m-110\">MID Account Creation on Cybersource Portal (EBC)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ue-038fdy-111\">Step of MID configuration on EBC and Admin Dashboard</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ue-xcneuz-112\"><a href=\"https://xendit.atlassian.net/wiki/spaces/CA/pages/2292154681/Create+MID+on+Admin+Dashboard#Cybersource-Credentials\"><u>EBC Configuration</u></a></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ue-3t1nil-113\">FDS Form</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ue-egtlm3-114\">Form need to be filled and sent to merchant</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uf-zpqtwr-115\"><a href=\"https://docs.google.com/document/d/16iCrk8zzKk4U-qSa2jbOvDD0Fnq79H3W/edit\"><u>FORM FDS NON-AGGREGATOR .docx</u></a></p></th></tr></tbody></table></div><h1 data-block-id=\"mm2yg5uf-caq5i7-116\"><a id=\"_5yqvg3bbyu21\" display=\"false\"></a></h1><h1 data-block-id=\"mm2yg5uf-6hsn1r-117\"><a id=\"_hbvftyg2k24s\" display=\"false\"></a>Eligibility</h1><h1 data-block-id=\"mm2yg5uf-9mm6b0-118\"><a id=\"_audslu4b8jx\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uf-m0bkju-119\"><strong>Entity Type</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uf-xxdmk0-120\"><strong>Can Apply for Mandiri Cards Aggregator</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uf-da3jag-121\">Indonesian Entity (PT/CV/Yayasan)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uf-myhxiw-122\">✅</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ug-ehxeu5-123\">Indonesian Entity (Perseroan perorangan/PP)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ug-ld849i-124\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ug-o8owws-125\">Indonesian Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ug-9kwlno-126\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ug-clg8re-127\">Foreign Entity</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uh-xjnq9c-128\">❌</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uh-9v3pup-129\">Foreign Individual</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uh-p0tx6u-130\">❌</p></th></tr></tbody></table></div><h1 data-block-id=\"mm2yg5uh-4k23ks-131\"><a id=\"_acexhig5p7db\" display=\"false\"></a>Industry Restriction</h1><p data-block-id=\"mm2yg5uh-on28hq-132\"><em>*) notes: there were some exceptions made if sales are really pushing for this. MO will to coordinate with partnership for partnerships to negotiate with partner</em></p><h1 data-block-id=\"mm2yg5uh-7zelg9-133\"><a id=\"_opno5zvq83i1\" display=\"false\"></a></h1><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uh-eq0u5d-134\"><strong>Industry</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ui-iafglx-135\"><strong>List of Business</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"5\"><p data-block-id=\"mm2yg5ui-npt2vx-136\">Pornographic/adult services/night club</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ui-satet7-137\">Sale of dangerous products/services, i.e. weaponry, illegal drugs, and narcotics</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ui-ydt0ga-138\">Gambling</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ui-oaje1u-139\">Sale of fake/imitated goods in which breaches the intellectual/property rights</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ui-9dh6ir-140\">Merchants that indicated/suspected as platform offering illegal cash-out (gesek tunai/gestun)</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uj-opgbsg-141\">Jasa Titip</p></th></tr><tr><th colspan=\"1\" rowspan=\"5\"><p data-block-id=\"mm2yg5uj-d29yyf-142\">Financial institutions</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uj-6x0d4x-143\">Banks and Remittance</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uj-d1ad7k-144\">Peer to Peer lending without license/not registered in Otoritas Jasa Keuangan (OJK)</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uj-cg7kei-145\">Payment Gateway or business that can potentially act as an aggregator</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uj-8sudl2-146\">Merchants classified as Financial Tech or Digital Finance companies without Bank Indonesia license</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uk-kugvrr-147\">Merchants classified as Financial Tech companies without license/not registered in OJK</p></th></tr><tr><th colspan=\"1\" rowspan=\"3\"><p data-block-id=\"mm2yg5uk-m7fklg-148\">Non-financial businesses that require licensing</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uk-6i8bj6-149\">Sale of alcohol/liquor/booze without license</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uk-sc976g-150\">Sale of living creatures without license i.e breeder, kennel, adoption center</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uk-u8oweq-151\">Business which product/services is yet to be licensed by authorities</p></th></tr></tbody></table></div><h1 data-block-id=\"mm2yg5uk-2xl0cc-152\"><a id=\"_p9ni9b15e5wm\" display=\"false\"></a></h1><h1 data-block-id=\"mm2yg5uk-obbc5q-153\"><a id=\"_mlq067tta99i\" display=\"false\"></a>Onboarding flow</h1><p data-block-id=\"mm2yg5uk-cij34m-154\">  </p><h1 data-block-id=\"mm2yg5uk-4xm26t-155\"><a id=\"_ozyaieexd4q6\" display=\"false\"></a></h1><h3 data-block-id=\"mm2yg5uk-7ui77e-156\"><a id=\"_3atiw2hwzzkt\" display=\"false\"></a>Merchant Requirements </h3><p data-block-id=\"mm2yg5uk-xxxib6-157\">Below are the requirements that a merchant has to submit, whether it’s upon onboarding or VA application request</p><h3 data-block-id=\"mm2yg5uk-cpigvr-158\"><a id=\"_6qs1laq7u8zd\" display=\"false\"></a>Onboarding</h3><ol data-block-id=\"mm2yg5ul-v8vlcu-159\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm2yg5ul-d5yikh-160\"><p data-block-id=\"mm2yj8ki-xppfut-248\">FDS Mandiri Switcher </p></li><li data-block-id=\"mm2yg5ul-motut5-161\"><p data-block-id=\"mn5lab4v-f178wk-013\"><a href=\"https://docs.google.com/document/d/1gC-uzZPFLCgzgc4wioRTz54PHCM_fYRB/edit\"><u>FDS Form</u></a></p></li><li data-block-id=\"mm2yg5ul-bd8yce-162\"><p data-block-id=\"mn5lab4v-vqv0sf-014\">Website</p><ol data-block-id=\"mm2yg5ul-dfeec3-163\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm2yg5ul-e2ljsk-164\"><p data-block-id=\"mn5lab4v-nnqqn6-015\">No Social Media and Micro-Ecommerce</p></li><li data-block-id=\"mm2yg5ul-9m7b5j-165\"><p data-block-id=\"mn5lab4v-iuklum-016\">If a website, website must be active and fully running, i.e:</p><ol data-block-id=\"mm2yg5ul-tstmys-166\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm2yg5ul-yqzava-167\"><p data-block-id=\"mn5lab4v-zn2ya6-017\">Link is accessible</p></li><li data-block-id=\"mm2yg5ul-gg7nps-168\"><p data-block-id=\"mn5lab4v-vq0emq-018\">Show product/ service</p></li><li data-block-id=\"mm2yg5ul-ek0pcp-169\"><p data-block-id=\"mn5lab4v-d3e0ht-019\">Price in IDR</p></li><li data-block-id=\"mm2yg5ul-1fl4mj-170\"><p data-block-id=\"mn5lab4v-5m7x41-020\">Not a template or “coming soon” website</p></li></ol></li><li data-block-id=\"mm2yg5ul-uieqx2-171\"><p data-block-id=\"mn5lab4v-hf36mt-021\">If an app, app is listed in PlayStore / AppStore</p></li></ol></li></ol><h1 data-block-id=\"mm2yg5ul-kxffd1-172\"><a id=\"_eer2kk965by4\" display=\"false\"></a>Activation SLA</h1><p data-block-id=\"mm2yg5ul-sbpmn9-173\">Mandiri Cards Aggregator activated in 21 working days from the date merchant submits complete requirements to MO</p><h2 data-block-id=\"mm2yg5ul-petc6y-174\"><a id=\"_tpuqyi7ndjx\" display=\"false\"></a></h2><p data-block-id=\"mn5lab4v-pbnudt-022\"><a id=\"5g4lycwbgoe0\" display=\"false\"></a></p><h2 data-block-id=\"mm2yg5ul-56jiqr-175\"><a id=\"_j34hgihjlfzy\" display=\"false\"></a>Pre-Activation Steps</h2><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ul-1d3m3a-176\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5um-dzbula-177\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5um-5p75e9-178\"><strong>Owner</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5um-829ysm-179\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5um-x6x1ud-180\">Merchant request Mandiri Switcher Cards via Sales/AM</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5um-ijtkua-181\">Sales/AM</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5um-k33gy2-182\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5un-syiz1i-183\">Sales/AM request MO to process FDS by filling <a href=\"https://docs.google.com/forms/d/e/1FAIpQLSdjyRSewzWHOCnSSQe3RqX06ELY4DHbA1MI43p9-uQCDjmgbQ/viewform\"><u>form</u></a></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5un-w0z19b-184\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5un-buc836-185\">2a</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5un-bzyk6o-186\">Sales/AM fill out merchant’s detail on the FDS form (uploaded to the above gform)</p><p data-block-id=\"mm2yg5un-pc7cjb-187\"><img data-block-id=\"mm2yg5un-tmcd57-188\" src=\"https://cdn.document360.io/217abc43-8677-41fb-a81d-fceeb1fa0358/Images/Documentation/draft-mandiri-cards-switcher-image-ke6dveiz.png\" class=\"adv-wysiwyg-img\" mediatype=\"img\" alt=\"\" width=\"auto\" height=\"auto\" dataalign=\"left\" datadisplay=\"flex\" data-type=\"media-content\" fixaspectratio=\"false\" autoaspectratio=\"false\" shadow=\"no\" border=\"no\" round=\"no\" link=\"\" newtab=\"\" style=\"width:auto;height:auto;\"></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5un-2bh9bf-189\">Sales/AM</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5un-f7jmwd-190\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uo-18sd5p-191\">MO will send <a href=\"https://docs.google.com/document/d/16iCrk8zzKk4U-qSa2jbOvDD0Fnq79H3W/edit\"><u>FDS Form</u></a> to Merchant and Merchant Risk <a><u>Thiraz yusuf</u></a> with subject <strong><em>FDS - {Merchant Name} Mandiri Switcher </em></strong>via Juro.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uo-y5vj27-192\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uo-5fftuo-193\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uo-y4t5ez-194\">Once fully-signed, MO will send the FDS to merchant</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uo-naor80-195\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uo-12wqxs-196\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5up-562v3p-197\">Mandiri will send MIDs directly to merchant and merchant will relay the details to their Sales Rep/AM</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5up-xww1rv-198\">-</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5up-jhkeko-199\">6</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5up-dg5jqa-200\">Sales Rep/AM will relay MIDs to MO (<a href=\"https://xendit.slack.com/archives/CRCJ2E5CK/p1673917306465089\"><u>ref</u></a>)</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5up-2gpvmw-201\">Sales Rep/AM</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5up-clb0mm-202\">7</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uq-2oz20q-203\">MO proceeds with Activation</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uq-31b31w-204\">MO</p></th></tr></tbody></table></div><h1 data-block-id=\"mm2yg5uq-qpzj3v-205\"><a id=\"_ynjvtd9cvxcn\" display=\"false\"></a></h1><h1 data-block-id=\"mm2yg5uq-qd587e-206\"><a id=\"_dyjk5zsj8pp1\" display=\"false\"></a></h1><h2 data-block-id=\"mm2yg5uq-4ybch7-207\"><a id=\"_m5b14r4s1l6z\" display=\"false\"></a>Activation Steps</h2><p data-block-id=\"mm2yg5uq-zs28od-208\">(Relevant only to Merchant Ops)</p><div data-type=\"table-content\"><table width=\"100%\" class=\"editor360-table\" borderstyle=\"solid\"><colgroup style=\"display:none;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"><col style=\"width:250px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uq-fqltyp-209\"><strong>Category</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uq-7dtu3j-210\"><strong>No</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uq-xkfzrc-211\"><strong>Steps</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uq-snx2zz-212\"><strong>Owner</strong></p></th></tr><tr><th colspan=\"1\" rowspan=\"4\"><p data-block-id=\"mm2yg5ur-mbpu9k-213\">MO Process Merchant’s Application</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ur-pzyd23-214\">1</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ur-jb80ka-215\">MO will send <a href=\"https://docs.google.com/document/d/1gC-uzZPFLCgzgc4wioRTz54PHCM_fYRB/edit\"><u>FDS Form</u></a> to Merchant Risk <a>thiraz@xendit.co</a> / <a>andriani@xendit.co</a> and merchant with subject <strong><em>FDS - {Merchant Name} Mandiri Switcher </em></strong>via Spotdraft.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ur-dbbebf-216\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ur-wzwkn4-217\">2</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ur-60w9kf-218\">MO have to check this channel <strong>#hellosign-alfamart-kredivo-Mandiri</strong></p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5us-vkqhtp-219\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5us-9jxrun-220\">3</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5us-mte6nm-221\">Once signed, MO has to email the form directly to Mandiri</p><p data-block-id=\"mm2yg5us-4vcd21-222\"><br type=\"inline\">Subject: [merchantops] Rekomendasi Merchant Mandiri Cards Switcher - <em>merchant name</em><br type=\"inline\">To:<em> </em><a><em><u>ecommerce@yokke.co.id</u></em></a><em>, </em><a><em><u>Dea.Asril@bankmandiri.co.id</u></em></a><em> <br type=\"inline\">Cc:  </em><a><em><u>ferdinand@xendit.co</u></em></a><em> , </em><a><em><u>merchantops@xendit.co</u></em></a><em>, </em><a><em><u>cards@xendit.co</u></em></a><em>, </em></p><p data-block-id=\"mm2yg5ut-rsvflv-225\"><strong><em>AM/Sales email address</em></strong><em>, </em><a><em><u>alvin.kristanto@xendit.co</u></em></a><em>, </em><a><em><u>syuhada.sipayung@xendit.co</u></em></a><em> </em></p><p data-block-id=\"mm2yg5ut-ujqtuu-226\">Dear Mandiri team,</p><p data-block-id=\"mm2yg5ut-7b2ndn-227\">Berikut terlampir pengajuan pendaftaran Cards Switcher Xendit pada <em>tanggal, bulan, tahun</em>. Total terdapat 1 merchant :</p><ol data-block-id=\"mm2yg5ut-pz6bfq-228\" start=\"1\" style=\"--start:0;\"><li data-block-id=\"mm2yg5ut-ahhk4w-229\"><p data-block-id=\"mn5lab50-1ru3nw-023\"><em>Merchant name</em> - cards non installment dan installment 3,6,12 months</p></li></ol><p data-block-id=\"mm2yg5ut-vnvgsu-230\">Mohon untuk dapat diproses dan didaftarkan. Apabila terdapat kekurangan informasi maupun dokumen harap menghubungi kami kembali.</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ut-giyouk-231\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ut-fbx6jy-232\">4</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ut-39b6vz-233\">Mandiri will give the MID by replying to MerchantOps email, and MO have to onboard it to the <a href=\"https://ebc.cybersource.com/ebc2/\"><u>EBC</u></a> portal by following this <a href=\"https://xendit.atlassian.net/wiki/spaces/CA/pages/2292154681/Create+MID+on+Admin+Dashboard#Cybersource-Credentials\"><u>SOP</u></a>. </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5ut-2cuopq-234\">MO</p></th></tr><tr><th colspan=\"1\" rowspan=\"3\"><p data-block-id=\"mm2yg5uu-d8f99t-235\">Cards Testing</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uu-qzca0w-236\">5</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uu-ugymaz-237\">After onboard to EBC Portal, MO will tag<strong> @merchantops-id-cards </strong>to do UAT.  </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uu-vlyh39-238\">MO Cards</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uu-6f5rpk-239\">6</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uu-ee21lb-240\">After the UAT process is completed, MO cards will ask Sales / AM regarding the settlement. </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uu-79ohlk-241\">MO Cards</p></th></tr><tr><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uv-ddbts3-242\">7</p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uv-onoqws-243\">Will inform merchant notification that Mandiri Cards Switcher is ready to use. </p></th><th colspan=\"1\" rowspan=\"1\"><p data-block-id=\"mm2yg5uv-calphu-244\">MO</p></th></tr></tbody></table></div><h1 data-block-id=\"mm2yg5uv-mn05s8-245\"><a id=\"_5wvr60goc0et\" display=\"false\"></a></h1><p data-block-id=\"mn5lab51-s2jffm-024\"></p>","SeoTitle":"Mandiri Cards - Switcher","Description":null},{"Code":"id","Title":"Cards Mandiri - Switcher","Slug":"cards-mandiri-switcher","ContentType":2,"Content":null,"SeoTitle":"Cards Mandiri - Switcher","Description":null},{"Code":"th","Title":"Cards Mandiri - Switcher","Slug":"cards-mandiri-switcher","ContentType":2,"Content":null,"SeoTitle":"Cards Mandiri - Switcher","Description":null},{"Code":"es-mx","Title":"Cards Mandiri - Switcher","Slug":"cards-mandiri-switcher","ContentType":2,"Content":null,"SeoTitle":"Cards Mandiri - Switcher","Description":null}]