g:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"957d2006-c589-4751-a1a0-174321a498e2\">❌</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"3795b679-c38a-4fae-88f4-7a3498c5b08e\">Refund Validity (days)</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"9f5634ea-ac19-47ae-9a88-b4b2d4a3d107\">N/A</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"d1760170-fa28-4c8b-b533-419100be3192\">Compatible integration</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"463\" style=\"overflow:hidden;padding:2px 3px 2px 3px;vertical-align:bottom;\"><p data-block-id=\"60823a34-d1b1-427e-90ab-60a877255f19\">Payment API, Payment Link</p></td></tr></tbody></table></div><h2 data-block-id=\"2b081c08-ffd2-493a-b253-c4931f5f1c75\">Payment flow</h2><p data-block-id=\"3a86b5ec-38da-4400-83d2-ef1024cbe6c9\"></p><p data-block-id=\"12295416-ce37-4b1f-ae9c-e422707d5254\"></p><p data-block-id=\"8e9aac87-b7ff-4f0e-b9c9-0178d8f76e42\"></p><p data-block-id=\"1fba7422-3f0f-475f-a3cd-ed72e33bce4f\"></p><p data-block-id=\"acd97665-43b1-498b-89ca-e66b24c0a68f\"></p><p data-block-id=\"490a489a-2a58-4dc9-96ea-9e5cc09fc8be\"></p>","SeoTitle":"China Bank Online Banking","Description":null},{"Code":"id","Title":"China Bank Internet Banking","Slug":"china-bank-online-banking","ContentType":2,"Content":"<style> p[data-block-id] {font-size:1rem;} ul li p[data-block-id] {margin-bottom: 0;} ul[data-type=\"taskList\"] li div p[data-block-id] {margin-bottom: 0;} ol li p[data-block-id] {margin-bottom: 0;} table tbody th p[data-block-id] { margin-bottom: 0;} blockquote p[data-block-id] {margin-bottom: 0 !important;}  p[data-block-id]:empty::after {content: \"\\00A0\";} </style><p data-block-id=\"0